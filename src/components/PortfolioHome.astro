---
import type { HomeContent, ClusterKey, PanelId } from '../data/homeContent';

interface Props {
  content: HomeContent;
}

const { content } = Astro.props;
const projectSummary = content.tabs.summaries.projects;
const interactiveContent = {
  summaries: content.tabs.summaries,
  featuredToggle: content.featured.toggle,
  form: content.contact.form,
  graph: content.cloud.graphNodes,
};

const clusterClass: Record<ClusterKey, string> = {
  health: 'health',
  models: 'models',
  ops: 'ops',
};

const panelIds: PanelId[] = ['projects', 'methodtab', 'stack', 'background'];
---
<!doctype html>
<html lang={content.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{content.title}</title>
  <meta name="description" content={content.description} />
  <link rel="alternate" hreflang={content.alternateHrefLang} href={content.alternateHref} />
  <link rel="icon" href="/assets/logo/monogram.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Poppins:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root{
      --bg:#06070a;
      --bg-soft:#0e1117;
      --ink:#f5f1e8;
      --soft:#cdc4b4;
      --muted:#93897a;
      --line:rgba(245,241,232,.12);
      --panel:rgba(255,255,255,.04);
      --health:#14b8a6;
      --models:#a78bfa;
      --ops:#fbbf24;
      --shadow:0 30px 80px rgba(0,0,0,.28);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth;background:var(--bg)}
    body{
      margin:0;
      color:var(--ink);
      background:
        radial-gradient(circle at 14% 12%, rgba(20,184,166,.10), transparent 22%),
        radial-gradient(circle at 88% 3%, rgba(167,139,250,.11), transparent 24%),
        radial-gradient(circle at 62% 82%, rgba(251,191,36,.08), transparent 28%),
        linear-gradient(180deg, #06070a 0%, #090c11 48%, #06070a 100%);
      font-family:'Poppins',sans-serif;
      overflow-x:hidden;
    }
    body::before,
    body::after{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:-1;
    }
    body::before{
      opacity:.18;
      background-image:
        linear-gradient(rgba(245,241,232,.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,241,232,.018) 1px, transparent 1px);
      background-size:96px 96px;
      mask-image:linear-gradient(to bottom, black, transparent 82%);
    }
    body::after{
      opacity:.05;
      background-image:radial-gradient(rgba(255,255,255,.9) .6px, transparent .8px);
      background-size:10px 10px;
      mix-blend-mode:soft-light;
    }
    a{color:inherit;text-decoration:none}
    button,
    input,
    textarea{font:inherit}
    .frame{display:grid;grid-template-columns:minmax(320px,28vw) 1fr;min-height:100vh}
    .side{
      position:sticky;
      top:0;
      height:100vh;
      padding:42px 34px 34px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:24px;
      border-right:1px solid var(--line);
      overflow:hidden;
      background:linear-gradient(180deg, rgba(6,7,10,.94), rgba(6,7,10,.82));
      backdrop-filter:blur(14px);
    }
    .side-top{display:grid;gap:26px}
    .brand{display:flex;align-items:center;gap:16px}
    .brand img{width:68px;height:68px;border-radius:20px;background:#fff}
    .brand strong{display:block;font-size:21px;line-height:.96;letter-spacing:-.05em}
    .brand span{display:block;color:var(--soft);font-size:15px;font-weight:300;margin-top:6px}
    .intro-card{
      padding:28px 0 0;
      border-top:1px solid var(--line);
    }
    .intro-card p{
      margin:0;
      color:var(--ink);
      font-size:20px;
      line-height:1.24;
      letter-spacing:-.05em;
      max-width:16ch;
    }
    .side-viz{
      height:252px;
      border:1px solid var(--line);
      border-radius:32px;
      position:relative;
      overflow:hidden;
      background:
        radial-gradient(circle at 28% 28%, rgba(20,184,166,.12), transparent 34%),
        radial-gradient(circle at 76% 24%, rgba(167,139,250,.12), transparent 28%),
        radial-gradient(circle at 58% 82%, rgba(251,191,36,.10), transparent 26%),
        rgba(255,255,255,.02);
    }
    .side-viz canvas{position:absolute;inset:0;width:100%;height:100%}
    .side-viz::after{
      content:attr(data-label);
      position:absolute;
      left:16px;
      bottom:14px;
      color:var(--muted);
      font:700 9px 'Space Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.14em;
    }
    .links{
      display:grid;
      border-top:1px solid var(--line);
    }
    .links a{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:18px 6px;
      border-bottom:1px solid var(--line);
      color:var(--soft);
      font-size:13px;
      font-weight:500;
      letter-spacing:.02em;
    }
    .main{padding:22px 42px 110px;min-width:0}
    .topnav{
      width:fit-content;
      min-height:64px;
      display:flex;
      justify-content:flex-end;
      gap:22px;
      align-items:center;
      padding:12px 20px;
      margin:6px 0 0 auto;
      border:1px solid var(--line);
      border-radius:999px;
      position:sticky;
      top:14px;
      z-index:20;
      background:linear-gradient(180deg, rgba(7,8,11,.98), rgba(7,8,11,.88));
      backdrop-filter:blur(18px);
      box-shadow:0 16px 50px rgba(0,0,0,.18);
    }
    .topnav a,
    .eyebrow,
    .tabbtn,
    .cloud-btn,
    .featured-label,
    .card-metric,
    .meta-line,
    label,
    .cluster-label{
      font-family:'Space Mono',monospace;
    }
    .topnav a{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.12em;
      color:var(--soft);
      white-space:nowrap;
    }
    .lang{
      border:1px solid var(--line);
      padding:8px 11px;
      border-radius:999px;
    }
    .hero{
      min-height:calc(100vh - 86px);
      display:grid;
      align-items:end;
      padding:84px 0 70px;
    }
    .eyebrow{
      margin:0 0 18px;
      font-size:11px;
      letter-spacing:.18em;
      text-transform:uppercase;
      color:var(--soft);
    }
    .hero h1{
      margin:0;
      max-width:1040px;
      font-size:clamp(64px,9vw,146px);
      line-height:.82;
      letter-spacing:-.08em;
      font-weight:300;
    }
    .hero h1 em{
      font-family:'DM Serif Display',serif;
      font-style:italic;
      font-weight:400;
      color:var(--ink);
      letter-spacing:-.03em;
    }
    .split{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(340px,.92fr);
      gap:28px;
      border-top:1px solid var(--line);
      margin-top:30px;
      padding-top:24px;
    }
    .split p{
      margin:0;
      color:var(--soft);
      font-size:17px;
      line-height:1.72;
      max-width:38ch;
    }
    .hero-metrics{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }
    .hero-metric{
      border:1px solid var(--line);
      border-radius:24px;
      padding:18px 18px 20px;
      background:rgba(255,255,255,.03);
    }
    .hero-metric strong{
      display:block;
      margin-bottom:10px;
      font:700 18px 'Space Mono',monospace;
      color:var(--ink);
      letter-spacing:.03em;
    }
    .hero-metric span{
      display:block;
      color:var(--soft);
      font-size:14px;
      line-height:1.55;
    }
    .section{padding:84px 0}
    .about-shell,
    .featured-shell{
      border:1px solid var(--line);
      border-radius:38px;
      padding:40px 40px 44px;
      background:rgba(255,255,255,.022);
      box-shadow:var(--shadow);
    }
    .about-head,
    .featured-head,
    .title,
    .contact-layout{
      display:grid;
      grid-template-columns:minmax(240px,.62fr) minmax(0,1.38fr);
      gap:44px;
    }
    .about-title h2,
    .title h2,
    .contact h2,
    .cloud-copy h2,
    .featured-intro h2{
      margin:0;
      font-size:clamp(34px,4vw,62px);
      line-height:.98;
      letter-spacing:-.06em;
      font-weight:300;
    }
    .section-accent{
      font-family:'DM Serif Display',serif;
      font-style:italic;
      letter-spacing:-.02em;
    }
    .about-text{
      display:grid;
      gap:18px;
    }
    .about-text p,
    .cloud-copy p,
    .featured-copy > p:last-of-type,
    .summary p,
    .note{
      margin:0;
      color:var(--soft);
      font-size:16px;
      line-height:1.72;
    }
    .about-cards,
    .grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
      margin-top:28px;
    }
    .about-card,
    .box,
    .summary,
    .card,
    form{
      border:1px solid var(--line);
      border-radius:28px;
      background:rgba(255,255,255,.024);
    }
    .about-card,
    .box{
      padding:24px;
    }
    .about-card span,
    .box span{
      display:block;
      margin-bottom:14px;
      color:var(--muted);
      font:700 12px 'Space Mono',monospace;
      letter-spacing:.1em;
      text-transform:uppercase;
    }
    .about-card h3,
    .box h3{
      margin:0 0 10px;
      font-size:24px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .about-card p,
    .box p{
      margin:0;
      color:var(--soft);
      line-height:1.68;
    }
    .cloud-section{height:250vh;position:relative}
    .cloud-pin{
      position:sticky;
      top:60px;
      height:calc(100vh - 60px);
      display:grid;
      grid-template-columns:minmax(280px,.58fr) minmax(0,1.42fr);
      gap:42px;
      align-items:center;
    }
    .cloud-copy{
      display:grid;
      gap:18px;
      align-content:center;
      max-width:32ch;
    }
    .actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:10px;
    }
    .cloud-btn{
      appearance:none;
      border:1px solid var(--line);
      border-radius:999px;
      padding:12px 16px;
      background:transparent;
      color:var(--ink);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      transition:transform .2s ease,border-color .2s ease,background .2s ease;
      cursor:pointer;
    }
    .cloud-btn:hover{transform:translateY(-1px);border-color:rgba(245,241,232,.22)}
    .cloud-btn.primary{
      background:var(--ink);
      border-color:var(--ink);
      color:var(--bg);
    }
    .cloud-stage{
      position:relative;
      height:min(78vh,720px);
      min-height:520px;
      border:1px solid var(--line);
      border-radius:40px;
      overflow:hidden;
      background:
        radial-gradient(circle at 20% 28%, rgba(20,184,166,.08), transparent 26%),
        radial-gradient(circle at 77% 25%, rgba(167,139,250,.10), transparent 24%),
        radial-gradient(circle at 54% 72%, rgba(251,191,36,.08), transparent 28%),
        rgba(255,255,255,.02);
    }
    .graph-canvas{position:absolute;inset:0;width:100%;height:100%}
    .cluster-label{
      position:absolute;
      font-size:10px;
      letter-spacing:.16em;
      text-transform:uppercase;
      color:var(--soft);
      text-shadow:0 1px 14px rgba(0,0,0,.6);
    }
    .cluster-label--health{left:11%;top:18%}
    .cluster-label--models{right:9%;top:16%}
    .cluster-label--ops{left:48%;bottom:15%}
    .featured-shell{background:rgba(18,26,31,.82)}
    .featured-head{
      gap:48px;
      padding-top:26px;
      border-top:1px solid var(--line);
    }
    .featured-intro{
      display:grid;
      align-content:start;
      gap:14px;
    }
    .featured-intro h2{
      margin:0;
      max-width:10ch;
    }
    .featured-copy{
      display:grid;
      gap:18px;
      align-content:start;
    }
    .featured-question{
      margin:0;
      max-width:24ch;
      font-size:clamp(28px,3.1vw,42px);
      line-height:1.22;
      letter-spacing:-.05em;
      font-weight:300;
      color:var(--ink);
    }
    .featured-copy > p:last-of-type{
      max-width:66ch;
    }
    .featured-stats{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
      margin-top:6px;
    }
    .featured-stat,
    .featured-detail article,
    .project-meta div{
      border:1px solid var(--line);
      border-radius:22px;
      padding:16px 16px 18px;
      background:rgba(255,255,255,.03);
    }
    .featured-label,
    .project-meta span{
      display:block;
      color:var(--muted);
      font-size:9px;
      letter-spacing:.12em;
      text-transform:uppercase;
    }
    .featured-stat strong{
      display:block;
      margin-top:10px;
      color:var(--ink);
      font:700 22px 'Space Mono',monospace;
      letter-spacing:.05em;
    }
    .featured-stat p{margin:10px 0 0;font-size:14px;line-height:1.62;color:var(--soft)}
    .featured-toggle,
    .btn,
    .featured-actions a,
    .card-actions a,
    button[type="submit"]{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border:1px solid var(--line);
      border-radius:999px;
      padding:12px 16px;
      background:transparent;
      color:var(--ink);
      font-size:11px;
      font-weight:600;
      letter-spacing:.08em;
      text-transform:uppercase;
      transition:transform .2s ease,border-color .2s ease,background .2s ease,color .2s ease;
      cursor:pointer;
    }
    .featured-toggle:hover,
    .btn:hover,
    .featured-actions a:hover,
    .card-actions a:hover,
    button[type="submit"]:hover{transform:translateY(-1px);border-color:rgba(245,241,232,.22)}
    .featured-toggle{
      margin-top:8px;
      width:max-content;
    }
    .featured-detail{
      display:none;
      margin-top:24px;
      padding-top:24px;
      border-top:1px solid var(--line);
    }
    .featured-detail.open{display:block}
    .featured-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:16px;
    }
    .featured-detail h3{
      margin:10px 0 10px;
      font-size:24px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .featured-detail p{
      margin:0;
      color:var(--soft);
      font-size:15px;
      line-height:1.72;
    }
    .featured-actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:20px;
    }
    .featured-actions .primary,
    .card-actions .primary,
    button[type="submit"]{
      background:var(--ink);
      border-color:var(--ink);
      color:var(--bg);
    }
    .tabs{
      padding:104px 0;
      border-top:1px solid var(--line);
      border-bottom:1px solid var(--line);
    }
    .title{
      margin-bottom:30px;
    }
    .tabbar{
      position:sticky;
      top:60px;
      z-index:18;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      padding:14px 0 18px;
      margin-bottom:18px;
      background:linear-gradient(180deg, rgba(6,7,10,.98), rgba(6,7,10,.80));
    }
    .tabbtn{
      appearance:none;
      border:1px solid var(--line);
      border-radius:999px;
      padding:10px 14px;
      background:transparent;
      color:var(--soft);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .tabbtn.active{
      background:var(--ink);
      color:var(--bg);
      border-color:var(--ink);
    }
    .summary{
      display:grid;
      grid-template-columns:.7fr 1.3fr;
      gap:18px;
      margin-bottom:18px;
      padding:22px;
    }
    .summary strong{
      font-size:23px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .panel{display:none;animation:panel .36s ease both}
    .panel.active{display:block}
    @keyframes panel{
      from{opacity:0;transform:translateY(12px)}
      to{opacity:1;transform:none}
    }
    #projects{gap:18px}
    #projects.active{display:grid}
    .card{
      position:relative;
      display:grid;
      grid-template-columns:74px minmax(0,1fr);
      gap:30px;
      align-items:start;
      padding:36px 34px 34px;
    }
    .card::before{
      content:"";
      position:absolute;
      left:0;
      top:24px;
      bottom:24px;
      width:2px;
      border-radius:999px;
    }
    .card--health::before{background:var(--health)}
    .card--models::before{background:var(--models)}
    .card--ops::before{background:var(--ops)}
    .num{
      font-size:34px;
      font-weight:300;
      color:var(--muted);
      letter-spacing:-.08em;
    }
    .card-metric{
      margin:0 0 12px;
      color:var(--ink);
      font-size:17px;
      font-weight:700;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .card h3{
      margin:0 0 14px;
      font-size:clamp(28px,4vw,52px);
      line-height:1;
      letter-spacing:-.06em;
      font-weight:300;
      max-width:18ch;
    }
    .card p{font-size:16px;line-height:1.68;color:var(--soft);margin:0}
    .project-meta{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
      margin-top:20px;
    }
    .project-meta strong{
      display:block;
      margin:10px 0 8px;
      color:var(--ink);
      font-size:21px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .project-meta small{display:block;color:var(--soft);line-height:1.58}
    .meta-line{
      margin-top:18px;
      padding-top:16px;
      border-top:1px solid var(--line);
      color:var(--soft);
      font-size:12px;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .card-actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:22px;
      grid-column:2;
    }
    .box{min-height:100%}
    .box span{margin-bottom:18px}
    .box--health span{color:var(--health)}
    .box--models span{color:var(--models)}
    .box--ops span{color:var(--ops)}
    .contact-divider{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:0;
      margin:32px 0 0;
    }
    .contact-divider span{height:2px}
    .contact-divider span:nth-child(1){background:var(--health)}
    .contact-divider span:nth-child(2){background:var(--models)}
    .contact-divider span:nth-child(3){background:var(--ops)}
    .contact{padding:90px 0 40px}
    .contact-layout{
      gap:54px;
      margin-top:32px;
      align-items:start;
    }
    .contact-layout > div:first-child{
      max-width:34ch;
      display:grid;
      gap:18px;
    }
    .row{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }
    form{
      padding:30px 30px 32px;
      display:grid;
      gap:14px;
    }
    label{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.12em;
      color:var(--soft);
    }
    input,
    textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:22px;
      padding:18px 20px;
      background:rgba(255,255,255,.02);
      color:var(--ink);
      outline:none;
    }
    textarea{
      min-height:186px;
      resize:vertical;
    }
    .submit-btn{
      width:max-content;
      min-width:190px;
      margin-top:8px;
    }
    .reveal,
    .card,
    .box,
    .about-card,
    .featured-shell{
      opacity:0;
      transform:translateY(24px);
      transition:opacity .7s ease, transform .7s ease;
    }
    .reveal.in,
    .card.in,
    .box.in,
    .about-card.in,
    .featured-shell.in{opacity:1;transform:none}
    @media (max-width: 1180px){
      .about-head,
      .featured-head,
      .title,
      .contact-layout,
      .summary{
        grid-template-columns:1fr;
      }
      .featured-intro h2,
      .featured-question,
      .featured-copy > p:last-of-type{max-width:none}
    }
    @media (max-width: 920px){
      .frame{display:block}
      .side{
        position:relative;
        height:auto;
        min-height:0;
        padding:28px 24px 24px;
        border-right:0;
        border-bottom:1px solid var(--line);
      }
      .side-top{gap:22px}
      .intro-card p{max-width:20ch}
      .side-viz{height:292px}
      .main{padding:0 18px 72px}
      .topnav{
        justify-content:flex-start;
        overflow-x:auto;
        width:100%;
        margin:0;
        border-radius:26px;
      }
      .topnav::-webkit-scrollbar,
      .tabbar::-webkit-scrollbar{display:none}
      .hero{
        min-height:auto;
        padding:58px 0 64px;
      }
      .split,
      .hero-metrics,
      .cloud-pin,
      .project-meta,
      #stack .grid,
      #background .grid{
        grid-template-columns:1fr;
      }
      .cloud-section{height:auto}
      .cloud-pin{
        position:relative;
        top:auto;
        height:auto;
        display:block;
        padding:72px 0;
      }
      .cloud-copy{
        max-width:none;
        margin-bottom:28px;
      }
      .cloud-stage{
        height:460px;
        min-height:460px;
      }
      .cluster-label{font-size:9px}
      .featured-shell,
      .about-shell{padding:32px 24px 34px}
      .featured-copy{padding-top:0}
      .featured-stats,
      .featured-grid,
      .about-cards,
      .grid{
        grid-template-columns:1fr;
      }
      .tabs{padding:82px 0}
      .tabbar{
        position:relative;
        top:auto;
        flex-wrap:nowrap;
        overflow-x:auto;
        margin-left:-18px;
        margin-right:-18px;
        padding:14px 18px 18px;
      }
      .card{
        grid-template-columns:1fr;
        gap:20px;
        padding:28px 24px 28px 28px;
      }
      .card-actions{
        grid-column:auto;
        margin-top:20px;
      }
      .contact{padding-top:76px}
      form{padding:24px 22px 26px}
    }
    @media (max-width: 720px){
      .main{padding:0 16px 66px}
      .side{padding:24px 18px 20px}
      .brand strong{font-size:19px}
      .brand span{font-size:14px}
      .hero h1{font-size:clamp(54px,18vw,76px)}
      .split{gap:20px}
      .hero-metric{padding:16px}
      .cloud-stage{height:380px;min-height:380px}
      .featured-question{font-size:24px}
      .featured-detail h3{font-size:22px}
      .project-meta strong{font-size:19px}
      .meta-line{font-size:11px;line-height:1.7}
      .submit-btn{width:100%}
    }
    @media (max-width: 520px){
      .hero{padding:50px 0 56px}
      .hero h1{font-size:52px}
      .eyebrow{font-size:10px}
      .summary strong{font-size:21px}
      .summary p,
      .featured-detail p,
      .note,
      .box p,
      .about-card p,
      .card p{font-size:14.5px}
      .featured-question{font-size:22px}
      .featured-shell,
      .about-shell{padding:28px 20px 30px}
      .card{padding:24px 20px 24px 24px}
      .cloud-stage{height:340px;min-height:340px}
      .contact-layout{gap:32px}
    }
  </style>
</head>
<body>
  <div class="frame">
    <aside class="side">
      <div class="side-top">
        <div class="brand">
          <img src="/assets/logo/monogram.svg" alt="Luanda Rodrigues monogram" />
          <div>
            <strong>Luanda Rodrigues,</strong>
            <span>{content.sidebar.role}</span>
          </div>
        </div>
        <div class="intro-card">
          <p>{content.sidebar.intro}</p>
        </div>
        <div class="side-viz" data-label={content.sidebar.graphLabel}>
          <canvas id="sideGraphCanvas"></canvas>
        </div>
      </div>
      <div class="links">
        {content.sidebar.links.map((link) => (
          <a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
            {link.label} <span>&nearr;</span>
          </a>
        ))}
      </div>
    </aside>

    <main class="main">
      <nav class="topnav">
        {content.topNav.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
        <a class="lang" href={content.languageSwitch.href}>{content.languageSwitch.label}</a>
      </nav>

      <section class="hero">
        <div>
          <p class="eyebrow reveal">{content.hero.eyebrow}</p>
          <h1 class="reveal">{content.hero.title.before}<em>{content.hero.title.accent}</em>{content.hero.title.after}</h1>
          <div class="split reveal">
            <p>{content.hero.copy}</p>
            <div class="hero-metrics">
              {content.hero.metrics.map((metric) => (
                <div class="hero-metric">
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="about section" id="about">
        <div class="about-shell reveal">
          <div class="about-head">
            <div class="about-title">
              <p class="eyebrow">{content.about.eyebrow}</p>
              <h2>{content.about.title}<span class="section-accent">{content.about.accent}</span></h2>
            </div>
            <div class="about-text">
              {content.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
          <div class="about-cards">
            {content.about.cards.map((card) => (
              <article class={`about-card box--${card.cluster ?? 'health'}`}>
                <span>{card.label}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="cloud-section" id="method">
        <div class="cloud-pin">
          <div class="cloud-copy">
            <p class="eyebrow">{content.cloud.eyebrow}</p>
            <h2>{content.cloud.title}</h2>
            <p>{content.cloud.copy}</p>
            <div class="actions">
              <button class="cloud-btn primary" id="clusterCloud" type="button">{content.cloud.actions.cluster}</button>
              <button class="cloud-btn" id="shuffleCloud" type="button">{content.cloud.actions.spread}</button>
            </div>
          </div>
          <div class="cloud-stage" id="cloudStage">
            <canvas class="graph-canvas" id="graphCanvas"></canvas>
            <div class="cluster-label cluster-label--health">{content.cloud.labels.health}</div>
            <div class="cluster-label cluster-label--models">{content.cloud.labels.models}</div>
            <div class="cluster-label cluster-label--ops">{content.cloud.labels.ops}</div>
          </div>
        </div>
      </section>

      <section class="featured section" id="featured">
        <div class="featured-shell reveal">
          <p class="eyebrow">{content.featured.eyebrow}</p>
          <div class="featured-head">
            <div class="featured-intro">
              <h2>{content.featured.title}</h2>
            </div>
            <div class="featured-copy">
              <p class="featured-question">{content.featured.question}</p>
              <p>{content.featured.summary}</p>
              <div class="featured-stats">
                {content.featured.stats.map((stat) => (
                  <div class="featured-stat">
                    <span class="featured-label">{stat.label}</span>
                    <strong>{stat.value}</strong>
                    <p>{stat.text}</p>
                  </div>
                ))}
              </div>
              <button class="featured-toggle" id="featuredToggle" type="button" aria-expanded="false" aria-controls="featuredDetail">{content.featured.toggle.open}</button>
            </div>
          </div>
          <div class="featured-detail" id="featuredDetail">
            <div class="featured-grid">
              {content.featured.detail.map((article) => (
                <article>
                  <span class="featured-label">{article.label}</span>
                  <h3>{article.title}</h3>
                  <p>{article.text}</p>
                </article>
              ))}
            </div>
            <div class="featured-actions">
              {content.featured.actions.map((action, index) => (
                <a
                  class={index === 0 ? 'primary' : undefined}
                  href={action.href}
                  target={action.external ? '_blank' : undefined}
                  rel={action.external ? 'noreferrer' : undefined}
                >
                  {action.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="tabs" id="work">
        <div class="title">
          <p class="eyebrow">{content.tabs.sectionEyebrow}</p>
          <h2>{content.tabs.title}<span class="section-accent">{content.tabs.accent}</span></h2>
        </div>
        <div class="tabbar">
          {content.tabs.buttons.map((button, index) => (
            <button class:list={['tabbtn', { active: index === 0 }]} data-tab={button.id} type="button">{button.label}</button>
          ))}
        </div>
        <div class="summary">
          <strong id="tabTitle">{projectSummary[0]}</strong>
          <p id="tabText">{projectSummary[1]}</p>
        </div>

        <div class="panel active" id="projects">
          {content.projects.map((project) => (
            <article class={`card card--${clusterClass[project.cluster]}`}>
              <span class="num">{project.number}</span>
              <div>
                <p class="card-metric">{project.metric}</p>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
                <div class="project-meta">
                  {project.meta.map((item) => (
                    <div>
                      <span>{item.label}</span>
                      <strong>{item.title}</strong>
                      <small>{item.text}</small>
                    </div>
                  ))}
                </div>
                <p class="meta-line">{project.metaLine}</p>
                <div class="card-actions">
                  {project.actions.map((action, index) => (
                    <a
                      class={index === 0 ? 'primary' : 'secondary'}
                      href={action.href}
                      target={action.external ? '_blank' : undefined}
                      rel={action.external ? 'noreferrer' : undefined}
                    >
                      {action.label}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="panel" id="methodtab">
          <div class="grid">
            {content.tabs.method.map((item) => (
              <div class={`box box--${item.cluster ?? 'health'}`}>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="panel" id="stack">
          <div class="grid">
            {content.tabs.stack.map((item) => (
              <div class="box">
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="panel" id="background">
          <div class="grid">
            {content.tabs.background.map((item) => (
              <div class="box">
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="contact-divider" aria-hidden="true">
        <span></span><span></span><span></span>
      </section>

      <section class="contact" id="contact">
        <div>
          <p class="eyebrow">{content.contact.eyebrow}</p>
          <h2>{content.contact.title}<span class="section-accent">{content.contact.accent}</span></h2>
          <div class="contact-layout">
            <div>
              <p class="note">{content.contact.note}</p>
              <div class="row">
                {content.contact.social.map((link) => (
                  <a class="btn" href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>{link.label}</a>
                ))}
              </div>
            </div>
            <form id="contactForm">
              <label for="name">{content.contact.form.labels.name}</label>
              <input id="name" placeholder={content.contact.form.placeholders.name} required />
              <label for="company">{content.contact.form.labels.company}</label>
              <input id="company" placeholder={content.contact.form.placeholders.company} />
              <label for="email">{content.contact.form.labels.email}</label>
              <input id="email" type="email" placeholder={content.contact.form.placeholders.email} />
              <label for="message">{content.contact.form.labels.message}</label>
              <textarea id="message" placeholder={content.contact.form.placeholders.message} required></textarea>
              <button class="submit-btn" type="submit">{content.contact.form.button}</button>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script define:vars={{ interactiveContent }}>
    function initMiniGraph() {
      const canvas = document.getElementById('sideGraphCanvas');
      if (!canvas) return;
      const box = canvas.parentElement;
      const ctx = canvas.getContext('2d');
      if (!box || !ctx) return;
      let width = 0;
      let height = 0;
      let dpr = 1;
      let points = [];

      function size() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = box.clientWidth;
        height = box.clientHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = width + 'px';
        canvas.style.height = height + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function reset() {
        size();
        points = [];
        const hubs = [
          [0.26, 0.36, '#14b8a6'],
          [0.68, 0.34, '#a78bfa'],
          [0.52, 0.72, '#fbbf24'],
        ];

        hubs.forEach((hub, hubIndex) => {
          points.push({ x: width * hub[0], y: height * hub[1], vx: 0, vy: 0, r: 4.4, c: hub[2], hub: true, group: hubIndex });
          for (let i = 0; i < 18; i += 1) {
            const angle = Math.random() * Math.PI * 2;
            const radius = 28 + Math.random() * 76;
            points.push({
              x: width * hub[0] + Math.cos(angle) * radius,
              y: height * hub[1] + Math.sin(angle) * radius,
              vx: (Math.random() - 0.5) * 0.5,
              vy: (Math.random() - 0.5) * 0.5,
              r: 1.3 + Math.random() * 1.7,
              c: hub[2],
              group: hubIndex
            });
          }
        });
      }

      function draw() {
        ctx.clearRect(0, 0, width, height);
        points.forEach((point, index) => {
          point.x += point.vx + Math.sin(Date.now() / 650 + index) * 0.06;
          point.y += point.vy + Math.cos(Date.now() / 720 + index) * 0.06;
          if (point.x < 14 || point.x > width - 14) point.vx *= -1;
          if (point.y < 14 || point.y > height - 24) point.vy *= -1;
        });
        for (let i = 0; i < points.length; i += 1) {
          for (let j = i + 1; j < points.length; j += 1) {
            const a = points[i];
            const b = points[j];
            const distance = Math.hypot(a.x - b.x, a.y - b.y);
            if (distance < 104 && (a.group === b.group || distance < 52)) {
              ctx.globalAlpha = Math.max(0.04, 0.24 - distance / 420);
              ctx.strokeStyle = a.group === b.group ? '#d2cec5' : '#6f6b63';
              ctx.lineWidth = a.hub || b.hub ? 0.75 : 0.45;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
        points.forEach((point) => {
          ctx.globalAlpha = point.hub ? 0.95 : 0.76;
          ctx.fillStyle = point.c;
          ctx.beginPath();
          ctx.arc(point.x, point.y, point.r, 0, Math.PI * 2);
          ctx.fill();
          if (point.hub) {
            ctx.globalAlpha = 0.12;
            ctx.beginPath();
            ctx.arc(point.x, point.y, 34, 0, Math.PI * 2);
            ctx.fill();
          }
        });
        requestAnimationFrame(draw);
      }

      window.addEventListener('resize', reset);
      reset();
      draw();
    }

    initMiniGraph();

    const tabTitle = document.getElementById('tabTitle');
    const tabText = document.getElementById('tabText');
    const tabButtons = Array.from(document.querySelectorAll('.tabbtn'));
    const panels = Array.from(document.querySelectorAll('.panel'));

    function setTab(id) {
      tabButtons.forEach((button) => {
        button.classList.toggle('active', button.dataset.tab === id);
      });
      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.id === id);
      });
      if (tabTitle && tabText && interactiveContent.summaries[id]) {
        tabTitle.textContent = interactiveContent.summaries[id][0];
        tabText.textContent = interactiveContent.summaries[id][1];
      }
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => setTab(button.dataset.tab));
    });

    const featuredToggle = document.getElementById('featuredToggle');
    const featuredDetail = document.getElementById('featuredDetail');

    if (featuredToggle && featuredDetail) {
      featuredToggle.addEventListener('click', () => {
        const expanded = featuredToggle.getAttribute('aria-expanded') === 'true';
        featuredToggle.setAttribute('aria-expanded', String(!expanded));
        featuredDetail.classList.toggle('open', !expanded);
        featuredToggle.textContent = expanded ? interactiveContent.featuredToggle.open : interactiveContent.featuredToggle.close;
      });
    }

    const contactForm = document.getElementById('contactForm');

    if (contactForm) {
      contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const button = contactForm.querySelector('button');
        if (!button) return;
        button.textContent = interactiveContent.form.sending;
        const data = {
          name: document.getElementById('name').value,
          company: document.getElementById('company').value,
          email: document.getElementById('email').value,
          message: document.getElementById('message').value
        };

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (!response.ok) throw new Error('request failed');
          button.textContent = interactiveContent.form.sent;
          contactForm.reset();
        } catch (error) {
          button.textContent = interactiveContent.form.fallback;
          location.href = 'mailto:luandarodrigues30@gmail.com';
        }
      });
    }

    const stage = document.getElementById('cloudStage');
    const graphCanvas = document.getElementById('graphCanvas');
    const graphCtx = graphCanvas ? graphCanvas.getContext('2d') : null;
    const mobileBreakpoint = 520;
    let graphWidth = 0;
    let graphHeight = 0;
    let graphDpr = 1;
    let nodes = [];
    let edges = [];
    let mode = 'cluster';
    let compactGraph = window.innerWidth < mobileBreakpoint;

    function getGroups() {
      return [
        { name: 'health', color: '#14b8a6', cx: 0.26, cy: 0.34, count: compactGraph ? 28 : 70, labels: interactiveContent.graph.health },
        { name: 'models', color: '#a78bfa', cx: 0.73, cy: 0.33, count: compactGraph ? 26 : 62, labels: interactiveContent.graph.models },
        { name: 'ops', color: '#fbbf24', cx: 0.56, cy: 0.74, count: compactGraph ? 30 : 74, labels: interactiveContent.graph.ops }
      ];
    }

    let groups = getGroups();

    function resizeGraph() {
      if (!stage || !graphCanvas || !graphCtx) return;
      graphDpr = Math.min(window.devicePixelRatio || 1, 2);
      graphWidth = stage.clientWidth;
      graphHeight = stage.clientHeight;
      graphCanvas.width = graphWidth * graphDpr;
      graphCanvas.height = graphHeight * graphDpr;
      graphCanvas.style.width = graphWidth + 'px';
      graphCanvas.style.height = graphHeight + 'px';
      graphCtx.setTransform(graphDpr, 0, 0, graphDpr, 0, 0);
    }

    function setTargets(kind) {
      mode = kind;
      groups.forEach((group) => {
        const list = nodes.filter((node) => node.group === group.name);
        const cx = graphWidth * group.cx;
        const cy = graphHeight * group.cy;
        list.forEach((node, index) => {
          if (kind === 'cluster') {
            const angle = index * 0.62;
            const radius = node.hub ? 0 : (node.major ? 48 + Math.random() * 52 : 74 + Math.random() * Math.min(graphWidth, graphHeight) * 0.21);
            node.tx = cx + Math.cos(angle) * radius;
            node.ty = cy + Math.sin(angle) * radius;
          } else {
            const angle = Math.random() * Math.PI * 2;
            const radius = Math.sqrt(Math.random()) * Math.min(graphWidth, graphHeight) * 0.42;
            node.tx = graphWidth * 0.5 + Math.cos(angle) * radius;
            node.ty = graphHeight * 0.52 + Math.sin(angle) * radius;
          }
        });
      });
    }

    function buildGraph() {
      if (!stage || !graphCanvas || !graphCtx) return;
      resizeGraph();
      nodes = [];
      edges = [];
      groups = getGroups();
      let id = 0;
      groups.forEach((group) => {
        const hub = { id: id += 1, group: group.name, color: group.color, label: group.name, x: graphWidth * group.cx, y: graphHeight * group.cy, tx: graphWidth * group.cx, ty: graphHeight * group.cy, r: 7, hub: true };
        nodes.push(hub);
        group.labels.forEach((label) => {
          nodes.push({
            id: id += 1,
            group: group.name,
            color: group.color,
            label,
            x: graphWidth * (group.cx + (Math.random() - 0.5) * 0.25),
            y: graphHeight * (group.cy + (Math.random() - 0.5) * 0.25),
            r: 3.6,
            major: true
          });
        });
        for (let i = 0; i < group.count; i += 1) {
          nodes.push({
            id: id += 1,
            group: group.name,
            color: group.color,
            label: '',
            x: graphWidth * (group.cx + (Math.random() - 0.5) * 0.35),
            y: graphHeight * (group.cy + (Math.random() - 0.5) * 0.35),
            r: 1.7 + Math.random() * 1.8
          });
        }
      });

      nodes.forEach((node) => {
        const sameGroup = nodes.filter((candidate) => candidate.group === node.group && candidate !== node);
        for (let i = 0; i < (node.hub ? 18 : node.major ? 4 : 1); i += 1) {
          const randomNode = sameGroup[Math.floor(Math.random() * sameGroup.length)];
          if (randomNode) edges.push([node, randomNode]);
        }
        if (Math.random() < 0.14) {
          const other = nodes[Math.floor(Math.random() * nodes.length)];
          if (other && other.group !== node.group) edges.push([node, other]);
        }
      });

      setTargets('cluster');
    }

    function drawGraph() {
      if (!graphCtx) return;
      graphCtx.clearRect(0, 0, graphWidth, graphHeight);
      nodes.forEach((node) => {
        node.x += (node.tx - node.x) * 0.05;
        node.y += (node.ty - node.y) * 0.05;
        node.x += Math.sin(Date.now() / 900 + node.id) * 0.08;
        node.y += Math.cos(Date.now() / 1000 + node.id) * 0.08;
      });

      graphCtx.lineWidth = 0.65;
      edges.forEach(([a, b]) => {
        const distance = Math.hypot(a.x - b.x, a.y - b.y);
        if (distance < 240) {
          graphCtx.globalAlpha = Math.max(0.03, 0.22 - distance / 1000);
          graphCtx.strokeStyle = '#8f8a81';
          graphCtx.beginPath();
          graphCtx.moveTo(a.x, a.y);
          graphCtx.lineTo(b.x, b.y);
          graphCtx.stroke();
        }
      });

      nodes.forEach((node) => {
        graphCtx.globalAlpha = node.hub ? 0.95 : node.major ? 0.84 : 0.68;
        graphCtx.fillStyle = node.hub ? '#f5f1e8' : node.color;
        graphCtx.beginPath();
        graphCtx.arc(node.x, node.y, node.r, 0, Math.PI * 2);
        graphCtx.fill();
        if (node.major || node.hub) {
          graphCtx.globalAlpha = 0.66;
          graphCtx.font = (node.hub ? '700 12px ' : '500 10px ') + 'Space Mono';
          graphCtx.fillStyle = '#d5d0c7';
          graphCtx.fillText(node.label, node.x + 8, node.y - 8);
        }
      });

      requestAnimationFrame(drawGraph);
    }

    if (stage && graphCanvas && graphCtx) {
      stage.addEventListener('click', () => setTargets(mode === 'cluster' ? 'spread' : 'cluster'));
      document.getElementById('shuffleCloud')?.addEventListener('click', () => setTargets('spread'));
      document.getElementById('clusterCloud')?.addEventListener('click', () => setTargets('cluster'));
      window.addEventListener('resize', () => {
        const nextCompact = window.innerWidth < mobileBreakpoint;
        if (nextCompact !== compactGraph) {
          compactGraph = nextCompact;
          buildGraph();
          return;
        }
        resizeGraph();
        setTargets(mode);
      });
      buildGraph();
      drawGraph();
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('in');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal,.card,.box,.about-card,.featured-shell').forEach((element) => {
      observer.observe(element);
    });
  </script>
</body>
</html>
