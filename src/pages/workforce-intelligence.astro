            </article>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    function initMiniGraph() {
      const canvas = document.getElementById("sideGraphCanvas");
      if (!canvas) return;
      const box = canvas.parentElement;
      const context = canvas.getContext("2d");
      let width = 0;
      let height = 0;
      let dpr = 1;
      let points = [];

      function resize() {
        dpr = Math.min(devicePixelRatio || 1, 2);
        width = box.clientWidth;
        height = box.clientHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        context.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function reset() {
        resize();
        points = [];
        const hubs = [
          [0.24, 0.34, "#d7ff6f"],
          [0.62, 0.43, "#98c1ff"],
          [0.45, 0.72, "#f7f3ea"],
        ];
        hubs.forEach((hub, groupIndex) => {
          points.push({ x: width * hub[0], y: height * hub[1], vx: 0, vy: 0, r: 4.2, c: hub[2], hub: true, group: groupIndex });
          for (let index = 0; index < 18; index += 1) {
            const angle = Math.random() * Math.PI * 2;
            const radius = 28 + Math.random() * 78;
            points.push({
              x: width * hub[0] + Math.cos(angle) * radius,
              y: height * hub[1] + Math.sin(angle) * radius,
              vx: (Math.random() - 0.5) * 0.55,
              vy: (Math.random() - 0.5) * 0.55,
              r: 1.3 + Math.random() * 1.8,
              c: hub[2],
              group: groupIndex,
            });
          }
        });
      }

      function draw() {
        context.clearRect(0, 0, width, height);
        points.forEach((point, index) => {
          point.x += point.vx + Math.sin(Date.now() / 650 + index) * 0.06;
          point.y += point.vy + Math.cos(Date.now() / 730 + index) * 0.06;
          if (point.x < 14 || point.x > width - 14) point.vx *= -1;
          if (point.y < 14 || point.y > height - 26) point.vy *= -1;
        });
        for (let firstIndex = 0; firstIndex < points.length; firstIndex += 1) {
          for (let secondIndex = firstIndex + 1; secondIndex < points.length; secondIndex += 1) {
            const first = points[firstIndex];
            const second = points[secondIndex];
            const distance = Math.hypot(first.x - second.x, first.y - second.y);
            if (distance < 100 && (first.group === second.group || distance < 52)) {
              context.globalAlpha = Math.max(0.04, 0.25 - distance / 410);
              context.strokeStyle = first.group === second.group ? "#d9d9d9" : "#8d8d8d";
              context.lineWidth = first.hub || second.hub ? 0.75 : 0.45;
              context.beginPath();
              context.moveTo(first.x, first.y);
              context.lineTo(second.x, second.y);
              context.stroke();
            }
          }
        }
        points.forEach((point) => {
          context.globalAlpha = point.hub ? 0.92 : 0.74;
          context.fillStyle = point.c;
          context.beginPath();
          context.arc(point.x, point.y, point.r, 0, Math.PI * 2);
          context.fill();
          if (point.hub) {
            context.globalAlpha = 0.15;
            context.beginPath();
            context.arc(point.x, point.y, 34, 0, Math.PI * 2);
            context.fill();
          }
        });
        requestAnimationFrame(draw);
      }

      addEventListener("resize", reset);
      reset();
      draw();
    }

    initMiniGraph();

    const state = {
      activeTab: "executive",
      department_name: [],
      job_role: [],
      risk_band: [],
      salary_band: [],
    };

    const copy = {
      filterLabels: {
        department_name: "Department",
        job_role: "Job Role",
        risk_band: "Risk Band",
        salary_band: "Salary Band",
      },
      tabs: {
        executive: {
          label: "Executive",
          eyebrow: "Executive view",
          title: "Business-facing workforce readout",
          text: "This cut brings workforce size, attrition, retention priority, and market pressure into one cleaner executive layer.",
          rail: [
            { value: "01", label: "retention focus" },
            { value: "02", label: "cost exposure" },
            { value: "03", label: "market pressure" },
          ],
          kpis: [
            { key: "headcount", label: "Headcount", format: "count" },
            { key: "attritionRate", label: "Attrition Rate", format: "percent" },
            { key: "highRiskEmployees", label: "High Risk Employees", format: "count" },
            { key: "averageTenure", label: "Average Tenure", format: "decimal" },
            { key: "replacementCost", label: "Replacement Cost", format: "currencyCompact" },
            { key: "externalPressure", label: "External Pressure", format: "decimal" },
          ],
          narrativeTitle: "What stands out in the current cut",
        },
        risk: {
          label: "Attrition Risk",
          eyebrow: "Risk view",
          title: "Where modeled risk is concentrated",
          text: "This cut isolates the attrition scoring layer, surfacing which roles, pay bands, drivers, and actions matter most.",
          rail: [
            { value: "Risk", label: "modeled layer" },
            { value: "Role", label: "exposure view" },
            { value: "Action", label: "guided readout" },
          ],
          kpis: [
            { key: "highRiskEmployees", label: "High Risk Employees", format: "count" },
            { key: "averageRiskScore", label: "Average Risk Score", format: "decimal" },
            { key: "overtimeRate", label: "Overtime Rate", format: "percent" },
            { key: "attritionRate", label: "Attrition Rate", format: "percent" },
            { key: "replacementCost", label: "Replacement Cost", format: "currencyCompact" },
            { key: "averageTenure", label: "Average Tenure", format: "decimal" },
          ],
          narrativeTitle: "How the risk layer should be read",
        },
        market: {
          label: "Labor Pressure",
          eyebrow: "Market view",
          title: "What the external layer changes",
          text: "This cut isolates the labor-market context that can make some workforce segments harder to replace or retain.",
          rail: [
            { value: "BLS", label: "context layer" },
            { value: "Roles", label: "occupation mapping" },
            { value: "Pressure", label: "retention pull" },
          ],
          kpis: [
            { key: "unemploymentRate", label: "Unemployment Rate", format: "decimal" },
            { key: "wageIndex", label: "Wage Index", format: "decimal" },
            { key: "laborDemandIndex", label: "Labor Demand Index", format: "decimal" },
            { key: "externalPressure", label: "External Pressure", format: "decimal" },
            { key: "replacementCost", label: "Replacement Cost", format: "currencyCompact" },
            { key: "headcount", label: "Headcount", format: "count" },
          ],
          narrativeTitle: "How the market layer changes the read",
        },
      },
      noResults: "No records match the current filter selection.",
    };

    async function loadCaseData() {
      const response = await fetch("/data/workforce-intelligence.en.json");
      return response.json();
    }

    function formatValue(value, kind) {
      if (kind === "percent") return `${(value * 100).toFixed(1)}%`;
      if (kind === "currencyCompact") {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          notation: "compact",
          maximumFractionDigits: 1,
        }).format(value);
      }
      if (kind === "count") return new Intl.NumberFormat("en-US", { notation: "compact" }).format(value);
      return Number(value || 0).toFixed(2).replace(/\.00$/, "");
    }

    function escapeLabel(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    function shortLabel(value, max = 24) {
      const text = String(value);
      return text.length > max ? `${text.slice(0, max - 1)}…` : text;
    }

    function filterRows(rows, filters) {
      return rows.filter((row) =>
        Object.entries(filters).every(([key, selected]) => {
          if (key === "activeTab" || !selected.length) return true;
          return selected.includes(row[key]);
        }),
      );
    }

    function computeMetrics(rows) {
      const uniqueEmployees = new Set(rows.map((row) => row.employee_id)).size;
      const rowCount = Math.max(rows.length, 1);
      const average = (field) => rows.reduce((sum, row) => sum + Number(row[field] || 0), 0) / rowCount;
      return {
        headcount: uniqueEmployees,
        attritionRate: average("attrition_flag"),
        highRiskEmployees: rows.filter((row) => row.risk_band === "High Risk").length,
        averageTenure: average("years_at_company"),
        replacementCost: rows.reduce((sum, row) => sum + Number(row.estimated_replacement_cost || 0), 0),
        externalPressure: average("external_pressure_score"),
        averageRiskScore: average("attrition_probability"),
        overtimeRate: average("overtime_flag"),
        unemploymentRate: average("unemployment_rate"),
        wageIndex: average("wage_index"),
        laborDemandIndex: average("labor_demand_index"),
      };
    }

    function groupAverage(rows, groupKey, valueKey, limit = null) {
      const groups = new Map();
      rows.forEach((row) => {
        const key = row[groupKey];
        if (!key) return;
        const value = Number(row[valueKey] || 0);
        if (!groups.has(key)) groups.set(key, { sum: 0, count: 0 });
        groups.get(key).sum += value;
        groups.get(key).count += 1;
      });
      const items = [...groups.entries()]
        .map(([label, aggregate]) => ({ label, value: aggregate.sum / Math.max(aggregate.count, 1) }))
        .sort((first, second) => second.value - first.value);
      return limit ? items.slice(0, limit) : items;
    }

    function countBy(rows, key, order = [], limit = null) {
      const counts = new Map(order.map((label) => [label, 0]));
      rows.forEach((row) => {
        const value = row[key];
        if (!value) return;
        counts.set(value, (counts.get(value) || 0) + 1);
      });
      const items = [...counts.entries()]
        .map(([label, value]) => ({ label, value }))
        .filter((item) => item.value > 0)
        .sort((first, second) => second.value - first.value);
      return limit ? items.slice(0, limit) : items;
    }

    function topRowsByAverage(rows, labelKey, metricKey, limit = 4) {
      return groupAverage(rows, labelKey, metricKey, limit);
    }

    function renderFilters(filterConfig) {
      document.getElementById("filterBar").innerHTML = Object.entries(filterConfig)
        .map(([key, values]) => {
          const selectedCount = state[key].length;
          return `
            <details class="filter-group">
              <summary>${copy.filterLabels[key]}${selectedCount ? ` · ${selectedCount}` : ""}</summary>
              <div class="filter-options">
                ${values
                  .map(
                    (value) => `
                      <label class="filter-option">
                        <input type="checkbox" data-filter="${key}" value="${value}" ${state[key].includes(value) ? "checked" : ""} />
                        <span>${value}</span>
                      </label>
                    `,
                  )
                  .join("")}
              </div>
            </details>
          `;
        })
        .join("");

      document.querySelectorAll("[data-filter]").forEach((input) => {
        input.addEventListener("change", (event) => {
          const { filter } = event.target.dataset;
          const { value, checked } = event.target;
          state[filter] = checked
            ? [...state[filter], value]
            : state[filter].filter((item) => item !== value);
          sync();
        });
      });
    }

    function renderTabs() {
      const entries = Object.entries(copy.tabs);
      document.getElementById("tabBar").innerHTML = entries
        .map(
          ([key, tab]) => `
            <button class="tab-button ${state.activeTab === key ? "active" : ""}" type="button" data-tab="${key}">
              ${tab.label}
            </button>
          `,
        )
        .join("");

      document.querySelectorAll("[data-tab]").forEach((button) => {
        button.addEventListener("click", () => {
          state.activeTab = button.dataset.tab;
          sync();
        });
      });
    }

    function renderTabFrame() {
      const tab = copy.tabs[state.activeTab];
      document.getElementById("tabEyebrow").textContent = tab.eyebrow;
      document.getElementById("tabTitle").textContent = tab.title;
      document.getElementById("tabText").textContent = tab.text;
      document.getElementById("narrativeTitle").textContent = tab.narrativeTitle;
      document.getElementById("tabRail").innerHTML = tab.rail
        .map(
          (item) => `
            <div>
              <strong>${item.value}</strong>
              <span>${item.label}</span>
            </div>
          `,
        )
        .join("");
    }

    function renderKPIs(metrics) {
      const cards = copy.tabs[state.activeTab].kpis;
      document.getElementById("kpiBand").innerHTML = cards
        .map(
          (item) => `
            <article class="kpi-card">
              <div class="kpi-value">${formatValue(metrics[item.key], item.format)}</div>
              <span class="kpi-label">${item.label}</span>
            </article>
          `,
        )
        .join("");
    }

    function renderHorizontalChart(items, formatter, palette = () => "#5ac8d8") {
      if (!items.length) return `<div class="empty-state">${copy.noResults}</div>`;
      const maxValue = Math.max(...items.map((item) => item.value), 1);
      const chartWidth = 620;
      const labelWidth = 188;
      const valueWidth = 84;
      const plotWidth = chartWidth - labelWidth - valueWidth - 12;
      const rowGap = 28;
      const barHeight = 18;
      const topPad = 18;
      const bottomPad = 18;
      const height = topPad + items.length * rowGap + bottomPad;

      return `
        <div class="chart-shell">
          <svg viewBox="0 0 ${chartWidth} ${height}" role="img" aria-label="dashboard chart">
            ${items
              .map((item, index) => {
                const y = topPad + index * rowGap;
                const width = Math.max((item.value / maxValue) * plotWidth, 8);
                return `
                  <text x="0" y="${y + 13}" fill="#f3eee4" style="font:600 12px Inter, sans-serif">
                    <title>${escapeLabel(item.label)}</title>${escapeLabel(shortLabel(item.label))}
                  </text>
                  <line x1="${labelWidth}" y1="${y + 9}" x2="${chartWidth - valueWidth}" y2="${y + 9}" stroke="rgba(255,255,255,.08)" stroke-width="1"></line>
                  <rect x="${labelWidth}" y="${y}" rx="9" ry="9" width="${width}" height="${barHeight}" fill="${palette(item.label, index)}"></rect>
                  <text x="${chartWidth - valueWidth + 8}" y="${y + 13}" fill="#fffaf2" style="font:700 11px 'IBM Plex Mono', monospace">${formatter(item.value)}</text>
                `;
              })
              .join("")}
            <line x1="${labelWidth}" y1="${height - 8}" x2="${chartWidth - valueWidth}" y2="${height - 8}" stroke="rgba(255,255,255,.2)" stroke-width="1"></line>
          </svg>
        </div>
      `;
    }

    function renderList(items, label = "records") {
      if (!items.length) return `<div class="empty-state">${copy.noResults}</div>`;
      return `
        <div class="list-shell">
          ${items
            .map(
              (item) => `
                <div class="list-row">
                  <div>
                    <strong>${escapeLabel(item.label)}</strong>
                    <span>${label}</span>
                  </div>
                  <em>${item.value.toLocaleString("en-US")}</em>
                </div>
              `,
            )
            .join("")}
        </div>
      `;
    }

    function executivePanels(rows) {
      const attritionByDepartment = groupAverage(rows, "department_name", "attrition_flag");
      const riskCounts = countBy(rows, "risk_band", ["High Risk", "Medium Risk", "Low Risk"]);
      const retentionPriority = groupAverage(rows, "department_name", "retention_priority_index");
      const externalPressure = groupAverage(rows, "occupation_group", "external_pressure_score");
      return {
        sectors: [
          {
            eyebrow: "Core signal",
            title: "Attrition and modeled risk",
            text: "This first sector keeps the internal signal clean: who is exposed, how much risk is concentrated, and where the executive story starts.",
            panels: [
              {
                title: "Attrition by Department",
                note: "filtered average attrition rate",
                copy: "This view keeps the department-level attrition signal visible without reducing the panel to one metric.",
                chart: renderHorizontalChart(attritionByDepartment, (value) => `${(value * 100).toFixed(1)}%`, () => "#5ac8d8"),
              },
              {
                title: "Risk Band Distribution",
                note: "employee counts by modeled band",
                copy: "The modeled bands keep the concentration of risk readable, especially when the high-risk slice is smaller but still urgent.",
                chart: renderHorizontalChart(riskCounts, (value) => value.toLocaleString("en-US"), (label) => {
                  if (label === "High Risk") return "#ff7676";
                  if (label === "Medium Risk") return "#f0b35f";
                  return "#5ac8d8";
                }),
              },
            ],
          },
          {
            eyebrow: "Decision layer",
            title: "Priority and market pull",
            text: "The second sector shifts from signal to action by combining internal vulnerability with market pressure in the same read.",
            panels: [
              {
                title: "Retention Priority by Department",
                note: "combined risk and pressure index",
                copy: "This is the more operational view: departments rise when internal vulnerability and external pull move together.",
                chart: renderHorizontalChart(retentionPriority, (value) => value.toFixed(2), () => "#98c1ff"),
              },
              {
                title: "External Pressure by Occupation Group",
                note: "market context by role exposure",
                copy: "The market layer shows which occupation groups are more exposed to labor pressure in the current cut.",
                chart: renderHorizontalChart(externalPressure, (value) => value.toFixed(2), () => "#d7ff6f"),
              },
            ],
          },
        ],
        readoutCards: [
          { label: "Attrition lead", value: attritionByDepartment[0]?.label || "N/A", text: "highest current attrition signal" },
          { label: "Priority lead", value: retentionPriority[0]?.label || "N/A", text: "highest retention priority in cut" },
          { label: "Market lead", value: externalPressure[0]?.label || "N/A", text: "largest external labor pressure" },
          { label: "High risk", value: countBy(rows, "risk_band", ["High Risk"])[0]?.value || 0, text: "employees currently in high risk" },
        ],
        notes: [
          {
            title: "Attrition becomes more useful with context",
            text: "This read combines internal workforce vulnerability with the external pull that can make talent harder to retain.",
          },
          {
            title: "Priority is what turns the panel operational",
            text: "Retention priority matters more than raw turnover because it starts to connect attrition, cost, and market exposure.",
          },
          {
            title: "The dashboard sits on reusable outputs",
            text: "Facts, dimensions, and metric logic were built to support downstream BI consumption, not just this page.",
          },
        ],
      };
    }

    function riskPanels(rows) {
      const riskByRole = groupAverage(rows, "job_role", "attrition_probability", 8);
      const riskBySalary = groupAverage(rows, "salary_band", "attrition_probability");
      const drivers = countBy(rows, "main_risk_driver", [], 4);
      const actions = countBy(rows, "recommended_action", [], 4);
      return {
        sectors: [
          {
            eyebrow: "Concentration",
            title: "Where modeled risk accumulates",
            text: "The first sector shows how the scoring layer concentrates risk across roles and pay structure after the current filters are applied.",
            panels: [
              {
                title: "Risk by Job Role",
                note: "average attrition probability",
                copy: "Role-level concentration shows where modeled risk is clustering after the current filters are applied.",
                chart: renderHorizontalChart(riskByRole, (value) => value.toFixed(2), () => "#98c1ff"),
              },
              {
                title: "Risk by Salary Band",
                note: "average attrition probability",
                copy: "This view isolates whether modeled risk is landing more heavily in lower, middle, or higher pay segments.",
                chart: renderHorizontalChart(riskBySalary, (value) => value.toFixed(2), () => "#5ac8d8"),
              },
            ],
          },
          {
            eyebrow: "Explainability",
            title: "Drivers and operational response",
            text: "The second sector is there to explain the score and push it closer to an action layer instead of a probability-only view.",
            panels: [
              {
                title: "Main Risk Drivers",
                note: "count of employees by dominant driver",
                copy: "The driver layer makes the score more explainable by surfacing the patterns behind the modeled risk.",
                chart: renderHorizontalChart(drivers, (value) => value.toLocaleString("en-US"), () => "#f0b35f"),
              },
              {
                title: "Recommended Actions",
                note: "count of employees by suggested action",
                copy: "The action layer turns the score into something closer to a planning conversation, not just a ranked list.",
                chart: renderList(actions, "recommended action counts"),
              },
            ],
          },
        ],
        readoutCards: [
          { label: "Top role", value: riskByRole[0]?.label || "N/A", text: "highest average attrition probability" },
          { label: "Top salary band", value: riskBySalary[0]?.label || "N/A", text: "highest average modeled risk" },
          { label: "Top driver", value: drivers[0]?.label || "N/A", text: "most common dominant driver" },
          { label: "Top action", value: actions[0]?.label || "N/A", text: "most common recommended action" },
        ],
        notes: [
          {
            title: "Modeled risk should still be explainable",
            text: "This section keeps the score interpretable by breaking it into role concentration, pay-band exposure, main drivers, and suggested actions.",
          },
          {
            title: "Overtime helps contextualize the score",
            text: "The KPI band adds overtime rate because work intensity is one of the most useful business-facing anchors for this risk layer.",
          },
