    function marketPanels(rows, metrics) {
      const byOccupation = groupAverage(rows, "occupation_group", "external_pressure_score");
      const byDepartment = groupAverage(rows, "department_name", "external_pressure_score");
      const byRole = groupAverage(rows, "job_role", "external_pressure_score", 8);
      const marketIndicators = [
        { label: "Unemployment Rate", value: metrics.unemploymentRate },
        { label: "Wage Index", value: metrics.wageIndex },
        { label: "Labor Demand Index", value: metrics.laborDemandIndex },
      ];
      return {
        sectors: [
          {
            eyebrow: "Exposure map",
            title: "Where the market pulls hardest",
            text: "This first market sector maps pressure back into workforce structure so the external layer stays legible for business users.",
            panels: [
              {
                title: "External Pressure by Occupation Group",
                note: "average external pressure score",
                copy: "Occupation groups are the cleanest way to read where the outside market is likely to pull hardest.",
                chart: renderHorizontalChart(byOccupation, (value) => value.toFixed(2), () => "#d7ff6f"),
              },
              {
                title: "Departments Exposed to Market Pressure",
                note: "average external pressure score",
                copy: "This translation back to departments shows where market pull becomes a workforce-planning issue inside the company.",
                chart: renderHorizontalChart(byDepartment, (value) => value.toFixed(2), () => "#98c1ff"),
              },
            ],
          },
          {
            eyebrow: "Signal layer",
            title: "What is feeding the pressure score",
            text: "This second sector isolates the indicators and role mapping that make the external score explainable rather than decorative.",
            panels: [
              {
                title: "Market Indicator Snapshot",
                note: "current external signal set",
                copy: "The market layer is made of unemployment, wage, and labor-demand signals that feed the pressure score.",
                chart: renderHorizontalChart(marketIndicators, (value) => value.toFixed(2), (label, index) => ["#ff7676", "#f0b35f", "#5ac8d8"][index] || "#5ac8d8"),
              },
              {
                title: "External Pressure by Job Role",
                note: "average external pressure score",
                copy: "This role cut helps connect occupation-level pressure back to the specific workforce roles shown in the case.",
                chart: renderHorizontalChart(byRole, (value) => value.toFixed(2), () => "#d7ff6f"),
              },
            ],
          },
        ],
        readoutCards: [
          { label: "Occupation lead", value: byOccupation[0]?.label || "N/A", text: "highest external pressure score" },
          { label: "Department lead", value: byDepartment[0]?.label || "N/A", text: "most exposed department in cut" },
          { label: "Wage index", value: formatValue(metrics.wageIndex, "decimal"), text: "current wage signal" },
          { label: "Labor demand", value: formatValue(metrics.laborDemandIndex, "decimal"), text: "current demand signal" },
        ],
        notes: [
          {
            title: "The external layer changes the story",
            text: "Even when attrition is flat, labor pressure can change how urgent a workforce segment becomes from a planning perspective.",
          },
          {
            title: "Occupation mapping is what makes the BI link work",
            text: "The market context becomes useful only when it can be translated back into the internal role structure that decision-makers know.",
          },
          {
            title: "This is still a governed data product",
            text: "The dashboard view is just one surface. The underlying value stays in the modeled tables and documented metrics that travel across tools.",
          },
        ],
      };
    }

    function renderPanels(panelData) {
      document.getElementById("dashboardGrid").innerHTML = panelData.sectors
        .map(
          (sector) => `
            <section class="sector-block">
              <div class="sector-head">
                <div>
                  <span class="eyebrow">${sector.eyebrow}</span>
                  <h4>${sector.title}</h4>
                </div>
                <p>${sector.text}</p>
              </div>
              <div class="sector-panels">
                ${sector.panels
                  .map(
                    (panel) => `
                        <article class="panel-card">
                          <div class="panel-head">
                            <h3>${panel.title}</h3>
                            <span class="panel-note">${panel.note}</span>
                          </div>
                          ${panel.chart}
                        </article>
                    `,
                  )
                  .join("")}
              </div>
            </section>
          `,
        )
        .join("");

      document.getElementById("readoutGrid").innerHTML = panelData.readoutCards
        .map(
          (card) => `
            <article class="readout-card">
              <span class="readout-label">${card.label}</span>
              <strong>${card.value}</strong>
              <span>${card.text}</span>
            </article>
          `,
        )
        .join("");

      document.getElementById("insightCopy").innerHTML = panelData.notes
        .map(
          (item) => `
            <article>
              <h4>${item.title}</h4>
              <p>${item.text}</p>
            </article>
          `,
        )
        .join("");
    }

    function renderHeroHighlights(metrics) {
      document.getElementById("heroHighlights").innerHTML = `
        <div class="hero-metric">
          <strong>${formatValue(metrics.headcount, "count")}</strong>
          <span class="hero-metric-label">Employees in current cut</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(metrics.attritionRate, "percent")}</strong>
          <span class="hero-metric-label">Attrition rate</span>
        </div>
        <div class="hero-metric">
          <strong>${metrics.highRiskEmployees}</strong>
          <span class="hero-metric-label">High-risk employees</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(metrics.replacementCost, "currencyCompact")}</strong>
          <span class="hero-metric-label">Replacement cost exposure</span>
        </div>
      `;
    }

    let caseData = null;

    function sync() {
      if (!caseData) return;
      renderFilters(caseData.filters);
      renderTabs();
      renderTabFrame();
      const filteredRows = filterRows(caseData.rows, state);
      const metrics = computeMetrics(filteredRows);
      renderHeroHighlights(metrics);
      renderKPIs(metrics);

      if (!filteredRows.length) {
        document.getElementById("dashboardGrid").innerHTML = `<div class="empty-state">${copy.noResults}</div>`;
        document.getElementById("readoutGrid").innerHTML = "";
        document.getElementById("insightCopy").innerHTML = "";
        return;
      }

      if (state.activeTab === "risk") {
        renderPanels(riskPanels(filteredRows));
      } else if (state.activeTab === "market") {
        renderPanels(marketPanels(filteredRows, metrics));
      } else {
        renderPanels(executivePanels(filteredRows));
      }
    }

    document.getElementById("resetFilters").addEventListener("click", () => {
      Object.keys(state).forEach((key) => {
        if (key !== "activeTab") state[key] = [];
      });
      sync();
    });

    loadCaseData().then((payload) => {
      caseData = payload;
      sync();
    });
  </script>
</body>
</html>
