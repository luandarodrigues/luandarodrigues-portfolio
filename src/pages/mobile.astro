<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Luanda Rodrigues | Mobile Portfolio</title>
  <meta name="description" content="Mobile-first portfolio of Luanda Rodrigues, Data Analyst focused on healthcare, BI, operations intelligence and machine learning." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#030303;
      --panel:#0b0b0b;
      --panel-2:#121212;
      --ink:#f7f5ef;
      --soft:#c9c4b8;
      --muted:#77736d;
      --line:rgba(247,245,239,.14);
      --acid:#d7ff6f;
      --blue:#9fc8ff;
      --red:#ff7777;
      --radius:26px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth;background:var(--bg)}
    body{
      margin:0;
      min-width:320px;
      background:
        radial-gradient(circle at 90% 0%,rgba(215,255,111,.15),transparent 26rem),
        radial-gradient(circle at 0% 22%,rgba(159,200,255,.11),transparent 22rem),
        var(--bg);
      color:var(--ink);
      font-family:Inter,system-ui,sans-serif;
      overflow-x:hidden;
    }
    a{color:inherit;text-decoration:none}
    button,input,textarea{font:inherit}

    .app{
      width:min(100%,520px);
      margin:0 auto;
      padding:18px 16px 96px;
    }

    .mobile-nav{
      position:sticky;
      top:0;
      z-index:50;
      margin:0 -16px 18px;
      padding:12px 16px;
      background:linear-gradient(to bottom,rgba(3,3,3,.96),rgba(3,3,3,.78));
      backdrop-filter:blur(18px);
      border-bottom:1px solid var(--line);
      display:flex;
      gap:8px;
      overflow-x:auto;
      scrollbar-width:none;
    }
    .mobile-nav::-webkit-scrollbar{display:none}
    .mobile-nav a{
      flex:0 0 auto;
      border:1px solid var(--line);
      border-radius:999px;
      padding:9px 12px;
      color:var(--soft);
      font:700 11px 'IBM Plex Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.08em;
      background:rgba(255,255,255,.03);
    }
    .mobile-nav a.primary{background:var(--acid);border-color:var(--acid);color:#030303}

    .hero-card{
      border:1px solid var(--line);
      border-radius:34px;
      padding:20px;
      background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.025));
      box-shadow:0 24px 70px rgba(0,0,0,.34);
      overflow:hidden;
      position:relative;
    }
    .hero-card:after{
      content:"";
      position:absolute;
      inset:auto -70px -90px auto;
      width:210px;
      height:210px;
      border-radius:50%;
      background:radial-gradient(circle,rgba(215,255,111,.25),transparent 68%);
      pointer-events:none;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:13px;
      margin-bottom:38px;
    }
    .brand img{
      width:58px;
      height:58px;
      border-radius:18px;
      background:#fff;
    }
    .brand strong{display:block;font-size:20px;line-height:1;letter-spacing:-.055em}
    .brand span{display:block;color:var(--soft);font-size:14px;margin-top:4px}
    .eyebrow{
      margin:0 0 14px;
      color:var(--acid);
      font:700 11px 'IBM Plex Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.14em;
    }
    h1{
      margin:0;
      font-size:clamp(48px,15vw,74px);
      line-height:.84;
      letter-spacing:-.085em;
    }
    h1 em{
      font-style:normal;
      color:transparent;
      -webkit-text-stroke:1px rgba(247,245,239,.74);
    }
    .lead{
      margin:22px 0 0;
      color:#ded8cc;
      font-size:18px;
      line-height:1.34;
      letter-spacing:-.035em;
      max-width:34rem;
    }
    .chips{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:22px;
    }
    .chip{
      border:1px solid var(--line);
      border-radius:999px;
      padding:8px 10px;
      color:var(--soft);
      background:rgba(255,255,255,.035);
      font:700 10px 'IBM Plex Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    section{padding:52px 0 0}
    .section-title{margin:0 0 18px}
    .section-title h2{
      margin:10px 0 0;
      font-size:clamp(34px,10vw,52px);
      line-height:.9;
      letter-spacing:-.07em;
    }
    .text-card,.project,.box,.contact-card{
      border:1px solid var(--line);
      border-radius:var(--radius);
      background:rgba(255,255,255,.035);
      padding:20px;
    }
    .text-card p,.project p,.box p,.contact-card p{
      margin:0;
      color:var(--soft);
      line-height:1.48;
    }
    .text-card p+p{margin-top:14px}

    .stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:9px;
      margin-top:12px;
    }
    .stat{
      border:1px solid var(--line);
      border-radius:19px;
      padding:13px 10px;
      background:rgba(255,255,255,.025);
    }
    .stat strong{display:block;font-size:22px;letter-spacing:-.06em}
    .stat span{display:block;margin-top:4px;color:var(--muted);font:700 9px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em}

    .project-list{display:grid;gap:13px}
    .project{display:grid;gap:16px}
    .project-head{display:flex;gap:14px;align-items:flex-start}
    .num{
      flex:0 0 auto;
      width:42px;
      height:42px;
      display:grid;
      place-items:center;
      border-radius:15px;
      background:var(--panel-2);
      border:1px solid var(--line);
      color:var(--muted);
      font-weight:900;
      letter-spacing:-.06em;
    }
    .project h3{
      margin:0 0 8px;
      font-size:27px;
      line-height:.96;
      letter-spacing:-.06em;
    }
    .project-meta{
      display:grid;
      grid-template-columns:1fr;
      gap:8px;
    }
    .mini{
      border:1px solid var(--line);
      border-radius:17px;
      padding:11px 12px;
      background:rgba(0,0,0,.18);
    }
    .mini strong{display:block;font-size:14px;letter-spacing:-.03em}
    .mini span{display:block;margin-top:3px;color:var(--muted);font:700 9px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em}
    .tags{display:flex;gap:7px;flex-wrap:wrap;margin:0;padding:0;list-style:none}
    .tags li{
      border:1px solid var(--line);
      border-radius:999px;
      padding:7px 9px;
      color:var(--soft);
      font:700 10px 'IBM Plex Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.07em;
    }
    .project a,.contact-actions a,.contact-form button{
      display:inline-flex;
      justify-content:center;
      align-items:center;
      min-height:46px;
      border-radius:999px;
      padding:12px 15px;
      font-weight:900;
      background:var(--acid);
      color:#030303;
      border:1px solid var(--acid);
    }
    .project a{width:100%}

    .grid{display:grid;gap:12px}
    .box span{display:block;color:var(--acid);font:700 11px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.1em}
    .box h3{margin:22px 0 9px;font-size:23px;line-height:1;letter-spacing:-.045em}

    .contact-card{display:grid;gap:18px}
    .contact-actions{display:grid;grid-template-columns:1fr;gap:10px}
    .contact-actions a.secondary{background:transparent;color:var(--soft);border-color:var(--line)}
    .contact-form{display:grid;gap:10px}
    .contact-form label{color:var(--muted);font:700 10px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.1em}
    .contact-form input,.contact-form textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:16px;
      background:#080808;
      color:var(--ink);
      padding:13px 14px;
    }
    .contact-form textarea{min-height:120px;resize:vertical}
    .contact-form button{width:100%;cursor:pointer}

    .bottom-bar{
      position:fixed;
      left:50%;
      bottom:14px;
      transform:translateX(-50%);
      z-index:80;
      width:min(calc(100% - 28px),492px);
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
      padding:8px;
      border:1px solid var(--line);
      border-radius:999px;
      background:rgba(3,3,3,.82);
      backdrop-filter:blur(18px);
      box-shadow:0 18px 54px rgba(0,0,0,.42);
    }
    .bottom-bar a{
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:42px;
      border-radius:999px;
      font-weight:900;
      font-size:13px;
    }
    .bottom-bar a:first-child{background:var(--acid);color:#030303}
    .bottom-bar a:last-child{border:1px solid var(--line);color:var(--soft)}

    @media(min-width:560px){
      .app{padding-inline:0}
      .mobile-nav{margin-inline:0;border-inline:1px solid var(--line);border-radius:999px;top:12px}
      .project-meta{grid-template-columns:repeat(3,1fr)}
      .contact-actions{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>
  <div class="app">
    <nav class="mobile-nav" aria-label="Mobile portfolio navigation">
      <a class="primary" href="#work">Work</a>
      <a href="#about">About</a>
      <a href="#method">Method</a>
      <a href="#stack">Stack</a>
      <a href="#contact">Contact</a>
      <a href="/">Desktop</a>
    </nav>

    <header class="hero-card">
      <a class="brand" href="/mobile">
        <img src="/assets/logo/monogram.svg" alt="Luanda Rodrigues monogram" />
        <div><strong>Luanda Rodrigues</strong><span>Data Analyst</span></div>
      </a>
      <p class="eyebrow">Health / BI / Operations</p>
      <h1>Readable data for <em>complex systems.</em></h1>
      <p class="lead">Brazilian data analyst connecting healthcare operations, SQL, BI, machine learning, graph analytics and decision communication.</p>
      <div class="chips" aria-label="Core skills">
        <span class="chip">Python</span>
        <span class="chip">SQL</span>
        <span class="chip">Power BI</span>
        <span class="chip">Health Data</span>
        <span class="chip">Remote</span>
        <span class="chip">Relocation</span>
      </div>
    </header>

    <section id="about">
      <div class="section-title">
        <p class="eyebrow">About</p>
        <h2>Healthcare, engineering and analytics.</h2>
      </div>
      <div class="text-card">
        <p>My background connects Biomedical Engineering, Hospital Management and operational data. I work with indicators, flows, risks and analytical communication for practical decisions.</p>
        <p>At HC-UFU/EBSERH, I work close to clinical pharmacy operations, KPI monitoring and public healthcare routines, with a digital layer from BI, automation, content and applied AI workflows.</p>
      </div>
      <div class="stats">
        <div class="stat"><strong>04</strong><span>portfolio cases</span></div>
        <div class="stat"><strong>06</strong><span>method layers</span></div>
        <div class="stat"><strong>EN/PT</strong><span>communication</span></div>
      </div>
    </section>

    <section id="work">
      <div class="section-title">
        <p class="eyebrow">Selected work</p>
        <h2>Projects made easy to scan.</h2>
      </div>
      <div class="project-list">
        <article class="project">
          <div class="project-head"><span class="num">01</span><div><h3>Mapping Primary Healthcare Units in Brazil</h3><p>47,714 Brazilian Primary Healthcare Units analyzed through geographic distribution, coordinate quality and public health data governance.</p></div></div>
          <div class="project-meta"><div class="mini"><strong>Scope</strong><span>Brazil · UBS</span></div><div class="mini"><strong>Method</strong><span>Maps · cleaning</span></div><div class="mini"><strong>Value</strong><span>Coverage · quality</span></div></div>
          <ul class="tags"><li>Health Analytics</li><li>Geoanalysis</li><li>Data Quality</li></ul>
          <a href="https://github.com/luandarodrigues/luandarodrigues/tree/main/projects/ubs-healthcare-mapping">Open project ↗</a>
        </article>

        <article class="project">
          <div class="project-head"><span class="num">02</span><div><h3>Heart Disease Risk Prediction</h3><p>Clinical machine learning project using 918 records and 11 predictors to compare models and interpret cardiovascular risk responsibly.</p></div></div>
          <div class="project-meta"><div class="mini"><strong>Scope</strong><span>Clinical data</span></div><div class="mini"><strong>Method</strong><span>ROC-AUC · F1</span></div><div class="mini"><strong>Value</strong><span>Risk · limits</span></div></div>
          <ul class="tags"><li>Machine Learning</li><li>Clinical Risk</li><li>Scikit-learn</li></ul>
          <a href="https://github.com/luandarodrigues/luandarodrigues/tree/main/projects/heart-disease-risk-ml">Open project ↗</a>
        </article>

        <article class="project">
          <div class="project-head"><span class="num">03</span><div><h3>Brazilian E-Commerce Delivery Experience</h3><p>Olist dataset analysis showing how delay, freight, seller, category and payment behavior affect customer reviews.</p></div></div>
          <div class="project-meta"><div class="mini"><strong>Scope</strong><span>99,441 orders</span></div><div class="mini"><strong>Method</strong><span>SQL · joins</span></div><div class="mini"><strong>Value</strong><span>CX · logistics</span></div></div>
          <ul class="tags"><li>SQL</li><li>Logistics</li><li>Customer Experience</li></ul>
          <a href="https://github.com/luandarodrigues/luandarodrigues/tree/main/projects/olist-ecommerce-experience-analytics">Open project ↗</a>
        </article>

        <article class="project">
          <div class="project-head"><span class="num">04</span><div><h3>CineGraph Network Intelligence</h3><p>Network and NLP project exploring relationships between movies, people, recommendations and review signals.</p></div></div>
          <div class="project-meta"><div class="mini"><strong>Scope</strong><span>TMDB graph</span></div><div class="mini"><strong>Method</strong><span>NetworkX · NLP</span></div><div class="mini"><strong>Value</strong><span>Connected data</span></div></div>
          <ul class="tags"><li>Graphs</li><li>NLP</li><li>Recommender Systems</li></ul>
          <a href="https://github.com/luandarodrigues/luandarodrigues/tree/main/projects/cinegraph-network-intelligence">Open project ↗</a>
        </article>
      </div>
    </section>

    <section id="method">
      <div class="section-title">
        <p class="eyebrow">Method</p>
        <h2>From question to decision.</h2>
      </div>
      <div class="grid">
        <div class="box"><span>01</span><h3>Frame the decision</h3><p>Define the user, metric, decision and operational risk before building analysis.</p></div>
        <div class="box"><span>02</span><h3>Audit the data</h3><p>Check granularity, keys, nulls, duplicates, dates, business rules and limitations.</p></div>
        <div class="box"><span>03</span><h3>Build the analytical layer</h3><p>Transform raw data into indicators, features, visualizations and clear outputs.</p></div>
        <div class="box"><span>04</span><h3>Communicate for action</h3><p>Turn findings into README, dashboard, executive summary or recommendation.</p></div>
      </div>
    </section>

    <section id="stack">
      <div class="section-title">
        <p class="eyebrow">Stack</p>
        <h2>Tools and domains.</h2>
      </div>
      <div class="grid">
        <div class="box"><span>Analysis</span><h3>Python · Pandas · NumPy · Excel</h3><p>Cleaning, exploration, feature creation and consistency checks.</p></div>
        <div class="box"><span>SQL & BI</span><h3>SQL · Power BI · Looker · KPIs</h3><p>Relational analysis, dashboards, indicators and operational monitoring.</p></div>
        <div class="box"><span>ML</span><h3>Scikit-learn · ROC-AUC · F1-score</h3><p>Classification, validation, model comparison and responsible interpretation.</p></div>
        <div class="box"><span>Graph & NLP</span><h3>NetworkX · TF-IDF · reviews</h3><p>Connected data, recommendations, text mining and opinion signals.</p></div>
      </div>
    </section>

    <section id="contact">
      <div class="section-title">
        <p class="eyebrow">Contact</p>
        <h2>Let’s connect data and decisions.</h2>
      </div>
      <div class="contact-card">
        <p>Send a structured message directly from this page. The form opens your email app with name, company and message ready for my inbox.</p>
        <div class="contact-actions">
          <a class="secondary" href="https://github.com/luandarodrigues">GitHub ↗</a>
          <a class="secondary" href="https://www.linkedin.com/in/luanda-rodrigues">LinkedIn ↗</a>
        </div>
        <form class="contact-form" id="contactForm">
          <label for="name">Name</label>
          <input id="name" name="name" placeholder="Your name" required />
          <label for="company">Company</label>
          <input id="company" name="company" placeholder="Company or organization" />
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="What would you like to discuss?" required></textarea>
          <button type="submit">Prepare email ↗</button>
        </form>
      </div>
    </section>
  </div>

  <div class="bottom-bar" aria-label="Fixed contact actions">
    <a href="mailto:luandarodrigues30@gmail.com">Email</a>
    <a href="#work">Projects</a>
  </div>

  <script>
    document.getElementById('contactForm').addEventListener('submit', event => {
      event.preventDefault();
      const name = document.getElementById('name').value.trim();
      const company = document.getElementById('company').value.trim();
      const message = document.getElementById('message').value.trim();
      const subject = `Portfolio contact - ${name || 'visitor'}`;
      const body = `Name: ${name}\nCompany: ${company}\n\nMessage:\n${message}`;
      window.location.href = `mailto:luandarodrigues30@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</body>
</html>
