g:11px 14px;font-weight:900;cursor:pointer}.cloud-btn.secondary{background:transparent;color:var(--soft)}.cloud-stage{position:relative;height:720px;border:1px solid var(--line);border-radius:34px;background:radial-gradient(circle at 50% 52%,rgba(255,255,255,.04),transparent 34%),rgba(255,255,255,.02);overflow:hidden;cursor:grab}.cloud-stage:after{content:'drag / click to reorganize';position:absolute;left:22px;bottom:18px;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:10px;letter-spacing:.12em}.graph-canvas{position:absolute;inset:0;width:100%;height:100%;display:block}.graph-legend{position:absolute;right:18px;top:18px;width:190px;border:1px solid var(--line);border-radius:18px;background:rgba(3,3,3,.58);backdrop-filter:blur(12px);padding:12px}.legend-row{display:flex;align-items:center;gap:8px;color:var(--soft);font:700 10px 'IBM Plex Mono';text-transform:uppercase;letter-spacing:.08em;margin:8px 0}.legend-dot{width:9px;height:9px;border-radius:50%}.legend-dot.health{background:var(--acid)}.legend-dot.models{background:var(--red)}.legend-dot.ops{background:var(--blue)}.tabs-section{padding:110px 0;border-bottom:1px solid var(--line)}.section-title{display:grid;grid-template-columns:.55fr 1.45fr;gap:26px;margin-bottom:28px}.tabbar{position:sticky;top:58px;z-index:25;display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;padding:16px 0;background:linear-gradient(to bottom,rgba(3,3,3,.98),rgba(3,3,3,.86))}.tabbtn{appearance:none;border:1px solid var(--line);border-radius:999px;background:transparent;color:var(--soft);padding:10px 14px;font-weight:800;cursor:pointer}.tabbtn.active{background:var(--ink);color:var(--bg);border-color:var(--ink)}.tab-summary{padding:22px;margin-bottom:16px;display:grid;grid-template-columns:.7fr 1.3fr;gap:18px}.tab-summary strong{font-size:22px;letter-spacing:-.05em}.panel{display:none;animation:panel .36s ease both}.panel.active{display:block}@keyframes panel{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}.project{display:grid;grid-template-columns:72px 1fr auto;gap:24px;align-items:start;padding:28px;margin-bottom:14px}.num{font-size:34px;font-weight:900;color:var(--muted);letter-spacing:-.08em}.project h3{font-size:clamp(28px,4vw,54px);line-height:.94;letter-spacing:-.065em;margin:0 0 12px}.project ul{display:flex;gap:8px;flex-wrap:wrap;padding:0;margin:16px 0 0;list-style:none}.project li{font-size:11px;text-transform:uppercase;color:var(--soft);border:1px solid var(--line);border-radius:999px;padding:7px 9px}.project a{border:1px solid var(--line);border-radius:999px;padding:11px 14px;font-weight:800;color:var(--acid);white-space:nowrap}.project-detail{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:18px}.project-detail strong{display:block;font-size:18px;letter-spacing:-.04em}.method-grid,.stack-grid,.background-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.contact{min-height:86vh;display:grid;align-items:end;padding:120px 0}.contact h2{font-size:clamp(64px,10vw,148px);line-height:.8;letter-spacing:-.09em;margin:0 0 26px}.contact-layout{display:grid;grid-template-columns:.9fr 1.1fr;gap:24px;border-top:1px solid var(--line);padding-top:24px}.contact-form{padding:22px}.contact-form label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:0 0 8px}.contact-form input,.contact-form textarea{width:100%;border:1px solid var(--line);border-radius:16px;background:#080808;color:var(--ink);padding:13px 14px;margin-bottom:14px;font:inherit}.contact-form textarea{min-height:140px;resize:vertical}.contact-form button{border:1px solid var(--ink);border-radius:999px;padding:13px 18px;background:var(--acid);color:#030303;font-weight:900;cursor:pointer}.contact-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}.btn{border:1px solid var(--line);border-radius:999px;padding:13px 18px;font-weight:800;color:var(--ink);background:var(--acid)}.btn.ghost{background:transparent;color:var(--soft)}.reveal{opacity:0;transform:translateY(28px)}@media(max-width:920px){.frame{display:block}.side{position:relative;height:auto;border-right:0;border-bottom:1px solid var(--line)}.main{padding:0 22px 80px}.topnav{justify-content:flex-start;overflow:auto}.hero-copy,.about-panel,.cloud-pin,.section-title,.method-grid,.stack-grid,.background-grid,.tab-summary,.contact-layout,.project-detail{grid-template-columns:1fr}.cloud-stage{height:620px}.project{grid-template-columns:1fr}.project a{width:max-content}.hero h1{font-size:76px}.contact h2{font-size:68px}.side-viz{height:230px}.side-stats{max-width:520px}.graph-legend{display:none}}@media(max-width:520px){.side{padding:20px}.main{padding:0 16px 70px}.hero h1{font-size:62px}.hero-copy p,.about-text p{font-size:18px}.cloud-stage{height:540px}.project h3{font-size:34px}.intro-card p{font-size:24px}.about-grid{grid-template-columns:1fr}}
