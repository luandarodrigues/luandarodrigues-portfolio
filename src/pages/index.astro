        secondary.style.textDecoration = 'none';
        secondary.style.font = "800 11px 'IBM Plex Mono', monospace";
        secondary.style.letterSpacing = '.08em';
        secondary.style.textTransform = 'uppercase';
        secondary.style.whiteSpace = 'nowrap';

        [primary, secondary].forEach((link) => {
          if (link.href.startsWith('http')) {
            link.target = '_blank';
            link.rel = 'noreferrer';
          }
        });

        actions.append(primary, secondary);
        existing.replaceWith(actions);
      });
    })();
  </script>
</body>
</html>

