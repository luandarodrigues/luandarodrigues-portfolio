in:0}.chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:24px}.chip{border:1px solid var(--line);border-radius:999px;padding:8px 10px;text-transform:uppercase;letter-spacing:.08em;font-size:11px;color:var(--soft);background:rgba(255,255,255,.03)}.viz{border:1px solid var(--line);border-radius:34px;background:radial-gradient(circle at 72% 20%,rgba(215,255,111,.16),transparent 32%),radial-gradient(circle at 40% 66%,rgba(159,200,255,.14),transparent 35%),rgba(255,255,255,.025);min-height:440px;padding:28px;position:relative;overflow:hidden}.viz:before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(247,245,239,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(247,245,239,.02) 1px,transparent 1px);background-size:58px 58px}.viz .card{position:relative;border:1px solid var(--line);border-radius:24px;background:rgba(3,3,3,.58);padding:20px;margin-bottom:12px}.viz strong{display:block;font-size:36px;letter-spacing:-.06em}.viz span{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.08em}.section{padding:80px 0;border-top:1px solid var(--line)}.section-head{display:grid;grid-template-columns:.65fr 1.35fr;gap:30px;margin-bottom:26px}.section h2{font-size:clamp(38px,5vw,68px);line-height:.92;letter-spacing:-.08em;margin:0}.section p{color:var(--soft);line-height:1.5}.projects{display:grid;gap:16px}.project{display:grid;grid-template-columns:68px 1fr auto;gap:22px;align-items:start;border:1px solid var(--line);border-radius:28px;background:var(--panel);padding:22px}.num{font-size:34px;font-weight:900;color:var(--muted);letter-spacing:-.08em}.project h3{font-size:clamp(27px,3.2vw,48px);line-height:.96;letter-spacing:-.065em;margin:0 0 12px}.project p{margin:0;color:var(--soft)}.project span{display:inline-block;color:var(--acid);text-transform:uppercase;font-size:10px;letter-spacing:.08em;margin-bottom:8px}.meta{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:18px 0}.meta div{border:1px solid var(--line);border-radius:17px;padding:12px;background:rgba(255,255,255,.025)}.meta strong{display:block;font-size:18px;letter-spacing:-.04em}.meta small{display:block;color:var(--soft);line-height:1.35;margin-top:4px}.actions{display:flex;gap:8px;flex-wrap:wrap;align-items:flex-start}.btn{border:1px solid var(--line);border-radius:999px;padding:12px 15px;font-weight:900;color:var(--acid);white-space:nowrap;background:rgba(255,255,255,.025)}.btn.primary{background:var(--acid);color:#030303;border-color:var(--acid)}.contact{display:grid;grid-template-columns:1fr 1fr;gap:16px}.contact a{border:1px solid var(--line);border-radius:22px;background:var(--panel);padding:22px;color:var(--soft);font-weight:800}.foot{padding:34px 0;color:var(--muted);font-family:'IBM Plex Mono',monospace;font-size:12px;border-top:1px solid var(--line)}@media(max-width:900px){.top{height:auto;position:relative;padding:16px 0}.top .wrap,.hero,.section-head,.project,.contact{grid-template-columns:1fr}.top .wrap{display:grid;gap:14px}.nav{overflow:auto;flex-wrap:nowrap}.hero{padding:54px 0}.hero h1{font-size:58px}.viz{min-height:320px}.meta{grid-template-columns:1fr}.project{gap:14px}.actions{margin-top:8px}}
