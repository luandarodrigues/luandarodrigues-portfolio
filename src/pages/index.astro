<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script><script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script><script>gsap.registerPlugin(ScrollTrigger);gsap.to('.reveal',{opacity:1,y:0,duration:.9,stagger:.12,ease:'power3.out'});const nodes=[...document.querySelectorAll('.node')];const clustered=[[18,36],[40,34],[58,34],[74,36],[22,56],[42,56],[60,56],[76,56],[28,74],[48,74],[64,74],[80,74]];const spread=[[12,18],[72,15],[38,10],[84,42],[18,55],[52,70],[82,78],[28,82],[6,82],[56,34],[24,36],[64,54]];const alternate=[[18,24],[34,18],[55,22],[76,24],[20,46],[42,46],[64,46],[82,48],[18,72],[38,76],[60,72],[80,74]];const tl=gsap.timeline({scrollTrigger:{trigger:'.cloud-section',start:'top top',end:'bottom bottom',scrub:1}});nodes.forEach((n,i)=>tl.to(n,{left:clustered[i][0]+'%',top:clustered[i][1]+'%',scale:i%4===0?1.2:1,duration:1,ease:'power2.inOut'},0));tl.to('.cloud-line',{opacity:1,duration:.7},.2);let mode=0;function placeCloud(layout){gsap.to(nodes,{left:(i)=>layout[i][0]+'%',top:(i)=>layout[i][1]+'%',x:(i)=>mode?0:[-70,90,-45,60,-90,75,-60,50,-80,65,-40,70][i],y:(i)=>mode?0:[-38,52,65,-70,58,-50,45,-62,40,55,-58,32][i],scale:(i)=>i%4===0?1.14:1,duration:.9,stagger:.025,ease:'power3.inOut'});gsap.fromTo('.cloud-stage',{rotate:.12},{rotate:0,duration:.8,ease:'elastic.out(1,.55)'})}function reshuffle(){mode=0;placeCloud(alternate)}document.getElementById('cloudStage').addEventListener('click',reshuffle);document.getElementById('shuffleCloud').addEventListener('click',reshuffle);document.getElementById('clusterCloud').addEventListener('click',()=>{mode=1;placeCloud(clustered)});gsap.utils.toArray('.project,.box,.about-grid article').forEach(el=>gsap.from(el,{opacity:0,y:28,duration:.65,ease:'power2.out',scrollTrigger:{trigger:el,start:'top 86%'}}));document.querySelectorAll('.tabbtn').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.tabbtn').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));btn.classList.add('active');document.getElementById(btn.dataset.tab).classList.add('active')}));</script>
