m:none}}.card{display:grid;grid-template-columns:72px 1fr auto;gap:24px;align-items:start;margin-bottom:14px}.num{font-size:34px;font-weight:900;color:var(--muted);letter-spacing:-.08em}.card h3{font-size:clamp(28px,4vw,54px);line-height:.94;letter-spacing:-.065em;margin:0 0 12px}.card p{font-size:16px}.project-meta{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:18px 0}.project-meta strong{display:block;font-size:18px;letter-spacing:-.04em;margin-bottom:5px}.project-meta small{display:block;color:var(--soft);line-height:1.35}.card ul{display:flex;gap:8px;flex-wrap:wrap;padding:0;margin:16px 0 0;list-style:none}.card li{font-size:11px;text-transform:uppercase;color:var(--soft);border:1px solid var(--line);border-radius:999px;padding:7px 9px}.card a{border:1px solid var(--line);border-radius:999px;padding:11px 14px;font-weight:800;color:var(--acid);white-space:nowrap}.contact{padding:120px 0}.contact h2{font-size:clamp(58px,9vw,132px);margin-bottom:26px}.contact-layout{display:grid;grid-template-columns:.9fr 1.1fr;gap:32px;border-top:1px solid var(--line);padding-top:24px}label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:0 0 8px}input,textarea{width:100%;border:1px solid var(--line);border-radius:16px;background:#080808;color:var(--ink);padding:13px 14px;margin-bottom:14px;font:inherit}textarea{min-height:140px;resize:vertical}button[type=submit]{border:1px solid var(--ink);border-radius:999px;padding:13px 18px;background:var(--acid);color:#030303;font-weight:900;cursor:pointer}.row{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}.btn{border:1px solid var(--line);border-radius:999px;padding:13px 18px;font-weight:800;color:var(--soft)}.reveal{opacity:0;transform:translateY(28px)}@media(max-width:1180px){.about{grid-template-columns:1fr}.about-copy{grid-template-columns:1fr 1fr}.about h2{max-width:780px}.about .grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:920px){.frame{display:block}.side{position:relative;height:auto;min-height:0;border-right:0;border-bottom:1px solid var(--line);padding:18px}.brand img{width:54px;height:54px;border-radius:16px}.brand strong{font-size:20px}.brand span{font-size:14px}.intro-card{margin-top:22px;padding:18px 0}.intro-card p{font-size:22px;line-height:1.16}.side-viz{height:150px;margin-top:18px;border-radius:24px}.side-stats{grid-template-columns:repeat(3,minmax(0,1fr))}.stat{padding:10px}.stat strong{font-size:19px}.links{display:grid;grid-template-columns:repeat(2,1fr);gap:0;margin-top:14px}.links a{font-size:12px;padding:12px 4px}.main{padding:0 18px 70px}.topnav{justify-content:flex-start;overflow-x:auto;gap:10px;height:auto;padding:12px 0;top:0;scrollbar-width:none}.topnav::-webkit-scrollbar{display:none}.topnav a{font-size:11px;letter-spacing:.06em;flex:0 0 auto;border:1px solid var(--line);border-radius:999px;padding:8px 10px}.hero{min-height:auto;padding:54px 0 64px}.hero h1{font-size:clamp(48px,15vw,76px);line-height:.86;letter-spacing:-.075em}.split,.about,.cloud-pin,.title,.grid,.summary,.contact-layout,.project-meta{grid-template-columns:1fr}.split p{font-size:18px;line-height:1.38}.section,.about{padding:64px 0}.about h2,.cloud-copy h2,.title h2{font-size:clamp(38px,12vw,62px);line-height:.9}.about-copy{grid-template-columns:1fr}.about-copy p{font-size:18px}.about-photo{grid-column:auto;grid-row:auto;height:280px;border-radius:26px}.about .grid{grid-template-columns:1fr 1fr}.cloud-section{height:auto}.cloud-pin{position:relative;top:auto;height:auto;padding:64px 0;display:block}.cloud-copy p{max-width:none}.cloud-stage{height:420px;min-height:420px;margin-top:24px;border-radius:26px}.legend{display:none}.tabs{padding:72px 0}.tabbar{position:relative;top:auto;overflow-x:auto;flex-wrap:nowrap;margin-left:-18px;margin-right:-18px;padding:14px 18px;scrollbar-width:none}.tabbar::-webkit-scrollbar{display:none}.tabbtn{flex:0 0 auto}.summary{padding:18px}.card{grid-template-columns:1fr;gap:12px;padding:20px}.num{font-size:28px}.card h3{font-size:32px;line-height:1}.card p{font-size:15px;line-height:1.5}.card a{width:max-content}.project-meta{gap:8px;margin:14px 0}.project-meta div{padding:12px}.contact{padding:74px 0}.contact h2{font-size:clamp(42px,13vw,72px);line-height:.9}.contact-layout{gap:20px}.box{padding:18px}}@media(max-width:520px){.main{padding-left:14px;padding-right:14px}.side{padding:16px}.hero h1{font-size:52px}.eyebrow{font-size:10px}.chips{gap:6px}.chip{font-size:9px;padding:7px 8px}.side-viz{height:140px}.about-photo{height:230px;object-position:center}.about .grid{grid-template-columns:1fr}.links{grid-template-columns:1fr}.cloud-stage{height:350px;min-height:350px}.cloud-stage:after{font-size:8px;left:14px}.card h3{font-size:28px}.card p,.box p,.summary p{font-size:14.5px}.topnav{margin-left:-14px;margin-right:-14px;padding-left:14px}.about h2,.cloud-copy h2,.title h2{font-size:40px}.intro-card p{font-size:20px}.project-meta strong{font-size:16px}.project-meta small{font-size:12px}}</style>
