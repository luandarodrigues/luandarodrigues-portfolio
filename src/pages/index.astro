argin:18px 0}.cloud-copy p{color:var(--soft);line-height:1.45}.cloud-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:22px}.cloud-btn{appearance:none;border:1px solid var(--line);border-radius:999px;background:var(--ink);color:var(--bg);padding:11px 14px;font-weight:900;cursor:pointer}.cloud-btn.secondary{background:transparent;color:var(--soft)}.cloud-stage{position:relative;height:640px;border:1px solid var(--line);border-radius:34px;background:radial-gradient(circle at 30% 26%,rgba(215,255,111,.16),transparent 26%),radial-gradient(circle at 72% 70%,rgba(164,184,255,.16),transparent 28%),rgba(255,255,255,.03);overflow:hidden;cursor:pointer}.cloud-stage:after{content:'click to reshuffle';position:absolute;left:22px;bottom:18px;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:10px;letter-spacing:.12em}.cloud-stage svg{position:absolute;inset:0;width:100%;height:100%;opacity:0;fill:none;stroke:rgba(247,245,239,.38)}.node{position:absolute;transform:translate(-50%,-50%);border:1px solid rgba(247,245,239,.18);background:rgba(3,3,3,.64);border-radius:999px;padding:11px 14px;font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.09em;font-size:11px;font-weight:700;color:#eee;white-space:nowrap}.tabs-section{padding:110px 0;border-bottom:1px solid var(--line)}.section-title{display:grid;grid-template-columns:.55fr 1.45fr;gap:26px;margin-bottom:28px}.tabbar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}.tabbtn{appearance:none;border:1px solid var(--line);border-radius:999px;background:transparent;color:var(--soft);padding:10px 14px;font-weight:800;cursor:pointer}.tabbtn.active{background:var(--ink);color:var(--bg);border-color:var(--ink)}.panel{display:none;animation:panel .36s ease both}.panel.active{display:block}@keyframes panel{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}.project{display:grid;grid-template-columns:72px 1fr auto;gap:24px;align-items:start;padding:26px 0;border-top:1px solid var(--line)}.project:last-child{border-bottom:1px solid var(--line)}.num{font-size:34px;font-weight:900;color:var(--muted);letter-spacing:-.08em}.project h3{font-size:clamp(28px,4vw,54px);line-height:.94;letter-spacing:-.065em;margin:0 0 12px}.project p{max-width:760px;color:var(--soft);font-size:17px;line-height:1.42}.project ul{display:flex;gap:8px;flex-wrap:wrap;padding:0;margin:16px 0 0;list-style:none}.project li{font-family:'IBM Plex Mono',monospace;font-size:11px;text-transform:uppercase;color:var(--soft);border:1px solid var(--line);border-radius:999px;padding:7px 9px}.project a{border:1px solid var(--line);border-radius:999px;padding:11px 14px;font-weight:800;color:var(--acid);white-space:nowrap}.method-grid,.stack-grid,.background-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.box{border:1px solid var(--line);border-radius:24px;padding:22px;background:rgba(255,255,255,.035)}.box span{font-family:'IBM Plex Mono',monospace;color:var(--acid);font-size:12px}.box h3{font-size:25px;letter-spacing:-.05em;margin:28px 0 10px}.box p,.box li{color:var(--soft);line-height:1.42}.box ul{margin:0;padding-left:18px}.contact{min-height:86vh;display:grid;align-items:end;padding:120px 0}.contact h2{font-size:clamp(64px,10vw,148px);line-height:.8;letter-spacing:-.09em;margin:0 0 26px}.contact-row{display:flex;gap:10px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px}.btn{border:1px solid var(--line);border-radius:999px;padding:13px 18px;font-weight:800;color:var(--ink);background:var(--acid)}.btn.ghost{background:transparent;color:var(--soft)}.reveal{opacity:0;transform:translateY(28px)}@media(max-width:920px){.frame{display:block}.side{position:relative;height:auto;border-right:0;border-bottom:1px solid var(--line)}.main{padding:0 22px 80px}.topnav{justify-content:flex-start;overflow:auto}.hero-copy,.about-panel,.cloud-pin,.section-title,.method-grid,.stack-grid,.background-grid{grid-template-columns:1fr}.cloud-stage{height:520px}.project{grid-template-columns:1fr}.project a{width:max-content}.hero h1{font-size:76px}.contact h2{font-size:68px}.side-viz{height:230px}.side-stats{max-width:520px}}@media(max-width:520px){.side{padding:20px}.main{padding:0 16px 70px}.hero h1{font-size:62px}.hero-copy p,.about-text p{font-size:18px}.cloud-stage{height:440px}.node{font-size:9px;padding:8px 10px}.project h3{font-size:34px}.intro-card p{font-size:24px}.about-grid{grid-template-columns:1fr}}
