:root{--bg:#030303;--ink:#f7f5ef;--soft:#b8b5ad;--muted:#77736d;--line:rgba(247,245,239,.13);--acid:#d7ff6f;--blue:#9fc8ff;--red:#ff7777}*{box-sizing:border-box}html{scroll-behavior:smooth;background:var(--bg)}body{margin:0;background:var(--bg);color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow-x:hidden}body:before{content:"";position:fixed;inset:0;background:radial-gradient(circle at 76% 12%,rgba(215,255,111,.12),transparent 25%),radial-gradient(circle at 8% 26%,rgba(159,200,255,.09),transparent 26%),linear-gradient(rgba(247,245,239,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(247,245,239,.025) 1px,transparent 1px);background-size:auto,auto,82px 82px,82px 82px;pointer-events:none;z-index:-2}a{color:inherit;text-decoration:none}.frame{display:grid;grid-template-columns:minmax(315px,34vw) 1fr;min-height:100vh}.side{position:sticky;top:0;height:100vh;padding:28px;display:flex;flex-direction:column;justify-content:space-between;border-right:1px solid var(--line);overflow:hidden}.brand{display:flex;align-items:center;gap:14px}.brand img{width:72px;height:72px;border-radius:22px;background:#fff}.brand strong{display:block;font-size:24px;line-height:1;letter-spacing:-.055em}.brand span{color:var(--soft);font-size:18px}.intro-card{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:28px 0;margin-top:76px}.intro-card p{font-size:28px;line-height:1.13;letter-spacing:-.055em;color:#e9e5dc;margin:0}.side-viz{height:310px;margin-top:34px;border-bottom:1px solid var(--line);position:relative;overflow:hidden;background:radial-gradient(circle at 45% 45%,rgba(255,255,255,.08),transparent 42%)}.side-viz i{position:absolute;width:6px;height:6px;border-radius:999px;background:#fff;box-shadow:0 0 28px rgba(255,255,255,.35);opacity:.85;animation:float 4s ease-in-out infinite}.side-viz i:nth-child(1){left:12%;top:22%;animation-delay:.1s}.side-viz i:nth-child(2){left:35%;top:16%;animation-delay:.7s}.side-viz i:nth-child(3){left:72%;top:18%;a