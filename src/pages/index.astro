<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script><script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script><script>const summaries={projects:['Projects','Public portfolio cases showing healthcare, machine learning, SQL, graphs, NLP and decision-oriented communication.'],methodtab:['Method','Practical data workflow: frame the decision, audit the data, build the analytical layer, choose the method and communicate limitations.'],stack:['Stack','Tools used across the projects: Python, SQL, Pandas, Power BI, Scikit-learn, NetworkX, NLP, dashboards and operational analysis.'],background:['Background','The career layer behind the projects: healthcare, Biomedical Engineering, Hospital Management, EBSERH/HC-UFU and marketing technology.']};function setTab(id){document.querySelectorAll('.tabbtn').forEach(b=>b.classList.toggle('active',b.dataset.tab===id));document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active',p.id===id));document.getElementById('tabTitle').textContent=summaries[id][0];document.getElementById('tabText').textContent=summaries[id][1];}document.querySelectorAll('.tabbtn').forEach(btn=>btn.addEventListener('click',()=>setTab(btn.dataset.tab)));document.getElementById('contactForm').addEventListener('submit',e=>{e.preventDefault();const n=document.getElementById('name').value.trim();const c=document.getElementById('company').value.trim();const m=document.getElementById('message').value.trim();const subject=encodeURIComponent('Portfolio contact - '+(n||'visitor'));const body=encodeURIComponent('Name: '+n+'\nCompany: '+c+'\n\nMessage:\n'+m);window.location.href='mailto:luandarodrigues30@gmail.com?subject='+subject+'&body='+body;});const nodes=[...document.querySelectorAll('.node')];const clustered=[[15,28],[38,24],[52,19],[72,23],[20,48],[39,48],[57,47],[75,48],[22,68],[42,68],[60,68],[78,68],[32,34],[63,34],[34,58],[84,58],[14,58],[46,31],[12,38],[27,21],[61,27],[68,55],[58,80],[36,78]];const spread=[[12,18],[72,15],[38,10],[84,42],[18,55],[52,70],[82,78],[28,82],[6,82],[56,34],[24,36],[64,54],[44,44],[70,30],[35,62],[88,60],[10,42],[46,23],[16,28],[30,24],[60,22],[76,50],[58,84],[42,78]];const alternate=[[18,24],[34,18],[55,22],[76,24],[20,46],[42,46],[64,46],[82,48],[18,72],[38,76],[60,72],[80,74],[28,35],[50,33],[70,36],[14,52],[46,60],[58,54],[25,28],[69,17],[88,34],[32,84],[52,82],[72,84]];let cloudMode=0;function applyLayout(layout,withOffset=false){nodes.forEach((n,i)=>{n.style.left=layout[i][0]+'%';n.style.top=layout[i][1]+'%';n.style.transform='translate(-50%,-50%) '+(withOffset?'translate('+([-80,90,-60,80,-100,90,-80,70,-90,75,-65,85,-55,65,-75,92,-68,77,-35,45,-50,55,-45,60][i])+'px,'+([-48,62,74,-82,68,-62,55,-72,50,65,-68,42,-55,45,60,-64,50,-44,36,-40,48,-52,38,-34][i])+'px) ':'')+'scale('+(i%5===0?1.18:1)+')';});document.querySelector('.cloud-stage').animate([{transform:'rotate(.18deg)'},{transform:'rotate(0deg)'}],{duration:480,easing:'cubic-bezier(.2,.8,.2,1)'});}function reshuffle(){cloudMode=1-cloudMode;applyLayout(cloudMode?alternate:spread,true);}document.getElementById('cloudStage').addEventListener('click',reshuffle);document.getElementById('shuffleCloud').addEventListener('click',reshuffle);document.getElementById('clusterCloud').addEventListener('click',()=>{cloudMode=0;applyLayout(clustered,false);});if(window.gsap){gsap.registerPlugin(ScrollTrigger);gsap.to('.reveal',{opacity:1,y:0,duration:.9,stagger:.12,ease:'power3.out'});const tl=gsap.timeline({scrollTrigger:{trigger:'.cloud-section',start:'top top',end:'bottom bottom',scrub:1}});nodes.forEach((n,i)=>tl.to(n,{left:clustered[i][0]+'%',top:clustered[i][1]+'%',scale:i%5===0?1.2:1,duration:1,ease:'power2.inOut'},0));tl.to('.cloud-line',{opacity:1,duration:.7},.2);gsap.utils.toArray('.project,.box,.about-grid article').forEach(el=>gsap.from(el,{opacity:0,y:28,duration:.65,ease:'power2.out',scrollTrigger:{trigger:el,start:'top 86%'}}));}</script>
