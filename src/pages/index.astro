<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Luanda Rodrigues | Data Analyst</title>
  <meta
    name="description"
    content="Portfolio of Luanda Rodrigues, a Brazilian data analyst focused on healthcare, BI, SQL, machine learning, hospital operations and decision intelligence."
  />
  <link rel="alternate" hreflang="pt-BR" href="/pt/" />
  <link rel="icon" href="/assets/logo/monogram.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Poppins:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root{
      --bg:#06070a;
      --bg-soft:#0e1117;
      --ink:#f5f1e8;
      --soft:#cdc4b4;
      --muted:#93897a;
      --line:rgba(245,241,232,.12);
      --panel:rgba(255,255,255,.04);
      --panel-strong:rgba(255,255,255,.06);
      --health:#14b8a6;
      --models:#a78bfa;
      --ops:#fbbf24;
      --shadow:0 30px 80px rgba(0,0,0,.28);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth;background:var(--bg)}
    body{
      margin:0;
      color:var(--ink);
      background:
        radial-gradient(circle at 14% 12%, rgba(20,184,166,.10), transparent 22%),
        radial-gradient(circle at 88% 3%, rgba(167,139,250,.11), transparent 24%),
        radial-gradient(circle at 62% 82%, rgba(251,191,36,.08), transparent 28%),
        linear-gradient(180deg, #06070a 0%, #090c11 48%, #06070a 100%);
      font-family:'Poppins',sans-serif;
      overflow-x:hidden;
    }
    body::before,
    body::after{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:-1;
    }
    body::before{
      opacity:.18;
      background-image:
        linear-gradient(rgba(245,241,232,.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,241,232,.018) 1px, transparent 1px);
      background-size:96px 96px;
      mask-image:linear-gradient(to bottom, black, transparent 82%);
    }
    body::after{
      opacity:.05;
      background-image:radial-gradient(rgba(255,255,255,.9) .6px, transparent .8px);
      background-size:10px 10px;
      mix-blend-mode:soft-light;
    }
    a{color:inherit;text-decoration:none}
    .frame{display:grid;grid-template-columns:minmax(310px,28vw) 1fr;min-height:100vh}
    .side{
      position:sticky;
      top:0;
      height:100vh;
      padding:42px 34px 34px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      border-right:1px solid var(--line);
      overflow:hidden;
      background:linear-gradient(180deg, rgba(6,7,10,.94), rgba(6,7,10,.82));
      backdrop-filter:blur(14px);
    }
    .brand{display:flex;align-items:center;gap:16px}
    .brand img{width:68px;height:68px;border-radius:20px;background:#fff}
    .brand strong{display:block;font-size:21px;line-height:.96;letter-spacing:-.05em}
    .brand span{display:block;color:var(--soft);font-size:15px;font-weight:300;margin-top:6px}
    .intro-card{
      margin-top:62px;
      padding:30px 0 0;
      border-top:1px solid var(--line);
    }
    .intro-card p{
      margin:0;
      color:var(--ink);
      font-size:20px;
      line-height:1.24;
      letter-spacing:-.05em;
      max-width:16ch;
    }
    .side-viz{
      height:252px;
      margin-top:40px;
      border:1px solid var(--line);
      border-radius:32px;
      position:relative;
      overflow:hidden;
      background:
        radial-gradient(circle at 28% 28%, rgba(20,184,166,.12), transparent 34%),
        radial-gradient(circle at 76% 24%, rgba(167,139,250,.12), transparent 28%),
        radial-gradient(circle at 58% 82%, rgba(251,191,36,.10), transparent 26%),
        rgba(255,255,255,.02);
    }
    .side-viz canvas{position:absolute;inset:0;width:100%;height:100%}
    .side-viz::after{
      content:"live note cloud";
      position:absolute;
      left:16px;
      bottom:14px;
      color:var(--muted);
      font:700 9px 'Space Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.14em;
    }
    .links{
      display:grid;
      border-top:1px solid var(--line);
      margin-top:40px;
    }
    .links a{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:18px 6px;
      border-bottom:1px solid var(--line);
      color:var(--soft);
      font-size:13px;
      font-weight:500;
      letter-spacing:.02em;
    }
    .main{padding:22px 42px 110px;min-width:0}
    .topnav{
      width:fit-content;
      min-height:64px;
      display:flex;
      justify-content:flex-end;
      gap:22px;
      align-items:center;
      padding:12px 20px;
      margin:6px 0 0 auto;
      border:1px solid var(--line);
      border-radius:999px;
      position:sticky;
      top:14px;
      z-index:20;
      background:linear-gradient(180deg, rgba(7,8,11,.98), rgba(7,8,11,.88));
      backdrop-filter:blur(18px);
      box-shadow:0 16px 50px rgba(0,0,0,.18);
    }
    .topnav a,
    .eyebrow,
    .tabbtn,
    .cloud-btn,
    .featured-label,
    .card-metric,
    .meta-line,
    label,
    .cluster-label{
      font-family:'Space Mono',monospace;
    }
    .topnav a{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.12em;
      color:var(--soft);
      white-space:nowrap;
    }
    .lang{
      border:1px solid var(--line);
      padding:8px 11px;
      border-radius:999px;
    }
    .hero{
      min-height:calc(100vh - 86px);
      display:grid;
      align-items:end;
      padding:84px 0 70px;
    }
    .eyebrow{
      margin:0 0 18px;
      font-size:11px;
      letter-spacing:.18em;
      text-transform:uppercase;
      color:var(--soft);
    }
    .hero h1{
      margin:0;
      max-width:1040px;
      font-size:clamp(64px,9vw,146px);
      line-height:.82;
      letter-spacing:-.08em;
      font-weight:300;
    }
    .hero h1 em{
      font-family:'DM Serif Display',serif;
      font-style:italic;
      font-weight:400;
      color:var(--ink);
      letter-spacing:-.03em;
    }
    .split{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:28px;
      border-top:1px solid var(--line);
      margin-top:30px;
      padding-top:24px;
    }
    .split p{
      margin:0;
      color:var(--soft);
      font-size:20px;
      line-height:1.5;
      letter-spacing:-.02em;
      max-width:30ch;
    }
    .hero-metrics{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:12px;
    }
    .hero-metric{
      border-left:1px solid var(--line);
      padding-left:14px;
    }
    .hero-metric strong{
      display:block;
      font:700 18px 'Space Mono',monospace;
      color:var(--ink);
      letter-spacing:.06em;
    }
    .hero-metric span{
      display:block;
      margin-top:6px;
      color:var(--muted);
      font-size:11px;
      line-height:1.5;
      text-transform:uppercase;
      letter-spacing:.08em;
    }
    .section{padding:88px 0;border-top:1px solid var(--line)}
    .about-shell,
    .featured-shell,
    .card,
    .summary,
    form,
    .box{
      border:1px solid var(--line);
      background:var(--panel);
      border-radius:28px;
      box-shadow:var(--shadow);
    }
    .about-shell{
      overflow:hidden;
      background:
        linear-gradient(140deg, rgba(255,255,255,.05), rgba(255,255,255,.02)),
        rgba(255,255,255,.015);
    }
    .about-head{
      display:grid;
      grid-template-columns:.9fr 1.1fr;
      border-bottom:1px solid var(--line);
    }
    .about-title,
    .about-text{padding:30px}
    .about-text{
      border-left:1px solid var(--line);
      max-width:68ch;
      display:grid;
      gap:16px;
    }
    .about-text p,
    .cloud-copy p,
    .featured-copy p,
    .card p,
    .summary p,
    .box p,
    .note{margin:0;color:var(--soft);line-height:1.65}
    .about h2,
    .cloud-copy h2,
    .title h2,
    .featured-copy h2,
    .contact h2{
      margin:12px 0 0;
      font-size:clamp(38px,3.4vw,58px);
      line-height:.95;
      letter-spacing:-.07em;
      font-weight:300;
    }
    .about h2 .section-accent,
    .title h2 .section-accent,
    .contact h2 .section-accent{
      font-family:'DM Serif Display',serif;
      font-style:italic;
      font-weight:400;
      letter-spacing:-.02em;
    }
    .about-body{
      display:grid;
      grid-template-columns:1fr;
    }
    .about-cards{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      border-top:1px solid var(--line);
    }
    .about-card{
      min-height:180px;
      padding:24px;
      border-right:1px solid var(--line);
      border-bottom:1px solid var(--line);
      background:rgba(255,255,255,.015);
    }
    .about-card:nth-child(2n){border-right:0}
    .about-card:nth-child(n+3){border-bottom:0}
    .about-card span,
    .box span{
      display:inline-block;
      font-size:10px;
      letter-spacing:.12em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .about-card h3,
    .box h3{
      margin:20px 0 10px;
      font-size:24px;
      line-height:1.02;
      letter-spacing:-.05em;
      font-weight:400;
    }
    .cloud-section{height:285vh;position:relative}
    .cloud-pin{
      position:sticky;
      top:60px;
      height:calc(100vh - 60px);
      display:grid;
      grid-template-columns:.56fr 1.44fr;
      gap:36px;
      align-items:center;
    }
    .cloud-copy p{max-width:34ch}
    .actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:24px;
    }
    .cloud-btn{
      appearance:none;
      border:1px solid var(--line);
      border-radius:999px;
      padding:12px 16px;
      background:transparent;
      color:var(--ink);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
      transition:transform .2s ease,border-color .2s ease,background .2s ease;
    }
    .cloud-btn:hover{transform:translateY(-1px);border-color:rgba(245,241,232,.22)}
    .cloud-btn.primary{background:var(--ink);color:var(--bg)}
    .cloud-stage{
      position:relative;
      height:min(820px, calc(100vh - 104px));
      min-height:620px;
      border:1px solid var(--line);
      border-radius:38px;
      overflow:hidden;
      background:
        radial-gradient(circle at 20% 24%, rgba(20,184,166,.07), transparent 28%),
        radial-gradient(circle at 78% 24%, rgba(167,139,250,.08), transparent 24%),
        radial-gradient(circle at 58% 76%, rgba(251,191,36,.07), transparent 26%),
        rgba(255,255,255,.015);
      box-shadow:var(--shadow);
      cursor:grab;
    }
    .cloud-stage::after{
      content:"click to shift between clusters and spread";
      position:absolute;
      left:22px;
      bottom:18px;
      color:var(--muted);
      font:700 9px 'Space Mono',monospace;
      text-transform:uppercase;
      letter-spacing:.14em;
    }
    .graph-canvas{position:absolute;inset:0;width:100%;height:100%}
    .cluster-label{
      position:absolute;
      z-index:2;
      font-size:11px;
      letter-spacing:.18em;
      text-transform:uppercase;
      pointer-events:none;
    }
    .cluster-label--health{left:8%;top:13%;color:var(--health)}
    .cluster-label--models{right:8%;top:14%;color:var(--models)}
    .cluster-label--ops{left:52%;bottom:12%;color:var(--ops)}
    .featured{padding:104px 0 44px}
    .featured-shell{
      padding:42px 42px 40px;
      background:
        linear-gradient(135deg, rgba(20,184,166,.08), rgba(255,255,255,.03)),
        rgba(255,255,255,.02);
    }
    .featured-head{
      display:grid;
      grid-template-columns:minmax(0,.72fr) minmax(0,1.28fr);
      gap:52px;
      align-items:start;
    }
    .featured-copy{
      display:grid;
      gap:18px;
      align-content:start;
    }
    .featured-question{
      margin-top:6px;
      max-width:20ch;
      font-size:25px;
      line-height:1.45;
      letter-spacing:-.04em;
      font-weight:300;
      color:var(--ink);
    }
    .featured-copy > p:last-of-type{
      max-width:44ch;
      font-size:17px;
      line-height:1.72;
    }
    .featured-stats{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
      margin-top:12px;
      max-width:820px;
    }
    .featured-stat,
    .featured-detail article,
    .project-meta div{
      border:1px solid var(--line);
      border-radius:22px;
      padding:14px;
      background:rgba(255,255,255,.03);
    }
    .featured-label,
    .project-meta span{
      display:block;
      color:var(--muted);
      font-size:9px;
      letter-spacing:.12em;
      text-transform:uppercase;
    }
    .featured-stat strong{
      display:block;
      margin-top:10px;
      color:var(--ink);
      font:700 22px 'Space Mono',monospace;
      letter-spacing:.05em;
    }
    .featured-stat p{margin-top:10px;font-size:14px;line-height:1.62}
    .featured-toggle,
    .btn,
    .featured-actions a,
    .card-actions a{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border:1px solid var(--line);
      border-radius:999px;
      padding:12px 16px;
      background:transparent;
      color:var(--ink);
      font-size:11px;
      font-weight:600;
      letter-spacing:.08em;
      text-transform:uppercase;
      transition:transform .2s ease,border-color .2s ease,background .2s ease,color .2s ease;
    }
    .featured-toggle:hover,
    .btn:hover,
    .featured-actions a:hover,
    .card-actions a:hover{transform:translateY(-1px);border-color:rgba(245,241,232,.22)}
    .featured-toggle{margin-top:22px}
    .featured-detail{
      display:none;
      margin-top:20px;
      padding-top:20px;
      border-top:1px solid var(--line);
    }
    .featured-detail.open{display:block}
    .featured-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }
    .featured-detail h3{
      margin:10px 0 10px;
      font-size:22px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .featured-actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:18px;
    }
    .featured-actions .primary,
    .card-actions .primary,
    button[type="submit"]{
      background:var(--ink);
      border-color:var(--ink);
      color:var(--bg);
    }
    .tabs{
      padding:104px 0;
      border-top:1px solid var(--line);
      border-bottom:1px solid var(--line);
    }
    .title{
      display:grid;
      grid-template-columns:.56fr 1.44fr;
      gap:34px;
      margin-bottom:30px;
    }
    .tabbar{
      position:sticky;
      top:60px;
      z-index:18;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      padding:14px 0 18px;
      margin-bottom:18px;
      background:linear-gradient(180deg, rgba(6,7,10,.98), rgba(6,7,10,.80));
    }
    .tabbtn{
      appearance:none;
      border:1px solid var(--line);
      border-radius:999px;
      padding:10px 14px;
      background:transparent;
      color:var(--soft);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
    }
    .tabbtn.active{
      background:var(--ink);
      color:var(--bg);
      border-color:var(--ink);
    }
    .summary{
      display:grid;
      grid-template-columns:.7fr 1.3fr;
      gap:18px;
      margin-bottom:18px;
      padding:22px;
      background:rgba(255,255,255,.025);
    }
    .summary strong{
      font-size:23px;
      font-weight:400;
      letter-spacing:-.04em;
    }
    .panel{display:none;animation:panel .36s ease both}
    .panel.active{display:block}
    @keyframes panel{
      from{opacity:0;transform:translateY(12px)}
      to{opacity:1;transform:none}
    }
    #projects{display:grid;gap:16px}
    .card{
      position:relative;
      display:grid;
      grid-template-columns:74px minmax(0,1fr);
      gap:30px;
      align-items:start;
      padding:36px 34px 32px 34px;
      background:rgba(255,255,255,.024);
    }
    .card::before{
      content:"";
      position:absolute;
      left:0;
      top:24px;
      bottom:24px;
      width:2px;
      border-radius:999px;
    }
    .card--health::before{background:var(--health)}
    .card--models::before{background:var(--models)}
    .card--ops::before{background:var(--ops)}
    .num{
      font-size:34px;
      font-weight:300;
      color:var(--muted);
      letter-spacing:-.08em;
    }
    .card-metric{
      margin:0 0 10px;
      color:var(--ink);
      font-size:17px;
      font-weight:700;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .card h3{
      margin:0 0 12px;
      font-size:clamp(28px,4vw,52px);
      line-height:1;
      letter-spacing:-.06em;
      font-weight:300;
      max-width:18ch;
    }
    .card p{font-size:16px;line-height:1.68}
    .project-meta{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
      margin:22px 0 0;
    }
    .project-meta strong{
      display:block;
      margin:6px 0;
      font-size:18px;
      letter-spacing:-.04em;
      font-weight:400;
    }
    .project-meta small{display:block;color:var(--soft);line-height:1.55}
    .meta-line{
      margin-top:22px;
      color:var(--muted);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      line-height:1.6;
    }
    .card-actions{
      display:flex;
      flex-direction:row;
      align-items:center;
      justify-content:flex-start;
      gap:10px;
      flex-wrap:wrap;
      min-width:0;
      grid-column:2;
      margin-top:4px;
    }
    .card-actions .secondary{background:rgba(255,255,255,.04)}
    #methodtab .grid,
    #stack .grid,
    #background .grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }
    #methodtab .grid{
      grid-template-columns:1fr;
      gap:0;
    }
    #methodtab .box{
      border:none;
      border-top:1px solid var(--line);
      border-radius:0;
      background:transparent;
      box-shadow:none;
      padding:24px 0 28px;
    }
    #methodtab .box:first-child{border-top:0}
    #methodtab .box span{min-width:3ch}
    #methodtab .box:nth-child(1) span,
    #methodtab .box:nth-child(2) span{color:var(--health)}
    #methodtab .box:nth-child(3) span,
    #methodtab .box:nth-child(4) span{color:var(--models)}
    #methodtab .box:nth-child(5) span,
    #methodtab .box:nth-child(6) span{color:var(--ops)}
    .box{
      padding:22px;
      background:rgba(255,255,255,.024);
      box-shadow:none;
    }
    .contact-divider{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      margin-top:46px;
    }
    .contact-divider span{height:2px;display:block}
    .contact-divider span:nth-child(1){background:var(--health)}
    .contact-divider span:nth-child(2){background:var(--models)}
    .contact-divider span:nth-child(3){background:var(--ops)}
    .contact{padding:110px 0 0}
    .contact h2{
      font-size:clamp(54px,8vw,120px);
      margin-bottom:26px;
    }
    .contact-layout{
      display:grid;
      grid-template-columns:.9fr 1.1fr;
      gap:52px;
      padding-top:30px;
      border-top:1px solid var(--line);
    }
    .contact-layout > div:first-child{max-width:34ch}
    form{
      padding:30px 30px 32px;
    }
    label{
      display:block;
      margin:8px 0 10px;
      color:var(--muted);
      font-size:11px;
      letter-spacing:.1em;
      text-transform:uppercase;
    }
    input:not(:first-of-type),
    textarea:not(:first-of-type){
      margin-top:4px;
    }
    input,
    textarea{
      width:100%;
      border:1px solid var(--line);
      border-radius:18px;
      background:rgba(255,255,255,.02);
      color:var(--ink);
      padding:16px 18px;
      margin-bottom:18px;
      font:inherit;
    }
    textarea{min-height:170px;resize:vertical}
    button[type="submit"]{
      cursor:pointer;
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .row{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
    .btn{background:rgba(255,255,255,.03)}
    .reveal{
      opacity:0;
      transform:translateY(24px);
      transition:opacity .7s ease, transform .7s ease;
    }
    .reveal.in{opacity:1;transform:none}
    @media (max-width: 1180px){
      .about-head,
