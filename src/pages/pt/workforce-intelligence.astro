    async function loadCaseData() {
      const response = await fetch("/data/workforce-intelligence.pt-br.json");
      return response.json();
    }

    function formatValue(value, kind) {
      if (kind === "percent") return `${(value * 100).toFixed(1).replace(".", ",")}%`;
      if (kind === "currencyCompact") {
        return new Intl.NumberFormat("pt-BR", {
          style: "currency",
          currency: "USD",
          notation: "compact",
          maximumFractionDigits: 1,
        }).format(value);
      }
      if (kind === "count") return new Intl.NumberFormat("pt-BR", { notation: "compact" }).format(value);
      return Number(value || 0).toFixed(2).replace(/\.00$/, "").replace(".", ",");
    }

    function escapeLabel(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    function shortLabel(value, max = 24) {
      const text = String(value);
      return text.length > max ? `${text.slice(0, max - 1)}…` : text;
    }

    function filterRows(rows, filters) {
      return rows.filter((row) =>
        Object.entries(filters).every(([key, selected]) => {
          if (key === "activeTab" || !selected.length) return true;
          return selected.includes(row[key]);
        }),
      );
    }

    function computeMetrics(rows) {
      const uniqueEmployees = new Set(rows.map((row) => row.employee_id)).size;
      const rowCount = Math.max(rows.length, 1);
      const average = (field) => rows.reduce((sum, row) => sum + Number(row[field] || 0), 0) / rowCount;
      return {
        headcount: uniqueEmployees,
        attritionRate: average("attrition_flag"),
        highRiskEmployees: rows.filter((row) => row.risk_band === "High Risk").length,
        averageTenure: average("years_at_company"),
        replacementCost: rows.reduce((sum, row) => sum + Number(row.estimated_replacement_cost || 0), 0),
        externalPressure: average("external_pressure_score"),
        averageRiskScore: average("attrition_probability"),
        overtimeRate: average("overtime_flag"),
        unemploymentRate: average("unemployment_rate"),
        wageIndex: average("wage_index"),
        laborDemandIndex: average("labor_demand_index"),
      };
    }

    function groupAverage(rows, groupKey, valueKey, limit = null) {
      const groups = new Map();
      rows.forEach((row) => {
        const key = row[groupKey];
        if (!key) return;
        const value = Number(row[valueKey] || 0);
        if (!groups.has(key)) groups.set(key, { sum: 0, count: 0 });
        groups.get(key).sum += value;
        groups.get(key).count += 1;
      });
      const items = [...groups.entries()]
        .map(([label, aggregate]) => ({ label, value: aggregate.sum / Math.max(aggregate.count, 1) }))
        .sort((first, second) => second.value - first.value);
      return limit ? items.slice(0, limit) : items;
    }

    function countBy(rows, key, order = [], limit = null) {
      const counts = new Map(order.map((label) => [label, 0]));
      rows.forEach((row) => {
        const value = row[key];
        if (!value) return;
        counts.set(value, (counts.get(value) || 0) + 1);
      });
      const items = [...counts.entries()]
        .map(([label, value]) => ({ label, value }))
        .filter((item) => item.value > 0)
        .sort((first, second) => second.value - first.value);
      return limit ? items.slice(0, limit) : items;
    }

    function renderFilters(filterConfig) {
      document.getElementById("filterBar").innerHTML = Object.entries(filterConfig)
        .map(([key, values]) => {
          const selectedCount = state[key].length;
          return `
            <details class="filter-group">
              <summary>${copy.filterLabels[key]}${selectedCount ? ` · ${selectedCount}` : ""}</summary>
              <div class="filter-options">
                ${values
                  .map(
                    (value) => `
                      <label class="filter-option">
                        <input type="checkbox" data-filter="${key}" value="${value}" ${state[key].includes(value) ? "checked" : ""} />
                        <span>${value}</span>
                      </label>
                    `,
                  )
                  .join("")}
              </div>
            </details>
          `;
        })
        .join("");

      document.querySelectorAll("[data-filter]").forEach((input) => {
        input.addEventListener("change", (event) => {
          const { filter } = event.target.dataset;
          const { value, checked } = event.target;
          state[filter] = checked
            ? [...state[filter], value]
            : state[filter].filter((item) => item !== value);
          sync();
        });
      });
    }

    function renderTabs() {
      const entries = Object.entries(copy.tabs);
      document.getElementById("tabBar").innerHTML = entries
        .map(
          ([key, tab]) => `
            <button class="tab-button ${state.activeTab === key ? "active" : ""}" type="button" data-tab="${key}">
              ${tab.label}
            </button>
          `,
        )
        .join("");

      document.querySelectorAll("[data-tab]").forEach((button) => {
        button.addEventListener("click", () => {
          state.activeTab = button.dataset.tab;
          sync();
        });
      });
    }

    function renderTabFrame() {
      const tab = copy.tabs[state.activeTab];
      document.getElementById("tabEyebrow").textContent = tab.eyebrow;
      document.getElementById("tabTitle").textContent = tab.title;
      document.getElementById("tabText").textContent = tab.text;
      document.getElementById("narrativeTitle").textContent = tab.narrativeTitle;
      document.getElementById("tabRail").innerHTML = tab.rail
        .map(
          (item) => `
            <div>
              <strong>${item.value}</strong>
              <span>${item.label}</span>
            </div>
          `,
        )
        .join("");
    }

    function renderKPIs(metrics) {
      const cards = copy.tabs[state.activeTab].kpis;
      document.getElementById("kpiBand").innerHTML = cards
        .map(
          (item) => `
            <article class="kpi-card">
              <div class="kpi-value">${formatValue(metrics[item.key], item.format)}</div>
              <span class="kpi-label">${item.label}</span>
            </article>
          `,
        )
        .join("");
    }

    function renderHorizontalChart(items, formatter, palette = () => "#5ac8d8") {
      if (!items.length) return `<div class="empty-state">${copy.noResults}</div>`;
      const maxValue = Math.max(...items.map((item) => item.value), 1);
      const chartWidth = 620;
      const labelWidth = 188;
      const valueWidth = 84;
      const plotWidth = chartWidth - labelWidth - valueWidth - 12;
      const rowGap = 28;
      const barHeight = 18;
      const topPad = 18;
      const bottomPad = 18;
      const height = topPad + items.length * rowGap + bottomPad;

      return `
        <div class="chart-shell">
          <svg viewBox="0 0 ${chartWidth} ${height}" role="img" aria-label="dashboard chart">
            ${items
              .map((item, index) => {
                const y = topPad + index * rowGap;
                const width = Math.max((item.value / maxValue) * plotWidth, 8);
                return `
                  <text x="0" y="${y + 13}" fill="#f3eee4" style="font:600 12px Inter, sans-serif">
                    <title>${escapeLabel(item.label)}</title>${escapeLabel(shortLabel(item.label))}
                  </text>
                  <line x1="${labelWidth}" y1="${y + 9}" x2="${chartWidth - valueWidth}" y2="${y + 9}" stroke="rgba(255,255,255,.08)" stroke-width="1"></line>
                  <rect x="${labelWidth}" y="${y}" rx="9" ry="9" width="${width}" height="${barHeight}" fill="${palette(item.label, index)}"></rect>
                  <text x="${chartWidth - valueWidth + 8}" y="${y + 13}" fill="#fffaf2" style="font:700 11px 'IBM Plex Mono', monospace">${formatter(item.value)}</text>
                `;
              })
              .join("")}
            <line x1="${labelWidth}" y1="${height - 8}" x2="${chartWidth - valueWidth}" y2="${height - 8}" stroke="rgba(255,255,255,.2)" stroke-width="1"></line>
          </svg>
        </div>
      `;
    }

    function renderList(items, label = "registros") {
      if (!items.length) return `<div class="empty-state">${copy.noResults}</div>`;
      return `
        <div class="list-shell">
          ${items
            .map(
              (item) => `
                <div class="list-row">
                  <div>
                    <strong>${escapeLabel(item.label)}</strong>
                    <span>${label}</span>
                  </div>
                  <em>${item.value.toLocaleString("pt-BR")}</em>
                </div>
              `,
            )
            .join("")}
        </div>
      `;
    }

