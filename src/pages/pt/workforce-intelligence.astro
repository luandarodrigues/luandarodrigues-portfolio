        notes: [
          {
            title: "Risco modelado ainda precisa ser explicável",
            text: "Essa seção mantém o score interpretável ao quebrá-lo em concentração por cargo, faixa salarial, drivers e ações recomendadas.",
          },
          {
            title: "Overtime ajuda a contextualizar o score",
            text: "A faixa de KPIs inclui overtime porque intensidade de trabalho é uma âncora bem mais útil para negócio do que uma probabilidade isolada.",
          },
          {
            title: "Ações importam tanto quanto drivers",
            text: "Um produto de risco fica mais útil quando consegue apontar para uma decisão, não apenas para uma probabilidade.",
          },
        ],
      };
    }

    function marketPanels(rows, metrics) {
      const byOccupation = groupAverage(rows, "occupation_group", "external_pressure_score");
      const byDepartment = groupAverage(rows, "department_name", "external_pressure_score");
      const byRole = groupAverage(rows, "job_role", "external_pressure_score", 8);
      const marketIndicators = [
        { label: "Desemprego", value: metrics.unemploymentRate },
        { label: "Wage index", value: metrics.wageIndex },
        { label: "Labor demand", value: metrics.laborDemandIndex },
      ];
      return {
        sectors: [
          {
            eyebrow: "Mapa de exposição",
            title: "Onde o mercado puxa mais",
            text: "Este primeiro setor devolve a pressão de mercado para a estrutura de workforce, deixando a camada externa mais legível para negócio.",
            panels: [
              {
                title: "Pressão externa por grupo ocupacional",
                note: "média do score de pressão externa",
                copy: "Os grupos ocupacionais são a forma mais limpa de ler onde o mercado externo tende a puxar com mais força.",
                chart: renderHorizontalChart(byOccupation, (value) => value.toFixed(2).replace(".", ","), () => "#d7ff6f"),
              },
              {
                title: "Departamentos expostos à pressão de mercado",
                note: "média do score de pressão externa",
                copy: "Essa tradução de volta para departamentos mostra onde a pressão externa vira um problema real de workforce planning.",
                chart: renderHorizontalChart(byDepartment, (value) => value.toFixed(2).replace(".", ","), () => "#98c1ff"),
              },
            ],
          },
          {
            eyebrow: "Camada de sinal",
            title: "O que alimenta o score de pressão",
            text: "O segundo setor isola os indicadores e o mapeamento por papel para que o score externo não vire só um adorno visual.",
            panels: [
              {
                title: "Snapshot dos indicadores de mercado",
                note: "sinal externo atual",
                copy: "A camada de mercado é composta por desemprego, salário e demanda de trabalho, que alimentam o score de pressão.",
                chart: renderHorizontalChart(marketIndicators, (value) => value.toFixed(2).replace(".", ","), (label, index) => ["#ff7676", "#f0b35f", "#5ac8d8"][index] || "#5ac8d8"),
              },
              {
                title: "Pressão externa por cargo",
                note: "média do score por papel",
                copy: "Esse corte por cargo ajuda a conectar a pressão ocupacional externa com os papéis específicos mostrados no case.",
                chart: renderHorizontalChart(byRole, (value) => value.toFixed(2).replace(".", ","), () => "#d7ff6f"),
              },
            ],
          },
        ],
        readoutCards: [
          { label: "Ocupação líder", value: byOccupation[0]?.label || "N/D", text: "maior score de pressão externa" },
          { label: "Departamento líder", value: byDepartment[0]?.label || "N/D", text: "maior exposição no recorte" },
          { label: "Wage index", value: formatValue(metrics.wageIndex, "decimal"), text: "sinal atual de salário" },
          { label: "Labor demand", value: formatValue(metrics.laborDemandIndex, "decimal"), text: "sinal atual de demanda" },
        ],
        notes: [
          {
            title: "A camada externa muda a história",
            text: "Mesmo quando attrition está estável, a pressão do mercado pode mudar o nível de urgência de um segmento de workforce.",
          },
          {
            title: "O mapeamento ocupacional é o elo de BI",
            text: "O contexto de mercado só fica útil quando pode ser traduzido de volta para a estrutura interna de papéis que a liderança reconhece.",
          },
          {
            title: "Isso continua sendo um produto de dados governado",
            text: "A visão de dashboard é só uma superfície. O valor mais forte segue nas tabelas modeladas e nas métricas documentadas.",
          },
        ],
      };
    }

    function renderPanels(panelData) {
      document.getElementById("dashboardGrid").innerHTML = panelData.sectors
        .map(
          (sector) => `
            <section class="sector-block">
              <div class="sector-head">
                <div>
                  <span class="eyebrow">${sector.eyebrow}</span>
                  <h4>${sector.title}</h4>
                </div>
                <p>${sector.text}</p>
              </div>
              <div class="sector-panels">
                ${sector.panels
                  .map(
                    (panel) => `
                        <article class="panel-card">
                          <div class="panel-head">
                            <h3>${panel.title}</h3>
                            <span class="panel-note">${panel.note}</span>
                          </div>
                          ${panel.chart}
                        </article>
                    `,
                  )
                  .join("")}
              </div>
            </section>
          `,
        )
        .join("");

      document.getElementById("readoutGrid").innerHTML = panelData.readoutCards
        .map(
          (card) => `
            <article class="readout-card">
              <span class="readout-label">${card.label}</span>
              <strong>${card.value}</strong>
              <span>${card.text}</span>
            </article>
          `,
        )
        .join("");

      document.getElementById("insightCopy").innerHTML = panelData.notes
        .map(
          (item) => `
            <article>
              <h4>${item.title}</h4>
              <p>${item.text}</p>
            </article>
          `,
        )
        .join("");
    }

    function renderHeroHighlights(metrics) {
      document.getElementById("heroHighlights").innerHTML = `
        <div class="hero-metric">
          <strong>${formatValue(metrics.headcount, "count")}</strong>
          <span class="hero-metric-label">Colaboradores no recorte</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(metrics.attritionRate, "percent")}</strong>
          <span class="hero-metric-label">Attrition rate</span>
        </div>
        <div class="hero-metric">
          <strong>${metrics.highRiskEmployees}</strong>
          <span class="hero-metric-label">Colaboradores em alto risco</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(metrics.replacementCost, "currencyCompact")}</strong>
          <span class="hero-metric-label">Exposição de custo</span>
        </div>
      `;
    }

    let caseData = null;

    function sync() {
      if (!caseData) return;
      renderFilters(caseData.filters);
      renderTabs();
      renderTabFrame();
      const filteredRows = filterRows(caseData.rows, state);
      const metrics = computeMetrics(filteredRows);
      renderHeroHighlights(metrics);
      renderKPIs(metrics);

      if (!filteredRows.length) {
        document.getElementById("dashboardGrid").innerHTML = `<div class="empty-state">${copy.noResults}</div>`;
        document.getElementById("readoutGrid").innerHTML = "";
        document.getElementById("insightCopy").innerHTML = "";
        return;
      }

      if (state.activeTab === "risk") {
        renderPanels(riskPanels(filteredRows));
      } else if (state.activeTab === "market") {
        renderPanels(marketPanels(filteredRows, metrics));
      } else {
        renderPanels(executivePanels(filteredRows));
      }
    }

    document.getElementById("resetFilters").addEventListener("click", () => {
      Object.keys(state).forEach((key) => {
        if (key !== "activeTab") state[key] = [];
      });
      sync();
    });

    loadCaseData().then((payload) => {
      caseData = payload;
      sync();
    });
  </script>
</body>
</html>
