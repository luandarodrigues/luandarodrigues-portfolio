---
const pageTitle = "Workforce Intelligence | Luanda Rodrigues";
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{pageTitle}</title>
  <meta
    name="description"
    content="Painel interativo de workforce combinando risco de turnover, pressão de mercado e métricas prontas para BI."
  />
  <link rel="alternate" hreflang="en" href="/workforce-intelligence" />
  <link rel="icon" href="/assets/logo/monogram.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root{--bg:#030303;--ink:#f7f5ef;--soft:#c9c4ba;--muted:#817d74;--line:rgba(247,245,239,.14);--panel:rgba(255,255,255,.035);--panel-strong:rgba(255,255,255,.06);--acid:#d7ff6f;--blue:#9fc8ff;--teal:#53d0db;--amber:#f0b35f;--red:#ff7777}
    *{box-sizing:border-box}
    html{background:var(--bg);scroll-behavior:smooth}
    body{margin:0;background:var(--bg);color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow-x:hidden}
    body:before{content:"";position:fixed;inset:0;background:radial-gradient(circle at 82% 4%,rgba(215,255,111,.11),transparent 25%),radial-gradient(circle at 8% 28%,rgba(159,200,255,.08),transparent 28%),linear-gradient(rgba(247,245,239,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(247,245,239,.02) 1px,transparent 1px);background-size:auto,auto,82px 82px,82px 82px;pointer-events:none;z-index:-1}
    a{color:inherit;text-decoration:none}
    .frame{display:grid;grid-template-columns:minmax(260px,22vw) 1fr;min-height:100vh}
    .side{position:sticky;top:0;height:100vh;padding:26px;display:flex;flex-direction:column;justify-content:space-between;border-right:1px solid var(--line);overflow:hidden}
    .brand{display:flex;align-items:center;gap:14px}
    .brand img{width:68px;height:68px;border-radius:20px;background:#fff}
    .brand strong{display:block;font-size:22px;line-height:1;letter-spacing:-.055em}
    .brand span{display:block;color:var(--soft);font-size:17px}
    .intro-card{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:22px 0;margin-top:44px}
    .intro-card p{font-size:22px;line-height:1.15;letter-spacing:-.055em;color:#e9e5dc;margin:0}
    .side-viz{height:220px;margin-top:20px;border:1px solid var(--line);border-radius:26px;position:relative;overflow:hidden;background:radial-gradient(circle at 42% 45%,rgba(215,255,111,.12),transparent 35%),radial-gradient(circle at 68% 70%,rgba(159,200,255,.10),transparent 36%),rgba(255,255,255,.025)}
    .side-viz canvas{position:absolute;inset:0;width:100%;height:100%}
    .side-viz:after{content:'dashboard case';position:absolute;left:16px;bottom:13px;color:var(--muted);font:700 9px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.14em}
    .side-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-top:16px}
    .stat,.shell,.kpi-card,.panel-card,.summary-card,.build-card,.repo-card,.readout-card,.narrative-card,.hero-note{border:1px solid var(--line);border-radius:20px;background:var(--panel)}
    .stat{padding:13px 11px}
    .stat strong{display:block;font-size:23px;letter-spacing:-.06em}
    .stat span,.eyebrow,.mini,.kpi-label,.panel-note,.summary-card span,.build-card span,.readout-label,.hero-metric-label{display:block;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:9px;letter-spacing:.08em}
    .links{display:grid;border-top:1px solid var(--line)}
    .links a{display:flex;justify-content:space-between;border-bottom:1px solid var(--line);padding:13px 4px;color:var(--soft);font-size:13px;font-weight:700}
    .main{padding:26px 34px 100px;min-width:0}
    .content{max-width:1360px}
    .topnav{height:58px;display:flex;justify-content:flex-end;gap:23px;align-items:center;border-bottom:1px solid var(--line);position:sticky;top:0;background:linear-gradient(to bottom,rgba(3,3,3,.96),rgba(3,3,3,.74));backdrop-filter:blur(18px);z-index:20}
    .topnav a,.eyebrow,.reset-btn,summary,.filter-option label{font-family:'IBM Plex Mono',monospace}
    .topnav a{font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:var(--soft);font-weight:800;white-space:nowrap}
    .lang{border:1px solid var(--line);padding:8px 10px;border-radius:999px}
    .dashboard-shell{padding-top:24px;display:grid;gap:16px}
    .dashboard-head{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(320px,.85fr);gap:16px;align-items:stretch}
    .dashboard-head h1{font-size:clamp(34px,4.6vw,62px);line-height:.92;letter-spacing:-.085em;margin:10px 0 12px}
    .dashboard-head p{margin:0;color:#ddd7cc;font-size:16px;line-height:1.42;max-width:70ch}
    .mini-badges{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
    .badge{border:1px solid var(--line);border-radius:999px;padding:8px 10px;color:var(--soft);font:700 10px 'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em;background:rgba(255,255,255,.03)}
    .hero-note{padding:18px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));display:grid;gap:16px}
    .hero-note h2{margin:8px 0 0;font-size:26px;line-height:1.04;letter-spacing:-.05em}
    .hero-note p{margin:0;color:var(--soft);font-size:14px;line-height:1.5}
    .hero-metrics{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .hero-metric{padding:14px;border:1px solid var(--line);border-radius:16px;background:rgba(0,0,0,.14)}
    .hero-metric strong{display:block;font-size:26px;letter-spacing:-.06em}
    .shell{padding:16px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03))}
    .controls-shell{display:grid;gap:14px}
    .filter-row{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;align-items:start}
    details.filter-group{border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.02);padding:10px 12px}
    details.filter-group summary{list-style:none;cursor:pointer;color:var(--soft);font-size:11px;text-transform:uppercase;letter-spacing:.08em;font-weight:700}
    details.filter-group summary::-webkit-details-marker{display:none}
    .filter-options{display:grid;gap:8px;max-height:220px;overflow:auto;padding-top:12px}
    .filter-option{display:flex;align-items:flex-start;gap:8px;color:#ece7dc;font-size:13px}
    .filter-option input{margin-top:2px}
    .filter-actions{display:flex;justify-content:flex-end}
    .reset-btn{appearance:none;border:1px solid var(--line);border-radius:999px;background:var(--ink);color:var(--bg);padding:12px 15px;font-weight:800;cursor:pointer}
    .kpi-band{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:10px}
    .kpi-card{padding:16px;min-height:104px;display:grid;align-content:space-between;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.03))}
    .kpi-value{font-size:36px;letter-spacing:-.07em;font-weight:800}
    .dashboard-panels{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .panel-card{padding:20px;min-height:336px;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(255,255,255,.025))}
    .panel-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:16px}
    .panel-head h3{margin:0;font-size:24px;line-height:1;letter-spacing:-.05em}
    .panel-note{font-size:9px;color:var(--acid)}
    .panel-copy{margin:0 0 16px;color:var(--soft);font-size:14px;line-height:1.45}
    .chart-shell svg{display:block;width:100%;height:auto}
    .bar-label{fill:#f2eee6;font:12px Inter,sans-serif}
    .value-label{fill:#f2eee6;font:700 11px 'IBM Plex Mono',monospace}
    .grid-line{stroke:rgba(255,255,255,.1);stroke-width:1}
    .baseline{stroke:rgba(255,255,255,.18);stroke-width:1}
    .readout-shell{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.9fr);gap:14px}
    .readout-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
    .readout-card{padding:16px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.03))}
    .readout-card strong{display:block;font-size:24px;letter-spacing:-.06em}
    .readout-card span{display:block;margin-top:5px;color:var(--soft);font-size:12px;line-height:1.35}
    .narrative-card{padding:18px;background:linear-gradient(135deg,rgba(255,255,255,.07),rgba(255,255,255,.025))}
    .narrative-card h3{margin:10px 0 14px;font-size:22px;letter-spacing:-.04em}
    .narrative-copy{display:grid;gap:12px}
    .narrative-copy article{padding-top:12px;border-top:1px solid var(--line)}
    .narrative-copy article:first-child{padding-top:0;border-top:0}
    .narrative-copy h4{margin:0 0 6px;font-size:17px;letter-spacing:-.03em}
    .narrative-copy p{margin:0;color:var(--soft);font-size:14px;line-height:1.45}
    .below-fold{display:grid;grid-template-columns:1.05fr .95fr;gap:14px;margin-top:18px}
    .summary-card,.repo-card{padding:22px}
    .summary-card h2,.repo-card h2{font-size:30px;line-height:.96;letter-spacing:-.07em;margin:10px 0 14px}
    .summary-list{display:grid;gap:14px}
    .summary-list article{padding-top:12px;border-top:1px solid var(--line)}
    .summary-list article:first-child{padding-top:0;border-top:0}
    .summary-list h3{margin:0 0 8px;font-size:18px;letter-spacing:-.04em}
    .summary-list p,.repo-card p,.build-card p{margin:0;color:var(--soft);line-height:1.5}
    .repo-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
    .repo-actions a{border:1px solid var(--line);border-radius:999px;padding:12px 15px;font-weight:800}
    .repo-actions a.primary{background:var(--acid);border-color:var(--acid);color:#030303}
    .build-shell{margin-top:18px}
    .build-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-top:14px}
    .build-card{padding:18px}
    .build-card h3{margin:12px 0 8px;font-size:18px;letter-spacing:-.04em}
    .empty-state{padding:18px;border:1px dashed var(--line);border-radius:18px;color:var(--soft);font-size:14px}
    @media(max-width:1280px){
      .dashboard-head,.readout-shell,.below-fold,.build-grid{grid-template-columns:1fr}
      .kpi-band{grid-template-columns:repeat(3,minmax(0,1fr))}
      .readout-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media(max-width:980px){
      .frame{display:block}
      .side{position:relative;height:auto;border-right:0;border-bottom:1px solid var(--line);padding:18px}
      .main{padding:0 18px 70px}
      .content{max-width:none}
      .topnav{justify-content:flex-start;overflow-x:auto;gap:10px;height:auto;padding:12px 0}
      .topnav a{font-size:11px;letter-spacing:.06em;flex:0 0 auto;border:1px solid var(--line);border-radius:999px;padding:8px 10px}
      .dashboard-shell{padding-top:18px}
      .filter-row,.dashboard-panels{grid-template-columns:1fr}
      .kpi-band{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media(max-width:560px){
      .main{padding-left:14px;padding-right:14px}
      .side{padding:16px}
      .kpi-band,.readout-grid,.hero-metrics{grid-template-columns:1fr}
      .dashboard-head h1{font-size:38px}
      .dashboard-head p{font-size:14px}
    }
  </style>
</head>
<body>
  <div class="frame">
    <aside class="side">
      <div>
        <a class="brand" href="/pt/">
          <img src="/assets/logo/monogram.svg" alt="" />
          <div>
            <strong>Luanda Rodrigues,</strong>
            <span>Analista de Dados</span>
          </div>
        </a>
        <div class="intro-card">
          <p>Um case com cara de BI, mostrando como sinais de workforce podem virar uma camada mais útil de decisão.</p>
        </div>
        <div class="side-viz" aria-label="Visual abstrato de dados">
          <canvas id="sideGraphCanvas"></canvas>
        </div>
        <div class="side-stats">
          <div class="stat"><strong>02</strong><span>segundo destaque</span></div>
          <div class="stat"><strong>BI</strong><span>foco em painel</span></div>
          <div class="stat"><strong>PT/EN</strong><span>case page</span></div>
        </div>
      </div>
      <div class="links">
        <a href="/pt/">Portfólio <span>↗</span></a>
        <a href="https://github.com/luandarodrigues/workforce-labor-market-intelligence-bi-suite">Repositório <span>↗</span></a>
        <a href="https://www.linkedin.com/in/luanda-rodrigues">LinkedIn <span>↗</span></a>
        <a href="/workforce-intelligence">English <span>↗</span></a>
      </div>
    </aside>
    <main class="main">
      <div class="content">
        <nav class="topnav">
          <a href="#dashboard">Painel</a>
          <a href="#summary">Resumo</a>
          <a href="#build">Construção</a>
          <a href="#repo">Repo</a>
          <a class="lang" href="/workforce-intelligence">EN</a>
        </nav>

        <section class="dashboard-shell" id="dashboard">
          <div class="dashboard-head">
            <div>
              <span class="eyebrow">People Analytics / Produto de BI / Workforce Planning</span>
              <h1>Workforce & Labor Market Intelligence</h1>
              <p>
                Um case com leitura de painel, desenhado para mostrar como sinais internos de RH,
                pressão de mercado e risco de turnover podem ser organizados em uma camada mais limpa de decisão.
              </p>
              <div class="mini-badges">
                <span class="badge">Python</span>
                <span class="badge">SQL</span>
                <span class="badge">DuckDB</span>
                <span class="badge">Risco de attrition</span>
                <span class="badge">Outputs prontos para BI</span>
              </div>
            </div>
            <div class="hero-note">
              <div>
                <span class="mini">Pergunta central</span>
                <h2>Onde a prioridade de retenção deve entrar primeiro quando risco interno e pressão externa andam juntos?</h2>
              </div>
              <p>Use os filtros para mudar o recorte e leia a faixa de KPIs com os quatro painéis principais como uma única superfície de decisão.</p>
              <div class="hero-metrics" id="heroHighlights"></div>
            </div>
          </div>

          <div class="shell controls-shell">
            <div class="filter-row" id="filterBar"></div>
            <div class="filter-actions">
              <button class="reset-btn" id="resetFilters" type="button">Limpar filtros</button>
            </div>
          </div>

          <div class="kpi-band" id="kpiBand"></div>
          <div class="dashboard-panels" id="dashboardGrid"></div>

          <div class="readout-shell">
            <div class="readout-grid" id="readoutGrid"></div>
            <div class="narrative-card">
              <span class="readout-label">Notas de decisão</span>
              <h3>O que pesa mais no recorte atual</h3>
              <div class="narrative-copy" id="insightCopy"></div>
            </div>
          </div>
        </section>

        <section class="below-fold" id="summary">
          <div class="summary-card">
            <span class="eyebrow">Resumo executivo</span>
            <h2>O que este painel está mostrando.</h2>
            <div class="summary-list">
              <article>
                <h3>Attrition faz mais sentido com contexto</h3>
                <p>O objetivo aqui não é só mostrar quem pode sair, mas combinar risco interno, exposição de custo e pressão de mercado na mesma leitura.</p>
              </article>
              <article>
                <h3>Prioridade importa mais que turnover bruto</h3>
                <p>Os departamentos mais urgentes nem sempre são os que têm attrition mais alto isoladamente. A leitura de prioridade é o que torna esse painel mais operacional.</p>
              </article>
              <article>
                <h3>O output foi feito para ser reaproveitado</h3>
                <p>Fatos, dimensões, KPIs e sinais de risco foram desenhados para alimentar ferramentas diferentes, em vez de morrerem em um único dashboard.</p>
              </article>
            </div>
          </div>

          <div class="repo-card" id="repo">
            <span class="eyebrow">Acesso ao projeto</span>
            <h2>O repositório é a evidência por trás do painel.</h2>
            <p>
              Esta página carrega a camada interativa do dashboard. O repositório fica como apoio para pipeline,
              lógica de warehouse, exports, testes e documentação de métricas por trás do case.
            </p>
            <div class="repo-actions">
              <a class="primary" href="https://github.com/luandarodrigues/workforce-labor-market-intelligence-bi-suite">Abrir repositório ↗</a>
              <a href="/pt/#work">Voltar ao portfólio ↗</a>
            </div>
          </div>
        </section>

        <section class="shell build-shell" id="build">
          <span class="eyebrow">Como foi construído</span>
          <h2 style="margin:10px 0 0;font-size:34px;line-height:.96;letter-spacing:-.07em">Da fonte de dados até uma camada reutilizável de BI.</h2>
          <div class="build-grid">
            <article class="build-card">
              <span>01 / RH interno</span>
              <h3>Base operacional de workforce</h3>
              <p>A camada de colaboradores parte da estrutura IBM HR Attrition e vira dimensões e fatos modelados.</p>
            </article>
            <article class="build-card">
              <span>02 / Mercado externo</span>
              <h3>Contexto de pressão de trabalho</h3>
              <p>As métricas externas são alinhadas por região e grupo ocupacional para ir além de headcount e turnover internos.</p>
            </article>
            <article class="build-card">
              <span>03 / Camada de risco</span>
              <h3>Score explicável de attrition</h3>
              <p>O output do modelo vira bandas, drivers e recomendações, e depois alimenta um índice de prioridade de retenção.</p>
            </article>
            <article class="build-card">
              <span>04 / Outputs de BI</span>
              <h3>Exports reaproveitáveis</h3>
              <p>O projeto termina em exports para dashboard, tabelas de warehouse e documentação de métricas, não em um mockup isolado.</p>
            </article>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    function initMiniGraph() {
      const canvas = document.getElementById("sideGraphCanvas");
      if (!canvas) return;
      const box = canvas.parentElement;
      const context = canvas.getContext("2d");
      let width = 0;
      let height = 0;
      let dpr = 1;
      let points = [];

      function resize() {
        dpr = Math.min(devicePixelRatio || 1, 2);
        width = box.clientWidth;
        height = box.clientHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        context.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function reset() {
        resize();
        points = [];
        const hubs = [
          [0.24, 0.34, "#d7ff6f"],
          [0.62, 0.43, "#9fc8ff"],
          [0.45, 0.72, "#f7f5ef"],
        ];

        hubs.forEach((hub, groupIndex) => {
          points.push({
            x: width * hub[0],
            y: height * hub[1],
            vx: 0,
            vy: 0,
            r: 4.2,
            c: hub[2],
            hub: true,
            group: groupIndex,
          });

          for (let index = 0; index < 18; index += 1) {
            const angle = Math.random() * Math.PI * 2;
            const radius = 28 + Math.random() * 78;
            points.push({
              x: width * hub[0] + Math.cos(angle) * radius,
              y: height * hub[1] + Math.sin(angle) * radius,
              vx: (Math.random() - 0.5) * 0.55,
              vy: (Math.random() - 0.5) * 0.55,
              r: 1.3 + Math.random() * 1.8,
              c: hub[2],
              group: groupIndex,
            });
          }
        });
      }

      function draw() {
        context.clearRect(0, 0, width, height);
        points.forEach((point, index) => {
          point.x += point.vx + Math.sin(Date.now() / 650 + index) * 0.06;
          point.y += point.vy + Math.cos(Date.now() / 730 + index) * 0.06;
          if (point.x < 14 || point.x > width - 14) point.vx *= -1;
          if (point.y < 14 || point.y > height - 26) point.vy *= -1;
        });

        for (let i = 0; i < points.length; i += 1) {
          for (let j = i + 1; j < points.length; j += 1) {
            const first = points[i];
            const second = points[j];
            const distance = Math.hypot(first.x - second.x, first.y - second.y);
            if (distance < 100 && (first.group === second.group || distance < 52)) {
              context.globalAlpha = Math.max(0.04, 0.25 - distance / 410);
              context.strokeStyle = first.group === second.group ? "#d9d9d9" : "#8d8d8d";
              context.lineWidth = first.hub || second.hub ? 0.75 : 0.45;
              context.beginPath();
              context.moveTo(first.x, first.y);
              context.lineTo(second.x, second.y);
              context.stroke();
            }
          }
        }

        points.forEach((point) => {
          context.globalAlpha = point.hub ? 0.92 : 0.74;
          context.fillStyle = point.c;
          context.beginPath();
          context.arc(point.x, point.y, point.r, 0, Math.PI * 2);
          context.fill();

          if (point.hub) {
            context.globalAlpha = 0.15;
            context.beginPath();
            context.arc(point.x, point.y, 34, 0, Math.PI * 2);
            context.fill();
          }
        });

        requestAnimationFrame(draw);
      }

      addEventListener("resize", reset);
      reset();
      draw();
    }

    initMiniGraph();

    const state = {
      department_name: [],
      job_role: [],
      risk_band: [],
      salary_band: [],
    };

    const copy = {
      filterLabels: {
        department_name: "Departamento",
        job_role: "Cargo",
        risk_band: "Banda de risco",
        salary_band: "Banda salarial",
      },
      kpis: [
        { key: "headcount", label: "Headcount", format: "count" },
        { key: "attritionRate", label: "Attrition rate", format: "percent" },
        { key: "highRiskEmployees", label: "Alto risco", format: "count" },
        { key: "averageTenure", label: "Tenure médio", format: "decimal" },
        { key: "replacementCost", label: "Custo de reposição", format: "currencyCompact" },
        { key: "externalPressure", label: "Pressão externa", format: "decimal" },
      ],
      noResults: "Nenhum registro corresponde ao filtro atual.",
    };

    async function loadCaseData() {
      const response = await fetch("/data/workforce-intelligence.pt-br.json");
      return response.json();
    }

    function formatValue(value, kind) {
      if (kind === "percent") return `${(value * 100).toFixed(1).replace(".", ",")}%`;
      if (kind === "currencyCompact") {
        return new Intl.NumberFormat("pt-BR", {
          style: "currency",
          currency: "USD",
          notation: "compact",
          maximumFractionDigits: 1,
        }).format(value);
      }
      if (kind === "decimal") return Number(value).toFixed(2).replace(/\.00$/, "").replace(".", ",");
      if (kind === "count") return new Intl.NumberFormat("pt-BR", { notation: "compact" }).format(value);
      return String(value);
    }

    function escapeLabel(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    function filterRows(rows, filters) {
      return rows.filter((row) =>
        Object.entries(filters).every(([key, selected]) => {
          if (!selected.length) return true;
          return selected.includes(row[key]);
        }),
      );
    }

    function computeSummary(rows) {
      const uniqueEmployees = new Set(rows.map((row) => row.employee_id)).size;
      const attritionRate =
        rows.reduce((sum, row) => sum + Number(row.attrition_flag || 0), 0) / Math.max(rows.length, 1);
      const highRiskEmployees = rows.filter((row) => row.risk_band === "High Risk").length;
      const averageTenure =
        rows.reduce((sum, row) => sum + Number(row.years_at_company || 0), 0) / Math.max(rows.length, 1);
      const replacementCost = rows.reduce((sum, row) => sum + Number(row.estimated_replacement_cost || 0), 0);
      const externalPressure =
        rows.reduce((sum, row) => sum + Number(row.external_pressure_score || 0), 0) / Math.max(rows.length, 1);

      return {
        headcount: uniqueEmployees,
        attritionRate,
        highRiskEmployees,
        averageTenure,
        replacementCost,
        externalPressure,
      };
    }

    function groupAverage(rows, groupKey, valueKey) {
      const groups = new Map();
      rows.forEach((row) => {
        const key = row[groupKey];
        if (!key) return;
        const value = Number(row[valueKey] || 0);
        if (!groups.has(key)) groups.set(key, { sum: 0, count: 0 });
        groups.get(key).sum += value;
        groups.get(key).count += 1;
      });

      return [...groups.entries()]
        .map(([label, aggregate]) => ({ label, value: aggregate.sum / Math.max(aggregate.count, 1) }))
        .sort((first, second) => second.value - first.value);
    }

    function countBy(rows, key, order = []) {
      const counts = new Map(order.map((label) => [label, 0]));
      rows.forEach((row) => {
        const value = row[key];
        if (!value) return;
        counts.set(value, (counts.get(value) || 0) + 1);
      });

      return [...counts.entries()]
        .map(([label, value]) => ({ label, value }))
        .filter((item) => item.value > 0)
        .sort((first, second) => second.value - first.value);
    }

    function renderFilters(filterConfig) {
      document.getElementById("filterBar").innerHTML = Object.entries(filterConfig)
        .map(([key, values]) => {
          const selectedCount = state[key].length;
          return `
            <details class="filter-group">
              <summary>${copy.filterLabels[key]}${selectedCount ? ` · ${selectedCount}` : ""}</summary>
              <div class="filter-options">
                ${values
                  .map(
                    (value) => `
                      <label class="filter-option">
                        <input type="checkbox" data-filter="${key}" value="${value}" ${
                          state[key].includes(value) ? "checked" : ""
                        } />
                        <span>${value}</span>
                      </label>
                    `,
                  )
                  .join("")}
              </div>
            </details>
          `;
        })
        .join("");

      document.querySelectorAll("[data-filter]").forEach((input) => {
        input.addEventListener("change", (event) => {
          const { filter } = event.target.dataset;
          const { value, checked } = event.target;
          state[filter] = checked
            ? [...state[filter], value]
            : state[filter].filter((item) => item !== value);
          sync();
        });
      });
    }

    function renderKPIs(summary) {
      document.getElementById("kpiBand").innerHTML = copy.kpis
        .map(
          (item) => `
            <article class="kpi-card">
              <div class="kpi-value">${formatValue(summary[item.key], item.format)}</div>
              <span class="kpi-label">${item.label}</span>
            </article>
          `,
        )
        .join("");
    }

    function renderHorizontalChart(items, formatter, palette = () => "#53d0db") {
      if (!items.length) return `<div class="empty-state">${copy.noResults}</div>`;
      const maxValue = Math.max(...items.map((item) => item.value), 1);
      const chartWidth = 620;
      const labelWidth = 168;
      const valueWidth = 76;
      const plotWidth = chartWidth - labelWidth - valueWidth - 12;
      const rowGap = 28;
      const barHeight = 18;
      const topPad = 18;
      const bottomPad = 18;
      const height = topPad + items.length * rowGap + bottomPad;

      return `
        <div class="chart-shell">
          <svg viewBox="0 0 ${chartWidth} ${height}" role="img" aria-label="dashboard chart">
            ${items
              .map((item, index) => {
                const y = topPad + index * rowGap;
                const width = Math.max((item.value / maxValue) * plotWidth, 8);
                return `
                  <text class="bar-label" x="0" y="${y + 13}">${escapeLabel(item.label)}</text>
                  <line class="grid-line" x1="${labelWidth}" y1="${y + 9}" x2="${chartWidth - valueWidth}" y2="${y + 9}"></line>
                  <rect x="${labelWidth}" y="${y}" rx="9" ry="9" width="${width}" height="${barHeight}" fill="${palette(item.label, index)}"></rect>
                  <text class="value-label" x="${chartWidth - valueWidth + 8}" y="${y + 13}">${formatter(item.value)}</text>
                `;
              })
              .join("")}
            <line class="baseline" x1="${labelWidth}" y1="${height - 8}" x2="${chartWidth - valueWidth}" y2="${height - 8}"></line>
          </svg>
        </div>
      `;
    }

    function renderRiskChart(items, formatter) {
      return renderHorizontalChart(items, formatter, (label) => {
        if (label === "High Risk") return "#ff7777";
        if (label === "Medium Risk") return "#f0b35f";
        return "#53d0db";
      });
    }

    function renderReadout(summary, attritionByDepartment, retentionPriority, externalPressure) {
      const topAttrition = attritionByDepartment[0]?.label || "Não disponível";
      const topPriority = retentionPriority[0]?.label || "Não disponível";
      const topPressure = externalPressure[0]?.label || "Não disponível";

      document.getElementById("heroHighlights").innerHTML = `
        <div class="hero-metric">
          <strong>${formatValue(summary.headcount, "count")}</strong>
          <span class="hero-metric-label">Colaboradores no recorte</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(summary.attritionRate, "percent")}</strong>
          <span class="hero-metric-label">Attrition rate</span>
        </div>
        <div class="hero-metric">
          <strong>${summary.highRiskEmployees}</strong>
          <span class="hero-metric-label">Colaboradores em alto risco</span>
        </div>
        <div class="hero-metric">
          <strong>${formatValue(summary.replacementCost, "currencyCompact")}</strong>
          <span class="hero-metric-label">Exposição de custo</span>
        </div>
      `;

      document.getElementById("readoutGrid").innerHTML = `
        <article class="readout-card">
          <span class="readout-label">Attrition líder</span>
          <strong>${topAttrition}</strong>
          <span>maior sinal atual de attrition</span>
        </article>
        <article class="readout-card">
          <span class="readout-label">Prioridade líder</span>
          <strong>${topPriority}</strong>
          <span>maior prioridade de retenção no corte</span>
        </article>
        <article class="readout-card">
          <span class="readout-label">Mercado líder</span>
          <strong>${topPressure}</strong>
          <span>maior pressão externa no corte</span>
        </article>
        <article class="readout-card">
          <span class="readout-label">Pressão externa</span>
          <strong>${formatValue(summary.externalPressure, "decimal")}</strong>
          <span>média atual do score filtrado</span>
        </article>
      `;

      document.getElementById("insightCopy").innerHTML = `
        <article>
          <h4>Retenção faz mais sentido com contexto</h4>
          <p>O painel junta vulnerabilidade interna com pressão de mercado, deixando a leitura mais próxima do que um time de workforce realmente precisaria priorizar.</p>
        </article>
        <article>
          <h4>Prioridade é o que transforma isso em produto de BI</h4>
          <p>Prioridade de retenção importa mais do que attrition bruto porque combina exposição de custo, sensibilidade do papel e a chance de perder talento para o mercado.</p>
        </article>
        <article>
          <h4>O dashboard fica apoiado em outputs governados</h4>
          <p>Esta página é só a camada visível. O valor reaproveitável do projeto continua nas tabelas semânticas, nas métricas e nos exports de BI.</p>
        </article>
      `;
    }

    function renderDashboard(rows) {
      if (!rows.length) {
        document.getElementById("dashboardGrid").innerHTML = `<div class="empty-state">${copy.noResults}</div>`;
        document.getElementById("heroHighlights").innerHTML = "";
        document.getElementById("readoutGrid").innerHTML = "";
        document.getElementById("insightCopy").innerHTML = "";
        return;
      }

      const summary = computeSummary(rows);
      const attritionByDepartment = groupAverage(rows, "department_name", "attrition_flag");
      const retentionPriority = groupAverage(rows, "department_name", "retention_priority_index");
      const externalPressure = groupAverage(rows, "occupation_group", "external_pressure_score");
      const riskCounts = countBy(rows, "risk_band", ["High Risk", "Medium Risk", "Low Risk"]);

      document.getElementById("dashboardGrid").innerHTML = `
        <article class="panel-card">
          <div class="panel-head">
            <div>
              <h3>Attrition por departamento</h3>
              <span class="panel-note">média filtrada de attrition</span>
            </div>
          </div>
          <p class="panel-copy">Essa leitura mantém visível o sinal de attrition por departamento sem transformar o painel em uma tela de métrica única.</p>
          ${renderHorizontalChart(attritionByDepartment, (value) => `${(value * 100).toFixed(1).replace(".", ",")}%`, () => "#53d0db")}
        </article>
        <article class="panel-card">
          <div class="panel-head">
            <div>
              <h3>Distribuição das bandas de risco</h3>
              <span class="panel-note">contagem de colaboradores por banda</span>
            </div>
          </div>
          <p class="panel-copy">As bandas mantêm a concentração de risco legível a cada filtro, principalmente quando o alto risco é pequeno em volume e grande em urgência.</p>
          ${renderRiskChart(riskCounts, (value) => value.toLocaleString("pt-BR"))}
        </article>
        <article class="panel-card">
          <div class="panel-head">
            <div>
              <h3>Prioridade de retenção por departamento</h3>
              <span class="panel-note">índice combinado de risco e pressão</span>
            </div>
          </div>
          <p class="panel-copy">Aqui a leitura fica mais operacional: os departamentos sobem quando vulnerabilidade interna e pressão externa começam a andar juntas.</p>
          ${renderHorizontalChart(retentionPriority, (value) => value.toFixed(2).replace(".", ","), () => "#9fc8ff")}
        </article>
        <article class="panel-card">
          <div class="panel-head">
            <div>
              <h3>Pressão externa por grupo ocupacional</h3>
              <span class="panel-note">contexto de mercado por exposição do papel</span>
            </div>
          </div>
          <p class="panel-copy">A camada de mercado mostra quais grupos ocupacionais estão mais expostos à pressão externa no recorte filtrado.</p>
          ${renderHorizontalChart(externalPressure, (value) => value.toFixed(2).replace(".", ","), () => "#d7ff6f")}
        </article>
      `;

      renderReadout(summary, attritionByDepartment, retentionPriority, externalPressure);
    }

    let caseData = null;

    function sync() {
      if (!caseData) return;
      renderFilters(caseData.filters);
      const filteredRows = filterRows(caseData.rows, state);
      renderKPIs(computeSummary(filteredRows));
      renderDashboard(filteredRows);
    }

    document.getElementById("resetFilters").addEventListener("click", () => {
      Object.keys(state).forEach((key) => {
        state[key] = [];
      });
      sync();
    });

    loadCaseData().then((payload) => {
      caseData = payload;
      sync();
    });
  </script>
</body>
</html>
