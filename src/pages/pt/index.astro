<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Luanda Rodrigues | Analista de Dados</title><meta name="description" content="Portfólio de Luanda Rodrigues, analista de dados brasileira focada em saúde, BI, SQL, machine learning e inteligência operacional."/><link rel="alternate" hreflang="en" href="/"/><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"><style>:root{--bg:#030303;--ink:#f7f5ef;--soft:#b8b5ad;--muted:#77736d;--line:rgba(247,245,239,.13);--acid:#d7ff6f;--blue:#9fc8ff;--red:#ff7777}*{box-sizing:border-box}html{scroll-behavior:smooth;background:var(--bg)}body{margin:0;background:var(--bg);color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow-x:hidden}body:before{content:"";position:fixed;inset:0;background:radial-gradient(circle at 76% 12%,rgba(215,255,111,.12),transparent 25%),radial-gradient(circle at 8% 26%,rgba(159,200,255,.09),transparent 26%),linear-gradient(rgba(247,245,239,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(247,245,239,.025) 1px,transparent 1px);background-size:auto,auto,82px 82px,82px 82px;pointer-events:none;z-index:-2}a{color:inherit;text-decoration:none}.frame{display:grid;grid-template-columns:minmax(315px,34vw) 1fr;min-height:100vh}.side{position:sticky;top:0;height:100vh;padding:28px;display:flex;flex-direction:column;justify-content:space-between;border-right:1px solid var(--line);overflow:hidden}.brand{display:flex;align-items:center;gap:14px}.brand img{width:72px;height:72px;border-radius:22px;background:#fff}.brand strong{display:block;font-size:24px;line-height:1;letter-spacing:-.055em}.brand span{color:var(--soft);font-size:18px}.intro-card{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:28px 0;margin-top:76px}.intro-card p{font-size:28px;line-height:1.13;letter-spacing:-.055em;color:#e9e5dc;margin:0}.side-viz{height:310px;margin-top:34px;border-bottom:1px solid var(--line);position:relative;overflow:hidden;background:radial-gradient(circle at 45% 45%,rgba(255,255,255,.08),transparent 42%)}.side-viz i{position:absolute;width:6px;height:6px;border-radius:999px;background:#fff;box-shadow:0 0 28px rgba(255,255,255,.35);opacity:.85;animation:float 4s ease-in-out infinite}.side-viz i:nth-child(1){left:12%;top:22%;animation-delay:.1s}.side-viz i:nth-child(2){left:35%;top:16%;animation-delay:.7s}.side-viz i:nth-child(3){left:72%;top:18%;animation-delay:.2s}.side-viz i:nth-child(4){left:22%;top:52%;animation-delay:1.2s}.side-viz i:nth-child(5){left:52%;top:44%;animation-delay:.4s}.side-viz i:nth-child(6){left:82%;top:50%;animation-delay:.9s}.side-viz i:nth-child(7){left:18%;top:78%;animation-delay:1.4s}.side-viz i:nth-child(8){left:47%;top:76%;animation-delay:.6s}.side-viz i:nth-child(9){left:75%;top:82%;animation-delay:1s}.side-viz i:nth-child(10){left:61%;top:28%;animation-delay:1.6s}@keyframes float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(12px,-18px) scale(1.45)}}.side-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:20px}.side-stats div,.detail div{border:1px solid var(--line);border-radius:18px;padding:14px 12px;background:rgba(255,255,255,.025)}.side-stats strong{display:block;font-size:24px;letter-spacing:-.06em}.side-stats span,.detail span{display:block;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;font-size:9px;letter-spacing:.08em;margin-top:4px}.links{display:grid;border-top:1px solid var(--line)}.links a{display:flex;justify-content:space-between;border-bottom:1px solid var(--line);padding:14px 4px;color:var(--soft);font-size:13px;font-weight:700}.main{padding:28px 42px 120px}.topnav{height:58px;display:flex;justify-conten