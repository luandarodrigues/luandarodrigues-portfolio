id{grid-template-columns:1fr}.about-text{border-left:0;border-top:1px solid var(--line)}.about-photo{border-right:0;border-bottom:1px solid var(--line);height:330px}.featured-stats{grid-template-columns:repeat(2,1fr)}}@media(max-width:920px){.frame{display:block}.side{position:relative;height:auto;min-height:0;border-right:0;border-bottom:1px solid var(--line);padding:18px}.brand img{width:54px;height:54px;border-radius:16px}.brand strong{font-size:20px}.brand span{font-size:14px}.intro-card{margin-top:22px;padding:18px 0}.intro-card p{font-size:22px;line-height:1.16}.side-viz{height:150px;margin-top:18px;border-radius:24px}.side-stats{grid-template-columns:repeat(3,minmax(0,1fr))}.stat{padding:10px}.stat strong{font-size:19px}.links{display:grid;grid-template-columns:repeat(2,1fr);gap:0;margin-top:14px}.links a{font-size:12px;padding:12px 4px}.main{padding:0 18px 70px}.topnav{justify-content:flex-start;overflow-x:auto;gap:10px;height:auto;padding:12px 0;top:0;scrollbar-width:none}.topnav::-webkit-scrollbar{display:none}.topnav a{font-size:11px;letter-spacing:.06em;flex:0 0 auto;border:1px solid var(--line);border-radius:999px;padding:8px 10px}.hero{min-height:auto;padding:54px 0 64px}.hero h1{font-size:clamp(48px,15vw,76px);line-height:.86;letter-spacing:-.075em}.split,.cloud-pin,.title,.grid,.summary,.contact-layout,.project-meta,.featured-stats{grid-template-columns:1fr}.split p{font-size:18px;line-height:1.38}.section,.featured{padding:64px 0}.about-shell{border-radius:28px}.about-title,.about-text{padding:20px}.about h2,.cloud-copy h2,.title h2,.featured-copy h2{font-size:clamp(38px,12vw,62px);line-height:.9}.about-photo{height:280px}.about-cards{grid-template-columns:1fr}.about-card{min-height:auto;border-right:0;border-bottom:1px solid var(--line)}.about-card:nth-child(n+3){border-bottom:1px solid var(--line)}.about-card:last-child{border-bottom:0}.cloud-section{height:auto}.cloud-pin{position:relative;top:auto;height:auto;padding:64px 0;display:block}.cloud-