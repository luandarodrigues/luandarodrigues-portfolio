  <script>
    function initMiniGraph(){const c=document.getElementById('sideGraphCanvas');if(!c)return;const box=c.parentElement,ctx=c.getContext('2d');let w=0,h=0,dpr=1,pts=[];function size(){dpr=Math.min(devicePixelRatio||1,2);w=box.clientWidth;h=box.clientHeight;c.width=w*dpr;c.height=h*dpr;c.style.width=w+'px';c.style.height=h+'px';ctx.setTransform(dpr,0,0,dpr,0,0)}function reset(){size();pts=[];const hubs=[[.24,.34,'#d7ff6f'],[.62,.43,'#9fc8ff'],[.45,.72,'#f7f5ef']];hubs.forEach((hub,hi)=>{pts.push({x:w*hub[0],y:h*hub[1],vx:0,vy:0,r:4.2,c:hub[2],hub:true,group:hi});for(let i=0;i<18;i++){const a=Math.random()*Math.PI*2,rad=28+Math.random()*78;pts.push({x:w*hub[0]+Math.cos(a)*rad,y:h*hub[1]+Math.sin(a)*rad,vx:(Math.random()-.5)*.55,vy:(Math.random()-.5)*.55,r:1.3+Math.random()*1.8,c:hub[2],group:hi})}})}function draw(){ctx.clearRect(0,0,w,h);pts.forEach((p,i)=>{p.x+=p.vx+Math.sin(Date.now()/650+i)*.06;p.y+=p.vy+Math.cos(Date.now()/730+i)*.06;if(p.x<14||p.x>w-14)p.vx*=-1;if(p.y<14||p.y>h-26)p.vy*=-1});for(let i=0;i<pts.length;i++){for(let j=i+1;j<pts.length;j++){const a=pts[i],b=pts[j],d=Math.hypot(a.x-b.x,a.y-b.y);if(d<100&&(a.group===b.group||d<52)){ctx.globalAlpha=Math.max(.04,.25-d/410);ctx.strokeStyle=a.group===b.group?'#d9d9d9':'#8d8d8d';ctx.lineWidth=a.hub||b.hub?.75:.45;ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.stroke()}}}pts.forEach(p=>{ctx.globalAlpha=p.hub?.92:.74;ctx.fillStyle=p.c;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();if(p.hub){ctx.globalAlpha=.15;ctx.beginPath();ctx.arc(p.x,p.y,34,0,Math.PI*2);ctx.fill()}});requestAnimationFrame(draw)}addEventListener('resize',reset);reset();draw()}initMiniGraph();
    const summaries={projects:['Projetos','O case principal da OMS esta logo acima. Estes outros projetos mostram como eu trabalho com saude, machine learning, SQL, grafos, NLP e comunicacao orientada a decisao.'],methodtab:['Metodo','Fluxo pratico de dados: enquadrar decisao, auditar dados, construir camada analitica, escolher metodo e comunicar limites.'],stack:['Stack','Ferramentas usadas nos projetos: Python, SQL, Pandas, Power BI, Scikit-learn, NetworkX, NLP e dashboards.'],background:['Background','Carreira por tras dos projetos: saude, Engenharia Biomedica, Gestao Hospitalar, EBSERH/HC-UFU e marketing technology.']};function setTab(id){document.querySelectorAll('.tabbtn').forEach(b=>b.classList.toggle('active',b.dataset.tab===id));document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active',p.id===id));tabTitle.textContent=summaries[id][0];tabText.textContent=summaries[id][1]}document.querySelectorAll('.tabbtn').forEach(btn=>btn.addEventListener('click',()=>setTab(btn.dataset.tab)));const featuredToggle=document.getElementById('featuredToggle'),featuredDetail=document.getElementById('featuredDetail');if(featuredToggle&&featuredDetail){featuredToggle.addEventListener('click',()=>{const expanded=featuredToggle.getAttribute('aria-expanded')==='true';featuredToggle.setAttribute('aria-expanded',String(!expanded));featuredDetail.classList.toggle('open',!expanded);featuredToggle.textContent=expanded?'Abrir case':'Fechar case'})}
    contactForm.addEventListener('submit',async e=>{e.preventDefault();const btn=e.target.querySelector('button');btn.textContent='Enviando...';const data={name:name.value,company:company.value,email:email.value,message:message.value};try{const r=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});if(!r.ok)throw new Error('erro');btn.textContent='Enviado ✓';e.target.reset()}catch(err){btn.textContent='Erro — tentar email';location.href='mailto:luandarodrigues30@gmail.com'}});
    const canvas=graphCanvas,ctx=canvas.getContext('2d'),stage=cloudStage;let W=0,H=0,dpr=1,nodes=[],edges=[],mode='cluster';const groups=[{name:'saude',color:'#d7ff6f',cx:.25,cy:.32,count:innerWidth<520?28:70,labels:['saúde','saúde pública','HC-UFU','EBSERH','farmácia clínica','UBS','SUS','geodados']},{name:'modelos',color:'#ff7777',cx:.72,cy:.34,count:innerWidth<520?26:62,labels:['machine learning','Scikit-learn','ROC-AUC','NLP','TF-IDF','reviews','risco']},{name:'ops',color:'#9fc8ff',cx:.55,cy:.72,count:innerWidth<520?30:74,labels:['Power BI','SQL','dashboards','KPIs','ETL','Pandas','operações']}];function resize(){dpr=Math.min(devicePixelRatio||1,2);W=stage.clientWidth;H=stage.clientHeight;canvas.width=W*dpr;canvas.height=H*dpr;canvas.style.width=W+'px';canvas.style.height=H+'px';ctx.setTransform(dpr,0,0,dpr,0,0)}function build(){resize();nodes=[];edges=[];let id=0;groups.forEach(g=>{let hub={id:id++,group:g.name,color:g.color,label:g.name,x:W*g.cx,y:H*g.cy,tx:W*g.cx,ty:H*g.cy,r:7,hub:true};nodes.push(hub);g.labels.forEach(l=>nodes.push({id:id++,group:g.name,color:g.color,label:l,x:W*(g.cx+(Math.random()-.5)*.25),y:H*(g.cy+(Math.random()-.5)*.25),r:3.6,major:true}));for(let i=0;i<g.count;i++)nodes.push({id:id++,group:g.name,color:g.color,label:'',x:W*(g.cx+(Math.random()-.5)*.35),y:H*(g.cy+(Math.random()-.5)*.35),r:1.7+Math.random()*1.8})});nodes.forEach(a=>{let same=nodes.filter(n=>n.group===a.group&&n.id!==a.id);for(let k=0;k<(a.hub?18:a.major?4:1);k++)edges.push([a,same[Math.floor(Math.random()*same.length)]]);if(Math.random()<.14){let b=nodes[Math.floor(Math.random()*nodes.length)];if(b.group!==a.group)edges.push([a,b])}});setTargets('cluster')}function setTargets(kind){mode=kind;groups.forEach(g=>{let list=nodes.filter(n=>n.group===g.name),cx=W*g.cx,cy=H*g.cy;list.forEach((n,i)=>{if(kind==='cluster'){let ang=i*.62,rad=n.hub?0:(n.major?45+Math.random()*50:70+Math.random()*Math.min(W,H)*.22);n.tx=cx+Math.cos(ang)*rad;n.ty=cy+Math.sin(ang)*rad}else{let ang=Math.random()*Math.PI*2,rad=Math.sqrt(Math.random())*Math.min(W,H)*.42;n.tx=W*.5+Math.cos(ang)*rad;n.ty=H*.52+Math.sin(ang)*rad}})})}function draw(){ctx.clearRect(0,0,W,H);nodes.forEach(n=>{n.x+=(n.tx-n.x)*.05;n.y+=(n.ty-n.y)*.05;n.x+=Math.sin(Date.now()/900+n.id)*.08;n.y+=Math.cos(Date.now()/1000+n.id)*.08});ctx.lineWidth=.65;edges.forEach(([a,b])=>{let d=Math.hypot(a.x-b.x,a.y-b.y);if(d<240){ctx.globalAlpha=Math.max(.03,.22-d/1000);ctx.strokeStyle='#9a9a9a';ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.stroke()}});nodes.forEach(n=>{ctx.globalAlpha=n.hub?.95:n.major?.82:.65;ctx.fillStyle=n.hub?'#d8d8d8':n.color;ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fill();if(n.major||n.hub){ctx.globalAlpha=.62;ctx.font=(n.hub?'700 12px ':'500 10px ')+'IBM Plex Mono';ctx.fillStyle='#d7d7d7';ctx.fillText(n.label,n.x+8,n.y-8)}});requestAnimationFrame(draw)}stage.addEventListener('click',()=>setTargets(mode==='cluster'?'spread':'cluster'));shuffleCloud.addEventListener('click',()=>setTargets('spread'));clusterCloud.addEventListener('click',()=>setTargets('cluster'));addEventListener('resize',()=>{resize();setTargets(mode)});build();draw();
    const observer=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.12});document.querySelectorAll('.reveal,.card,.box,.about-card,.featured-shell').forEach(el=>observer.observe(el));
  </script>
