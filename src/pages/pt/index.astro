lor:#2c2925;font-size:clamp(20px,2.6vw,34px);line-height:1.08;letter-spacing:-.04em;margin:0}.availability,.buttons,.stats,.caption{display:flex;flex-wrap:wrap;gap:8px}.availability{margin:26px 0 34px}.pill,.caption span{border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.35);padding:8px 11px;font-size:11px}.btn{display:inline-flex;border:1px solid var(--line);border-radius:999px;padding:13px 18px;font-weight:800;font-size:14px;background:rgba(255,255,255,.26);transition:.2s}.btn.primary{color:var(--bg);background:var(--ink);border-color:var(--ink)}.glass{border:1px solid var(--line);background:var(--card);backdrop-filter:blur(16px);box-shadow:0 24px 80px rgba(9,9,9,.08)}.portrait{border-radius:44px;padding:16px}.portrait img{width:100%;display:block;border-radius:32px}.caption{margin-top:12px}.ticker{width:100vw;margin-left:calc(50% - 50vw);overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.28);white-space:nowrap}.track{display:inline-flex;animation:ticker 36s linear infinite}.track span{font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-size:13px;font-weight:700;padding:18px 24px}.track span:after{content:"";display:inline-block;width:5px;height:5px;border-radius:50%;background:#28241f;opacity:.5;margin-left:22px}@keyframes ticker{to{transform:translateX(-50%)}}.about{display:grid;grid-template-columns:.75fr 1.25fr;gap:clamp(32px,6vw,80px)}h2{margin:18px 0 0;font-size:clamp(48px,7vw,96px);line-height:.84}.about-text>p{margin:0;color:#38332d;font-size:22px;line-height:1.35;letter-spacing:-.035em}.about-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:34px}.about-grid article,.project-card{border:1px solid var(--line);background:rgba(255,255,255,.36)}.about-grid article{padding:22px;border-radius:26px}.about-grid h3{margin:32px 0 10px;font-size:24px;line-height:1;letter-spacing:-.05em}.about-grid p,.project-card p{color:var(--muted)}.head{display:grid;grid-template-columns:.75fr 1.25fr;gap:clamp(28px,6vw,80px);margin-bottom:42px}.head h2{margin:0}.project-list{display:grid;gap:16px}.project-card{display:grid;grid-template-columns:80px 1fr auto;gap:28px;align-items:start;padding:30px;border-radius:30px;transition:.25s}.number{font-size:42px;font-weight:900;letter-spacing:-.08em}.project-card h3{margin:8px 0 14px;font-size:clamp(30px,4vw,58px);line-height:.95;letter-spacing:-.065em}.project-card a{border:1px solid var(--line);border-radius:999px;padding:12px 15px;font-weight:800;white-space:nowrap}.stats span{border:1px solid var(--line);border-radius:999px;padding:7px 10px;background:rgba(255,255,255,.32);font-family:'IBM Plex Mono';font-size:11px;font-weight:700}.cloud{min-height:100vh;padding:clamp(64px,8vw,110px) 0;display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(28px,5vw,70px);align-items:center;border-bottom:1px solid var(--line)}.cloud h2{font-size:clamp(52px,7vw,104px);line-height:.82}.cloud-copy>p:not(.kicker){color:#38332d;font-size:20px;line-height:1.35;max-width:440px}.status{margin-top:30px;display:flex;flex-wrap:wrap;gap:8px;overflow:hidden}.status span{transform:translateY(20px);opacity:0}.stage{position:relative;min-height:560px;border-radius:48px;overflow:hidden;background:radial-gradient(circle at 28% 22%,rgba(199,214,203,.65),transparent 22%),radial-gradient(circle at 70% 76%,rgba(231,222,209,.72),transparent 28%),rgba(255,255,255,.48)}.stage:before{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(9,9,9,.055) 1px,transparent 1px),linear-gradient(90deg,rgba(9,9,9,.055) 1px,transparent 1px);background-size:54px 54px;mask-image:linear-gradient(to bottom,black,transparent 82%)}.cloud-line{position:absolute;inset:0;width:100%;height:100%;opacity:0;fill:none;stroke:rgba(9,9,9,.35);stroke-width:1.4}.node{position:absolute;transform:translate(-50%,-50%);border:1px solid rgba(9,9,9,.12);border-radius:999px;padding:10px 14px;background:rgba(255,255,255,.70);font-size:12px;box-shadow:0 12px 36px rgba(9,9,9,.08);white-space:nowrap}.contact{padding-bottom:150px}.contact h2{max-width:900px;font-size:clamp(52px,8vw,112px)}.contact p:not(.kicker){color:var(--muted);font-size:22px;letter-spacing:-.03em;margin-bottom:32px}@media(max-width:920px){.hero,.about,.head,.project-card,.cloud{grid-template-columns:1fr}.portrait{max-width:520px}.stage{min-height:480px}}@media(max-width:760px){main,.header,.cloud{width:min(100% - 24px,1180px)}.header{align-items:flex-start;flex-direction:column;gap:18px}.nav{flex-wrap:wrap;gap:12px}.about-grid{grid-template-columns:1fr}h1{font-size:68px}.project-card a{width:fit-content}}
