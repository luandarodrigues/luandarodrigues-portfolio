            <div class="box"><span>Análise</span><h3>Python &middot; Pandas &middot; NumPy</h3><p>Limpeza, exploração, nulos, features e checagens de consistência.</p></div>
            <div class="box"><span>SQL &amp; Dados</span><h3>SQL &middot; joins &middot; modelagem</h3><p>Consultas analíticas, CTEs, chaves, granularidade e desenho de datasets.</p></div>
            <div class="box"><span>BI</span><h3>Power BI &middot; Looker &middot; KPIs</h3><p>Dashboards, indicadores, monitoramento e métricas para decisão.</p></div>
            <div class="box"><span>Machine Learning</span><h3>Scikit-learn &middot; ROC-AUC</h3><p>Classificação, validação, comparação de modelos e interpretação.</p></div>
            <div class="box"><span>Grafos &amp; NLP</span><h3>NetworkX &middot; TF-IDF &middot; reviews</h3><p>Redes, relações, recomendações e mineração de texto.</p></div>
            <div class="box"><span>Operações</span><h3>Saúde &middot; logística &middot; experiência</h3><p>Fluxos, gargalos, atrasos, cobertura e impacto operacional.</p></div>
          </div>
        </div>

        <div class="panel" id="background">
          <div class="grid">
            <div class="box"><span>Saúde</span><h3>Operações hospitalares</h3><p>Fluxos de farmácia clínica, KPIs, dados públicos e apoio à decisão.</p></div>
            <div class="box"><span>Formação</span><h3>Engenharia Biomédica + Gestão Hospitalar</h3><p>Pensamento sistêmico, tecnologia em saúde e base analítica.</p></div>
            <div class="box"><span>Setor público</span><h3>EBSERH &middot; 5º lugar</h3><p>Contexto de saúde pública brasileira e visão operacional hospitalar.</p></div>
            <div class="box"><span>Digital</span><h3>Marketing technology</h3><p>Conteúdo, design, e-mail HTML, comunicação científica, automação e fluxos com IA.</p></div>
          </div>
        </div>
      </section>

      <section class="contact-divider" aria-hidden="true">
        <span></span><span></span><span></span>
      </section>

      <section class="contact" id="contact">
        <div>
          <p class="eyebrow">Contato</p>
          <h2>Vamos conectar dados, operações e <span class="section-accent">decisões.</span></h2>
          <div class="contact-layout">
            <div>
              <p class="note">Envie uma mensagem estruturada direto por aqui. O formulário encaminha tudo para a minha caixa de entrada.</p>
              <div class="row">
                <a class="btn" href="https://github.com/luandarodrigues">GitHub</a>
                <a class="btn" href="https://www.linkedin.com/in/luanda-rodrigues">LinkedIn</a>
              </div>
            </div>
            <form id="contactForm">
              <label for="name">Nome</label>
              <input id="name" placeholder="Seu nome" required />
              <label for="company">Empresa</label>
              <input id="company" placeholder="Empresa ou organização" />
              <label for="email">Email</label>
              <input id="email" type="email" placeholder="voce@email.com" />
              <label for="message">Mensagem</label>
              <textarea id="message" placeholder="Sobre o que você gostaria de conversar?" required></textarea>
              <button type="submit">Enviar mensagem</button>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    function initMiniGraph() {
      const canvas = document.getElementById('sideGraphCanvas');
      if (!canvas) return;
      const box = canvas.parentElement;
      const ctx = canvas.getContext('2d');
      let width = 0;
      let height = 0;
      let dpr = 1;
      let points = [];

      function size() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = box.clientWidth;
        height = box.clientHeight;
        canvas.width = width * dpr;
        canvas.height = height * dpr;
        canvas.style.width = width + 'px';
        canvas.style.height = height + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function reset() {
        size();
        points = [];
        const hubs = [
          [0.26, 0.36, '#14b8a6'],
          [0.68, 0.34, '#a78bfa'],
          [0.52, 0.72, '#fbbf24'],
        ];

        hubs.forEach((hub, hubIndex) => {
          points.push({ x: width * hub[0], y: height * hub[1], vx: 0, vy: 0, r: 4.4, c: hub[2], hub: true, group: hubIndex });
          for (let i = 0; i < 18; i += 1) {
            const angle = Math.random() * Math.PI * 2;
            const radius = 28 + Math.random() * 76;
            points.push({
              x: width * hub[0] + Math.cos(angle) * radius,
              y: height * hub[1] + Math.sin(angle) * radius,
              vx: (Math.random() - 0.5) * 0.5,
              vy: (Math.random() - 0.5) * 0.5,
              r: 1.3 + Math.random() * 1.7,
              c: hub[2],
              group: hubIndex
            });
          }
        });
      }

      function draw() {
        ctx.clearRect(0, 0, width, height);
        points.forEach((point, index) => {
          point.x += point.vx + Math.sin(Date.now() / 650 + index) * 0.06;
          point.y += point.vy + Math.cos(Date.now() / 720 + index) * 0.06;
          if (point.x < 14 || point.x > width - 14) point.vx *= -1;
          if (point.y < 14 || point.y > height - 24) point.vy *= -1;
        });
        for (let i = 0; i < points.length; i += 1) {
          for (let j = i + 1; j < points.length; j += 1) {
            const a = points[i];
            const b = points[j];
            const distance = Math.hypot(a.x - b.x, a.y - b.y);
            if (distance < 104 && (a.group === b.group || distance < 52)) {
              ctx.globalAlpha = Math.max(0.04, 0.24 - distance / 420);
              ctx.strokeStyle = a.group === b.group ? '#d2cec5' : '#6f6b63';
              ctx.lineWidth = a.hub || b.hub ? 0.75 : 0.45;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
        points.forEach((point) => {
          ctx.globalAlpha = point.hub ? 0.95 : 0.76;
          ctx.fillStyle = point.c;
          ctx.beginPath();
          ctx.arc(point.x, point.y, point.r, 0, Math.PI * 2);
          ctx.fill();
          if (point.hub) {
            ctx.globalAlpha = 0.12;
            ctx.beginPath();
            ctx.arc(point.x, point.y, 34, 0, Math.PI * 2);
            ctx.fill();
          }
        });
        requestAnimationFrame(draw);
      }

      window.addEventListener('resize', reset);
      reset();
      draw();
    }

    initMiniGraph();

    const summaries = {
      projects: ['Projetos', 'O case principal da OMS está logo acima. Estes outros projetos mostram como eu trabalho com saúde, machine learning, SQL, grafos, NLP e comunicação orientada à decisão.'],
      methodtab: ['Método', 'Fluxo prático de dados: enquadrar a decisão, auditar dados, construir a camada analítica, escolher o método e comunicar os limites.'],
      stack: ['Stack', 'Ferramentas usadas nos projetos: Python, SQL, Pandas, Power BI, Scikit-learn, NetworkX, NLP e dashboards.'],
      background: ['Background', 'A camada de trajetória por trás dos projetos: saúde, Engenharia Biomédica, Gestão Hospitalar, EBSERH/HC-UFU e marketing technology.']
    };

    const tabTitle = document.getElementById('tabTitle');
    const tabText = document.getElementById('tabText');

    function setTab(id) {
      document.querySelectorAll('.tabbtn').forEach((button) => {
        button.classList.toggle('active', button.dataset.tab === id);
      });
      document.querySelectorAll('.panel').forEach((panel) => {
        panel.classList.toggle('active', panel.id === id);
      });
      tabTitle.textContent = summaries[id][0];
      tabText.textContent = summaries[id][1];
    }

    document.querySelectorAll('.tabbtn').forEach((button) => {
      button.addEventListener('click', () => setTab(button.dataset.tab));
    });

    const featuredToggle = document.getElementById('featuredToggle');
    const featuredDetail = document.getElementById('featuredDetail');

    if (featuredToggle && featuredDetail) {
      featuredToggle.addEventListener('click', () => {
        const expanded = featuredToggle.getAttribute('aria-expanded') === 'true';
        featuredToggle.setAttribute('aria-expanded', String(!expanded));
        featuredDetail.classList.toggle('open', !expanded);
        featuredToggle.textContent = expanded ? 'Abrir case' : 'Fechar case';
      });
    }

    const contactForm = document.getElementById('contactForm');

    if (contactForm) {
      contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const button = contactForm.querySelector('button');
        button.textContent = 'Enviando...';
        const data = {
          name: document.getElementById('name').value,
          company: document.getElementById('company').value,
          email: document.getElementById('email').value,
          message: document.getElementById('message').value
        };

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (!response.ok) throw new Error('request failed');
          button.textContent = 'Enviado';
          contactForm.reset();
        } catch (error) {
          button.textContent = 'Tente pelo email';
          location.href = 'mailto:luandarodrigues30@gmail.com';
        }
      });
    }

    const stage = document.getElementById('cloudStage');
    const graphCanvas = document.getElementById('graphCanvas');
    const graphCtx = graphCanvas.getContext('2d');
    let graphWidth = 0;
    let graphHeight = 0;
    let graphDpr = 1;
    let nodes = [];
    let edges = [];
    let mode = 'cluster';

    const groups = [
      { name: 'saude', color: '#14b8a6', cx: 0.26, cy: 0.34, count: window.innerWidth < 520 ? 28 : 70, labels: ['saúde', 'saúde pública', 'HC-UFU', 'EBSERH', 'farmácia clínica', 'UBS', 'SUS', 'geodados'] },
      { name: 'modelos', color: '#a78bfa', cx: 0.73, cy: 0.33, count: window.innerWidth < 520 ? 26 : 62, labels: ['machine learning', 'Scikit-learn', 'ROC-AUC', 'NLP', 'TF-IDF', 'reviews', 'risco'] },
      { name: 'ops', color: '#fbbf24', cx: 0.56, cy: 0.74, count: window.innerWidth < 520 ? 30 : 74, labels: ['Power BI', 'SQL', 'dashboards', 'KPIs', 'ETL', 'Pandas', 'operações'] }
    ];

    function resizeGraph() {
      graphDpr = Math.min(window.devicePixelRatio || 1, 2);
      graphWidth = stage.clientWidth;
      graphHeight = stage.clientHeight;
      graphCanvas.width = graphWidth * graphDpr;
      graphCanvas.height = graphHeight * graphDpr;
      graphCanvas.style.width = graphWidth + 'px';
      graphCanvas.style.height = graphHeight + 'px';
      graphCtx.setTransform(graphDpr, 0, 0, graphDpr, 0, 0);
    }

    function setTargets(kind) {
      mode = kind;
      groups.forEach((group) => {
        const list = nodes.filter((node) => node.group === group.name);
        const cx = graphWidth * group.cx;
        const cy = graphHeight * group.cy;
        list.forEach((node, index) => {
          if (kind === 'cluster') {
            const angle = index * 0.62;
            const radius = node.hub ? 0 : (node.major ? 48 + Math.random() * 52 : 74 + Math.random() * Math.min(graphWidth, graphHeight) * 0.21);
            node.tx = cx + Math.cos(angle) * radius;
            node.ty = cy + Math.sin(angle) * radius;
          } else {
            const angle = Math.random() * Math.PI * 2;
            const radius = Math.sqrt(Math.random()) * Math.min(graphWidth, graphHeight) * 0.42;
            node.tx = graphWidth * 0.5 + Math.cos(angle) * radius;
            node.ty = graphHeight * 0.52 + Math.sin(angle) * radius;
          }
        });
      });
    }

    function buildGraph() {
      resizeGraph();
      nodes = [];
      edges = [];
      let id = 0;
      groups.forEach((group) => {
        const hub = { id: id += 1, group: group.name, color: group.color, label: group.name, x: graphWidth * group.cx, y: graphHeight * group.cy, tx: graphWidth * group.cx, ty: graphHeight * group.cy, r: 7, hub: true };
        nodes.push(hub);
        group.labels.forEach((label) => {
          nodes.push({
            id: id += 1,
            group: group.name,
            color: group.color,
            label,
            x: graphWidth * (group.cx + (Math.random() - 0.5) * 0.25),
            y: graphHeight * (group.cy + (Math.random() - 0.5) * 0.25),
            r: 3.6,
            major: true
          });
        });
        for (let i = 0; i < group.count; i += 1) {
          nodes.push({
            id: id += 1,
            group: group.name,
            color: group.color,
            label: '',
            x: graphWidth * (group.cx + (Math.random() - 0.5) * 0.35),
            y: graphHeight * (group.cy + (Math.random() - 0.5) * 0.35),
            r: 1.7 + Math.random() * 1.8
          });
        }
      });

      nodes.forEach((node) => {
        const sameGroup = nodes.filter((candidate) => candidate.group === node.group && candidate !== node);
        for (let i = 0; i < (node.hub ? 18 : node.major ? 4 : 1); i += 1) {
          edges.push([node, sameGroup[Math.floor(Math.random() * sameGroup.length)]]);
        }
        if (Math.random() < 0.14) {
          const other = nodes[Math.floor(Math.random() * nodes.length)];
          if (other.group !== node.group) edges.push([node, other]);
        }
      });

      setTargets('cluster');
    }

    function drawGraph() {
      graphCtx.clearRect(0, 0, graphWidth, graphHeight);
      nodes.forEach((node) => {
        node.x += (node.tx - node.x) * 0.05;
        node.y += (node.ty - node.y) * 0.05;
        node.x += Math.sin(Date.now() / 900 + node.id) * 0.08;
        node.y += Math.cos(Date.now() / 1000 + node.id) * 0.08;
      });

      graphCtx.lineWidth = 0.65;
      edges.forEach(([a, b]) => {
        const distance = Math.hypot(a.x - b.x, a.y - b.y);
        if (distance < 240) {
          graphCtx.globalAlpha = Math.max(0.03, 0.22 - distance / 1000);
          graphCtx.strokeStyle = '#8f8a81';
          graphCtx.beginPath();
          graphCtx.moveTo(a.x, a.y);
          graphCtx.lineTo(b.x, b.y);
          graphCtx.stroke();
        }
      });

      nodes.forEach((node) => {
        graphCtx.globalAlpha = node.hub ? 0.95 : node.major ? 0.84 : 0.68;
        graphCtx.fillStyle = node.hub ? '#f5f1e8' : node.color;
        graphCtx.beginPath();
        graphCtx.arc(node.x, node.y, node.r, 0, Math.PI * 2);
        graphCtx.fill();
        if (node.major || node.hub) {
          graphCtx.globalAlpha = 0.66;
          graphCtx.font = (node.hub ? '700 12px ' : '500 10px ') + 'Space Mono';
          graphCtx.fillStyle = '#d5d0c7';
          graphCtx.fillText(node.label, node.x + 8, node.y - 8);
        }
      });

      requestAnimationFrame(drawGraph);
    }

    stage.addEventListener('click', () => setTargets(mode === 'cluster' ? 'spread' : 'cluster'));
    document.getElementById('shuffleCloud').addEventListener('click', () => setTargets('spread'));
    document.getElementById('clusterCloud').addEventListener('click', () => setTargets('cluster'));
    window.addEventListener('resize', () => {
      resizeGraph();
      setTargets(mode);
    });
    buildGraph();
    drawGraph();

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('in');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal,.card,.box,.about-card,.featured-shell').forEach((element) => {
      observer.observe(element);
    });
  </script>
</body>
</html>
